# Database - SQL Server
DB_PASSWORD=Change_this_SQL_Server_password_123!
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=OmniBizDB;User Id=sa;Password=Change_this_SQL_Server_password_123!;TrustServerCertificate=True;

# JWT
Jwt__Secret=change-this-jwt-secret-at-least-32-characters
Jwt__Issuer=OmniBizAI
Jwt__Audience=OmniBizAI

# Frontend / CORS
AllowedOrigins=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Optional AI provider values for future external LLM adapters
AI__Provider=LocalRulesFallback
AI__ApiKey=
AI__Model=local-rules-fallback
