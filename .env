# OmniBizAI local environment
# Fill your local secrets here. This file is ignored by git.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5170
AllowedHosts=localhost

# Database
# Default local development connection. Replace with remote SQL Server when needed.
ConnectionStrings__DefaultConnection=Server=.\SQLEXPRESS;Database=OmniBizDB;User Id=kpiokr;Password=Anhquan0108;TrustServerCertificate=True;Encrypt=False

# Remote SQL Server template:
# ConnectionStrings__DefaultConnection=Server=YOUR_SQL_HOST,1433;Database=OmniBizDB;User Id=YOUR_SQL_USER;Password=YOUR_SQL_PASSWORD;TrustServerCertificate=True;Encrypt=False

# AI provider
AI__Provider=Gemini
AI__Model=gemini-1.5-flash
AI__ApiKey=AQ.Ab8RN6Kg0wG1pf74U0WJR1HVqnyPrwbl04mi07ITtqwbDH6ZOg
AI__Mode=Mock
AI__UseMock=true
AI__MaxPromptTokens=12000

# Cache / notification
Cache__Provider=Memory
Redis__ConnectionString=localhost:6379
Notification__RealtimeEnabled=false

# Demo seed accounts
Seed__AdminEmail=admin@omnibiz.ai
Seed__DirectorEmail=director@omnibiz.ai
Seed__ManagerEmail=manager.mkt@omnibiz.ai
Seed__StaffEmail=staff.mkt@omnibiz.ai
Seed__DefaultPassword=

# Upload / report
FileStorage__RootPath=wwwroot/uploads
Upload__MaxFileSizeMB=10
Report__EnableAiSummary=true

# Security
Security__RequireConfirmedAccount=false
Security__CookieSecurePolicy=SameAsRequest
