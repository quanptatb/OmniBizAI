{
  "AI": {
    "Provider": "Gemini",
    "Model": "gemini-1.5-flash",
    "Mode": "Mock",
    "UseMock": true,
    "MaxPromptTokens": 12000
  },
  "Cache": {
    "Provider": "Memory"
  },
  "Notification": {
    "RealtimeEnabled": false
  },
  "Report": {
    "EnableAiSummary": true
  },
  "Security": {
    "RequireConfirmedAccount": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
