@model OmniBizAI.ViewModels.AuditLogListViewModel
@{
    ViewData["Title"] = "Nhật ký Hệ thống";
    ViewData["Breadcrumb"] = "<span>Kiểm soát</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>Nhật ký</span>";
}

<div class="content-card mb-4">
    <div class="card-body-custom py-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Loại Entity</label>
                <input type="text" name="entityType" value="@Model.EntityTypeFilter" class="form-control" placeholder="VD: OperationRequest">
            </div>
            <div class="col-md-3">
                <label class="form-label">Hành động</label>
                <select name="action" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="Create" selected="@(Model.ActionFilter == "Create")">Create</option>
                    <option value="Submit" selected="@(Model.ActionFilter == "Submit")">Submit</option>
                    <option value="Approve" selected="@(Model.ActionFilter == "Approve")">Approve</option>
                    <option value="Reject" selected="@(Model.ActionFilter == "Reject")">Reject</option>
                    <option value="Cancel" selected="@(Model.ActionFilter == "Cancel")">Cancel</option>
                    <option value="AiQuery" selected="@(Model.ActionFilter == "AiQuery")">AI Query</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Người thực hiện</label>
                <input type="text" name="user" value="@Model.UserFilter" class="form-control" placeholder="Tên người dùng">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="fa-solid fa-filter me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-light"><i class="fa-solid fa-rotate-left"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="content-card">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-shield-halved"></i> Nhật ký hoạt động</h5>
        <span class="badge" style="background:var(--apple-blue);color:#fff">@Model.TotalCount</span>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="ps-4">Thời gian</th>
                    <th>Người thực hiện</th>
                    <th>Hành động</th>
                    <th>Entity</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Items)
                {
                    <tr>
                        <td class="ps-4" style="white-space:nowrap;color:var(--text-muted)">
                            <i class="fa-regular fa-clock me-1"></i>@log.CreatedAt.ToString("HH:mm:ss dd/MM/yyyy")
                        </td>
                        <td style="font-weight:500">@log.UserName</td>
                        <td>
                            @{
                                var actionBadge = log.Action switch {
                                    "Create" => "badge-on-track",
                                    "Approve" => "badge-on-track",
                                    "Reject" => "badge-late",
                                    "Submit" => "badge-at-risk",
                                    _ => ""
                                };
                            }
                            <span class="status-badge-soft @actionBadge"><span class="status-dot"></span>@log.Action</span>
                        </td>
                        <td><span class="badge" style="background:var(--parchment);color:var(--text-secondary);border:1px solid var(--divider)">@log.EntityType</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.NewValues))
                            {
                                <code class="text-truncate d-inline-block" style="max-width:280px;font-size:.78rem;color:var(--text-secondary)" title="@log.NewValues">@log.NewValues</code>
                            }
                            else
                            {
                                <span style="color:var(--text-muted)">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="5" class="text-center py-5" style="color:var(--text-muted)"><i class="fa-solid fa-shield fa-2x d-block mb-2 opacity-50"></i>Không có nhật ký</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalCount > 50)
    {
        <div class="pagination-custom">
            <span>Trang @Model.Page / @Math.Ceiling(Model.TotalCount / 50.0)</span>
            <div class="pagination-pages">
                <a class="page-btn @(Model.Page == 1 ? "disabled" : "")" asp-action="Index" asp-route-page="@(Model.Page-1)" asp-route-entityType="@Model.EntityTypeFilter" asp-route-action="@Model.ActionFilter" asp-route-user="@Model.UserFilter">‹</a>
                <a class="page-btn @(Model.Page * 50 >= Model.TotalCount ? "disabled" : "")" asp-action="Index" asp-route-page="@(Model.Page+1)" asp-route-entityType="@Model.EntityTypeFilter" asp-route-action="@Model.ActionFilter" asp-route-user="@Model.UserFilter">›</a>
            </div>
        </div>
    }
</div>
