@model OmniBizAI.Models.Entities.Department
@{
    ViewData["Title"] = "Edit Department";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="fw-bold text-primary">Edit Department</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label text-muted fw-semibold small">Department Code</label>
                            <input asp-for="Code" class="form-control rounded-3" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label text-muted fw-semibold small">Department Name</label>
                            <input asp-for="Name" class="form-control rounded-3" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CompanyId" class="form-label text-muted fw-semibold small">Company</label>
                            <select asp-for="CompanyId" class="form-select rounded-3" asp-items="ViewBag.CompanyId">
                                <option value="">-- Select Company --</option>
                            </select>
                            <span asp-validation-for="CompanyId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ParentDepartmentId" class="form-label text-muted fw-semibold small">Parent Department</label>
                            <select asp-for="ParentDepartmentId" class="form-select rounded-3" asp-items="ViewBag.ParentDepartmentId">
                                <option value="">-- None --</option>
                            </select>
                            <span asp-validation-for="ParentDepartmentId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12 mt-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" role="switch">
                                <label class="form-check-label text-muted" asp-for="IsActive">Is Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
