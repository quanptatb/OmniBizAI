@model OmniBizAI.ViewModels.OperationRequestCreateViewModel
@{
    ViewData["Title"] = "Tạo Yêu cầu Vận hành";
    ViewData["Breadcrumb"] = "<span>Vận hành</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>Tạo mới</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-pen-to-square"></i> Khởi tạo yêu cầu</h5>
            </div>
            <div class="card-body-custom">
                <p style="color:var(--text-secondary);font-size:.85rem;margin-bottom:24px">Vui lòng điền đầy đủ thông tin để hệ thống có thể chuyển luồng phê duyệt chính xác.</p>
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 p-3 rounded" style="background:var(--danger-bg);border:1px solid rgba(255,59,48,.2);border-radius:var(--r-sm)"></div>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label">Tiêu đề yêu cầu <span style="color:var(--danger)">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tóm tắt nội dung yêu cầu..." />
                            <span asp-validation-for="Title" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label">Loại yêu cầu <span style="color:var(--danger)">*</span></label>
                            <select asp-for="Type" class="form-select">
                                <option value="">-- Chọn loại yêu cầu --</option>
                                <option value="IT_SUPPORT">Hỗ trợ IT & Thiết bị</option>
                                <option value="PROCUREMENT">Đề xuất mua sắm</option>
                                <option value="FACILITY">Bảo trì cơ sở vật chất</option>
                                <option value="Maintenance_PM">Bảo trì phòng ngừa (PM)</option>
                                <option value="Maintenance_CM">Bảo trì khắc phục (CM)</option>
                                <option value="Maintenance">Bảo trì khác</option>
                                <option value="SERVICE">Cung cấp dịch vụ/Sản phẩm</option>
                                <option value="OTHER">Khác</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="OrganizationUnitId" class="form-label">Phòng ban tiếp nhận <span style="color:var(--danger)">*</span></label>
                            <select asp-for="OrganizationUnitId" class="form-select">
                                <option value="">-- Chọn phòng ban --</option>
                                @foreach (var opt in Model.Departments)
                                {
                                    <option value="@opt.Value">@opt.Text</option>
                                }
                            </select>
                            <span asp-validation-for="OrganizationUnitId" class="text-danger small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Priority" class="form-label">Mức độ ưu tiên <span style="color:var(--danger)">*</span></label>
                            <select asp-for="Priority" class="form-select">
                                @foreach (var p in EnumHelper.GetSelectList<PriorityLevel>())
                                { <option value="@((int)Enum.Parse<PriorityLevel>(p.Value))" selected="@(p.Value == "Normal")">@p.Text</option> }
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label">Hạn xử lý mong muốn</label>
                            <input asp-for="DueDate" type="date" class="form-control" />
                            <span asp-validation-for="DueDate" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="col-md-12">
                            <label asp-for="CustomerId" class="form-label">Khách hàng liên quan (Nếu có)</label>
                            <select asp-for="CustomerId" class="form-select">
                                <option value="">-- Nội bộ (Không chọn khách hàng) --</option>
                                @foreach (var opt in Model.Customers)
                                {
                                    <option value="@opt.Value">@opt.Text</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="TotalAmount" class="form-label">Tổng chi phí dự kiến (VNĐ)</label>
                            <div class="input-group">
                                <input asp-for="TotalAmount" type="number" step="1000" class="form-control" placeholder="0" />
                                <span class="input-group-text">₫</span>
                            </div>
                            <small style="color:var(--text-muted);margin-top:4px;display:block">Điền nếu yêu cầu có phát sinh chi phí mua sắm/dịch vụ.</small>
                        </div>
                        
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label">Mô tả chi tiết nội dung</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Cung cấp đầy đủ thông tin để bộ phận tiếp nhận có thể xử lý dễ dàng..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div style="border-top:1px solid var(--divider);padding-top:20px" class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-1"></i>Lưu nháp (Draft)</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
