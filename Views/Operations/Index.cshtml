@model OmniBizAI.ViewModels.OperationRequestListViewModel
@{
    ViewData["Title"] = "Yêu cầu vận hành";
    ViewData["Breadcrumb"] = "<span>Vận hành</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>Danh sách</span>";
}

<div class="content-card mb-4">
    <div class="card-body-custom py-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Mã, tiêu đề...">
            </div>
            <div class="col-md-2">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var st in Enum.GetNames(typeof(OmniBizAI.Models.Entities.Enums.OperationStatus)))
                    {
                        <option value="@st" selected="@(Model.StatusFilter == st)">@st</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Mức ưu tiên</label>
                <select name="priority" class="form-select">
                    <option value="">Tất cả</option>
                    @foreach (var pr in Enum.GetNames(typeof(OmniBizAI.Models.Entities.Enums.PriorityLevel)))
                    {
                        <option value="@pr" selected="@(Model.PriorityFilter == pr)">@pr</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Phòng ban</label>
                <select name="dept" class="form-select">
                    <option value="">Tất cả phòng ban</option>
                    @foreach (var d in Model.Departments)
                    {
                        <option value="@d.Value" selected="@(Model.DeptFilter?.ToString() == d.Value)">@d.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1"><i class="fa-solid fa-filter me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-light" title="Xóa bộ lọc"><i class="fa-solid fa-rotate-left"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="content-card">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-list-check"></i> Danh sách yêu cầu</h5>
        <div class="d-flex gap-2">
            <a asp-controller="Workflow" asp-action="Kanban" class="btn btn-light btn-sm">
                <i class="fa-solid fa-table-columns me-1"></i>Kanban
            </a>
            @if (User.IsInRole("STAFF") || User.IsInRole("DEPARTMENT_MANAGER") || User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
            {
                <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus me-1"></i>Tạo mới</a>
            }
        </div>
    </div>
    <div class="card-body-custom p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="ps-4">Mã YC</th>
                        <th>Tiêu đề / Loại</th>
                        <th>Phòng ban</th>
                        <th>Trạng thái</th>
                        <th>Ưu tiên</th>
                        <th>Hạn xử lý</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4" style="font-weight:600;color:var(--apple-blue)">@item.RequestNo</td>
                            <td>
                                <div style="font-weight:600;margin-bottom:3px">@item.Title</div>
                                <span class="badge" style="background:var(--parchment);color:var(--text-secondary);border:1px solid var(--divider);font-weight:500">@item.Type</span>
                            </td>
                            <td>@item.Department</td>
                            <td>
                                @{
                                    var statusBadge = item.Status switch {
                                        "Completed" => "badge-on-track",
                                        "InProgress" or "Approved" => "badge-on-track",
                                        "Pending" or "Submitted" or "InReview" => "badge-at-risk",
                                        "Rejected" or "Cancelled" => "badge-late",
                                        _ => ""
                                    };
                                }
                                <span class="status-badge-soft @statusBadge"><span class="status-dot"></span>@item.Status</span>
                            </td>
                            <td>
                                @{
                                    var priColor = item.Priority switch {
                                        "Low" => "var(--info)",
                                        "Normal" => "var(--success)",
                                        "High" => "var(--warning)",
                                        "Critical" => "var(--danger)",
                                        _ => "var(--text-muted)"
                                    };
                                }
                                <span style="color:@priColor;font-weight:500"><i class="fa-solid fa-circle" style="font-size:.4rem;vertical-align:middle;margin-right:4px"></i>@item.Priority</span>
                            </td>
                            <td style="color:var(--text-muted)">@(item.DueDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light">
                                    <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center py-5" style="color:var(--text-muted)"><i class="fa-solid fa-inbox fa-2x d-block mb-2 opacity-50"></i>Không tìm thấy dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    @if (Model.TotalCount > 20)
    {
        <div class="pagination-custom">
            <span>Hiển thị trang @Model.Page của @Math.Ceiling(Model.TotalCount / 20.0)</span>
            <div class="pagination-pages">
                <a class="page-btn @(Model.Page == 1 ? "disabled" : "")" asp-action="Index" asp-route-page="@(Model.Page-1)" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter" asp-route-priority="@Model.PriorityFilter" asp-route-dept="@Model.DeptFilter">‹</a>
                <a class="page-btn @(Model.Page * 20 >= Model.TotalCount ? "disabled" : "")" asp-action="Index" asp-route-page="@(Model.Page+1)" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter" asp-route-priority="@Model.PriorityFilter" asp-route-dept="@Model.DeptFilter">›</a>
            </div>
        </div>
    }
</div>
