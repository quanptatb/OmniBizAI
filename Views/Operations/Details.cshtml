@model OmniBizAI.ViewModels.OperationRequestDetailViewModel
@{
    ViewData["Title"] = "Chi tiết Yêu cầu " + Model.RequestNo;
    ViewData["Breadcrumb"] = "<span>Vận hành</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>" + Model.RequestNo + "</span>";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card mb-4">
            <div class="card-header-custom" style="flex-wrap:wrap;gap:12px">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge" style="background:var(--parchment);color:var(--text-secondary);border:1px solid var(--divider)">@Model.Type</span>
                        @{
                            var statusBadge = Model.Status switch {
                                "Completed" or "Approved" or "InProgress" => "badge-on-track",
                                "Submitted" or "InReview" => "badge-at-risk",
                                "Rejected" or "Cancelled" => "badge-late",
                                _ => ""
                            };
                        }
                        <span class="status-badge-soft @statusBadge"><span class="status-dot"></span>@Model.Status</span>
                    </div>
                    <h5 style="font-weight:600;margin:0;letter-spacing:-0.01em">@Model.Title</h5>
                </div>
                <div class="text-end">
                    <div style="font-weight:600;color:var(--apple-blue)">@Model.RequestNo</div>
                    <small style="color:var(--text-muted)">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                </div>
            </div>
            <div class="card-body-custom">
                <div class="row mb-4 g-4">
                    <div class="col-sm-6">
                        <label class="form-label" style="margin-bottom:4px">Người tạo</label>
                        <div style="font-weight:500">@Model.CreatedBy</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" style="margin-bottom:4px">Phòng ban phụ trách</label>
                        <div style="font-weight:500">@Model.Department</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" style="margin-bottom:4px">Độ ưu tiên</label>
                        <div style="font-weight:500">
                            @if(Model.Priority == "Critical") { <span style="color:var(--danger);font-weight:600"><i class="fa-solid fa-triangle-exclamation me-1"></i>Nghiêm trọng</span> }
                            else { <span>@Model.Priority</span> }
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" style="margin-bottom:4px">Hạn xử lý</label>
                        <div style="font-weight:500">@(Model.DueDate?.ToString("dd/MM/yyyy") ?? "Không có")</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label" style="margin-bottom:6px">Mô tả chi tiết</label>
                    <div style="padding:16px;background:var(--parchment);border-radius:var(--r-sm);border:1px solid var(--divider);font-size:.88rem;line-height:1.6">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả" : Model.Description)
                    </div>
                </div>

                @if (Model.CanSubmit || Model.CanCancel)
                {
                    <div class="d-flex flex-wrap gap-2" style="border-top:1px solid var(--divider);padding-top:16px">
                        <a asp-controller="Workflow" asp-action="Kanban" asp-route-search="@Model.RequestNo" class="btn btn-light">
                            <i class="fa-solid fa-table-columns me-1"></i>Xem Kanban
                        </a>
                        @if (Model.CanSubmit)
                        {
                            <form asp-action="Submit" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane me-1"></i>Gửi duyệt</button>
                            </form>
                        }
                        @if (Model.CanCancel)
                        {
                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy yêu cầu này?');">
                                <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-ban me-1"></i>Hủy</button>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <div style="border-top:1px solid var(--divider);padding-top:16px">
                        <a asp-controller="Workflow" asp-action="Kanban" asp-route-search="@Model.RequestNo" class="btn btn-light">
                            <i class="fa-solid fa-table-columns me-1"></i>Xem Kanban
                        </a>
                    </div>
                }
            </div>
        </div>

        @if (Model.WorkItems.Any())
        {
            <div class="content-card">
                <div class="card-header-custom">
                    <h5><i class="fa-solid fa-tasks"></i> Công việc liên quan</h5>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var task in Model.WorkItems)
                    {
                        <li class="list-group-item p-3 d-flex justify-content-between align-items-center" style="border-color:var(--divider)">
                            <div>
                                <div style="font-weight:500">@task.Title</div>
                                <small style="color:var(--text-muted)">Hạn: @(task.DueDate?.ToString("dd/MM") ?? "—")</small>
                            </div>
                            <span class="badge" style="background:var(--parchment);color:var(--text-secondary);border:1px solid var(--divider)">@task.Status</span>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="content-card mb-4">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-list-check" style="color:var(--warning)"></i> Tiến trình phê duyệt</h5>
            </div>
            <div class="card-body-custom">
                @if (!Model.ApprovalTasks.Any())
                {
                    <div class="text-center py-3" style="color:var(--text-muted)">Chưa có luồng duyệt</div>
                }
                else
                {
                    <div class="checkin-timeline">
                        @foreach (var task in Model.ApprovalTasks)
                        {
                            <div class="checkin-timeline-item @(task.Status == "Approved" ? "approved" : task.Status == "Rejected" ? "late" : "")">
                                <div style="font-weight:600;font-size:.85rem;margin-bottom:4px">@task.StepName</div>
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="status-badge-soft @(task.Status == "Approved" ? "badge-on-track" : task.Status == "Rejected" ? "badge-late" : "badge-at-risk")">
                                        <span class="status-dot"></span>@task.Status
                                    </span>
                                    <small style="color:var(--text-muted)">@task.AssignedRole</small>
                                </div>
                                @if (!string.IsNullOrEmpty(task.DecisionNote))
                                {
                                    <div style="padding:8px 12px;background:var(--parchment);border-radius:var(--r-sm);font-size:.82rem;margin-top:6px">@task.DecisionNote</div>
                                }
                                @if (task.DecidedAt.HasValue)
                                {
                                    <small style="color:var(--text-muted);display:block;margin-top:4px"><i class="fa-regular fa-clock me-1"></i>@task.DecidedAt.Value.ToString("HH:mm dd/MM")</small>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @if (Model.AiInsights.Any())
        {
            <div class="content-card">
                <div class="card-header-custom">
                    <h5><i class="fa-solid fa-robot" style="color:var(--apple-blue)"></i> AI Insights</h5>
                </div>
                <div class="card-body-custom">
                    @foreach (var ai in Model.AiInsights)
                    {
                        <div class="mb-3 pb-3" style="border-bottom:1px solid var(--divider)">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="ai-risk-badge @ai.RiskLevel.ToLower()">
                                    @if(ai.RiskLevel == "High") { <i class="fa-solid fa-fire"></i> }
                                    Risk: @ai.RiskLevel
                                </span>
                                <small style="color:var(--text-muted)">@ai.CreatedAt.ToString("dd/MM")</small>
                            </div>
                            <p style="font-weight:500;font-size:.85rem;margin-bottom:4px">@ai.Summary</p>
                            <p style="font-size:.82rem;color:var(--text-secondary);margin:0">@ai.Recommendation</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
