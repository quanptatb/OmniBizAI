@using OmniBizAI.ViewModels
@model KpiViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết KPI";
    var pct = (int)Model.OverallProgress;
    string gradeLower = Model.GradeLetter.ToLower();
    string statusLabel = Model.Status switch {
        KpiStatus.OnTrack   => "On Track",
        KpiStatus.AtRisk    => "At Risk",
        KpiStatus.Behind    => "Behind",
        KpiStatus.Completed => "Hoàn thành",
        _                   => ""
    };
    string badgeClass = Model.Status switch {
        KpiStatus.OnTrack   => "kpi-badge-ontrack",
        KpiStatus.AtRisk    => "kpi-badge-atrisk",
        KpiStatus.Behind    => "kpi-badge-behind",
        KpiStatus.Completed => "kpi-badge-completed",
        _                   => "kpi-badge-ontrack"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/kpi.css" />
}

<div class="kpi-page-header kpi-reveal d1">
    <div>
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <a href="@Url.Action("Index","Kpi")" style="color:var(--muted);font-size:13px;text-decoration:none;display:flex;align-items:center;gap:4px">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
                KPI / OKR
            </a>
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="color:var(--muted2)"><path d="M9 5l7 7-7 7"/></svg>
            <span style="font-size:13px;color:var(--muted)">Chi tiết</span>
        </div>
        <h1 class="kpi-page-title" style="max-width:600px;line-height:1.3">@Model.Objective</h1>
    </div>
    <a href="@Url.Action("CheckIn","Kpi",new{id=Model.Id})" class="kpi-btn kpi-btn-primary">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Check-in
    </a>
</div>

<div class="kpi-detail-grid kpi-reveal d2">

    <!-- LEFT: Key Results -->
    <div class="kpi-detail-card">
        <div>
            <div class="kpi-section-title">Thông tin chung</div>
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                <div class="kpi-owner" style="display:flex;align-items:center;gap:10px">
                    <div class="kpi-avatar">@Model.OwnerAvatar</div>
                    <div>
                        <div class="kpi-owner-name">@Model.OwnerName</div>
                        <div class="kpi-period">@Model.StartDate.ToString("dd/MM/yyyy") – @Model.EndDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
                <span class="kpi-badge @badgeClass">@statusLabel</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p style="font-size:13px;color:var(--muted);margin-top:12px;line-height:1.7">@Model.Description</p>
            }
        </div>

        <!-- Overall progress bar -->
        <div>
            <div class="kpi-section-title">Tiến độ tổng thể</div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                <span style="font-size:13px;color:var(--muted)">@pct% hoàn thành</span>
                <span style="font-size:13px;font-weight:700;color:var(--accent2)">@pct / 100</span>
            </div>
            <div class="kpi-detail-track" style="height:12px">
                <div class="kpi-detail-fill" data-w="@pct%" style="background:linear-gradient(90deg,var(--accent),#a78bfa)"></div>
            </div>
        </div>

        <!-- Key Results -->
        <div>
            <div class="kpi-section-title">Key Results (@Model.KeyResults.Count)</div>
            <div style="display:flex;flex-direction:column;gap:14px">
                @foreach (var kr in Model.KeyResults)
                {
                    var krPct = (int)kr.ClampedProgress;
                    var rawPct = (int)kr.RawProgress;
                    string fillColor = krPct >= 70 ? "linear-gradient(90deg,var(--green),#14b8a6)"
                                     : krPct >= 40 ? "linear-gradient(90deg,var(--accent),#a78bfa)"
                                     : "linear-gradient(90deg,var(--red),#f472b6)";

                    <div class="kpi-detail-kr">
                        <div class="kpi-detail-kr-header">
                            <div class="kpi-detail-kr-title">@kr.Title</div>
                            <div style="text-align:right">
                                <div class="kpi-detail-kr-pct">@krPct%</div>
                                @if (kr.IsOverTarget)
                                {
                                    <span class="kpi-over-target">
                                        <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                                        Vượt mục tiêu (@rawPct%)
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="kpi-detail-track">
                            <div class="kpi-detail-fill" data-w="@krPct%" style="background:@fillColor"></div>
                        </div>
                        <div class="kpi-detail-metrics">
                            <div class="kpi-metric-cell">
                                <div class="kpi-metric-label">Bắt đầu</div>
                                <div class="kpi-metric-val">@kr.StartValue <small style="font-size:11px;color:var(--muted)">@kr.Unit</small></div>
                            </div>
                            <div class="kpi-metric-cell">
                                <div class="kpi-metric-label">Hiện tại</div>
                                <div class="kpi-metric-val" style="color:var(--accent2)">@kr.CurrentValue <small style="font-size:11px;color:var(--muted)">@kr.Unit</small></div>
                            </div>
                            <div class="kpi-metric-cell">
                                <div class="kpi-metric-label">Mục tiêu</div>
                                <div class="kpi-metric-val" style="color:var(--green)">@kr.TargetValue <small style="font-size:11px;color:var(--muted)">@kr.Unit</small></div>
                            </div>
                        </div>
                        <div style="font-size:11px;color:var(--muted)">
                            Hướng: <span style="color:var(--text);font-weight:600">@(kr.Direction == KpiDirection.Higher ? "Càng cao càng tốt ↑" : "Càng thấp càng tốt ↓")</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT: Grade + Scale -->
    <div style="display:flex;flex-direction:column;gap:18px">
        <div class="kpi-detail-card" style="align-items:center">
            <div class="kpi-grade-widget" style="width:100%">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted)">Xếp loại gợi ý</div>
                <div class="kpi-grade-letter grade-@gradeLower">@Model.GradeLetter</div>
                <div class="kpi-grade-label">@Model.GradeLabel</div>
                <div class="kpi-grade-desc">Dựa trên tiến độ tổng thể @pct%</div>
            </div>

            <div class="kpi-divider" style="width:100%"></div>

            <div style="width:100%">
                <div class="kpi-section-title">Thang điểm xếp loại</div>
                <div class="kpi-grade-scale">
                    @foreach (var (letter, cls, range, desc) in new[]{
                        ("A","ga","≥ 90%","Xuất sắc"),
                        ("B","gb","70 – 89%","Tốt"),
                        ("C","gc","50 – 69%","Trung bình"),
                        ("D","gd","30 – 49%","Yếu"),
                        ("E","ge","< 30%","Kém")
                    })
                    {
                        <div class="kpi-grade-row @(Model.GradeLetter == letter ? "active" : "")">
                            <div class="kpi-grade-badge @cls">@letter</div>
                            <span style="font-size:12px;color:var(--text);font-weight:@(Model.GradeLetter == letter ? "700" : "400")">@desc</span>
                            <span class="kpi-grade-range">@range</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="kpi-detail-card">
            <div class="kpi-section-title">Hành động</div>
            <a href="@Url.Action("CheckIn","Kpi",new{id=Model.Id})" class="kpi-btn kpi-btn-primary" style="width:100%;justify-content:center">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Gửi Check-in mới
            </a>
            <a href="@Url.Action("Index","Kpi")" class="kpi-btn kpi-btn-ghost" style="width:100%;justify-content:center">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Quay lại danh sách
            </a>
        </div>
    </div>
</div>

@section Scripts {
<script>
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      document.querySelectorAll('.kpi-detail-fill[data-w]').forEach(el => {
        el.style.width = el.dataset.w;
      });
    }, 200);
  });
</script>
}
