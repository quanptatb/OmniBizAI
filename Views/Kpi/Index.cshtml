@using OmniBizAI.ViewModels
@model List<KpiViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "KPI / OKR";
    var isManager = ViewData["UserRole"]?.ToString() == "Manager";
    int onTrack = Model.Count(k => k.Status == KpiStatus.OnTrack);
    int atRisk   = Model.Count(k => k.Status == KpiStatus.AtRisk);
    int behind   = Model.Count(k => k.Status == KpiStatus.Behind);
}

@section Styles {
    <link rel="stylesheet" href="~/css/kpi.css" />
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="kpi-alert kpi-reveal d1">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        @TempData["SuccessMessage"]
    </div>
}

<div class="kpi-page-header kpi-reveal d1">
    <div>
        <h1 class="kpi-page-title">KPI / OKR</h1>
        <p class="kpi-page-sub">@(isManager ? "Tổng quan hiệu suất toàn nhóm" : "KPI của tôi – Quý 2 / 2026")</p>
    </div>
    @if (isManager)
    {
        <a href="@Url.Action("Pending","Kpi")" class="kpi-btn kpi-btn-primary">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            Chờ duyệt (3)
        </a>
    }
</div>

<div class="kpi-summary-strip kpi-reveal d2">
    <div class="kpi-strip-card">
        <div class="kpi-strip-label">Tổng OKR</div>
        <div class="kpi-strip-value">@Model.Count</div>
        <div class="kpi-strip-sub">mục tiêu đang theo dõi</div>
    </div>
    <div class="kpi-strip-card">
        <div class="kpi-strip-label">On Track</div>
        <div class="kpi-strip-value" style="color:var(--green)">@onTrack</div>
        <div class="kpi-strip-sub">đang đúng hướng</div>
    </div>
    <div class="kpi-strip-card">
        <div class="kpi-strip-label">At Risk</div>
        <div class="kpi-strip-value" style="color:var(--amber)">@atRisk</div>
        <div class="kpi-strip-sub">cần chú ý</div>
    </div>
    <div class="kpi-strip-card">
        <div class="kpi-strip-label">Behind</div>
        <div class="kpi-strip-value" style="color:var(--red)">@behind</div>
        <div class="kpi-strip-sub">đang tụt hậu</div>
    </div>
</div>

<div class="kpi-grid">
    @foreach (var (kpi, idx) in Model.Select((k,i)=>(k,i)))
    {
        var delay = idx + 3;
        var pct   = (int)kpi.OverallProgress;
        var strokeOffset = (int)(157 - pct * 157.0 / 100);
        string badgeClass = kpi.Status switch {
            KpiStatus.OnTrack   => "kpi-badge-ontrack",
            KpiStatus.AtRisk    => "kpi-badge-atrisk",
            KpiStatus.Behind    => "kpi-badge-behind",
            KpiStatus.Completed => "kpi-badge-completed",
            _                   => "kpi-badge-ontrack"
        };
        string statusLabel = kpi.Status switch {
            KpiStatus.OnTrack   => "On Track",
            KpiStatus.AtRisk    => "At Risk",
            KpiStatus.Behind    => "Behind",
            KpiStatus.Completed => "Hoàn thành",
            _                   => ""
        };

        <div class="kpi-card kpi-reveal d@delay" id="kpi-card-@kpi.Id">
            <div class="kpi-card-top">
                <div class="kpi-owner">
                    <div class="kpi-avatar">@kpi.OwnerAvatar</div>
                    <div>
                        <div class="kpi-owner-name">@kpi.OwnerName</div>
                        <div class="kpi-period">@kpi.StartDate.ToString("dd/MM") – @kpi.EndDate.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
                <span class="kpi-badge @badgeClass">@statusLabel</span>
            </div>

            <div class="kpi-objective">@kpi.Objective</div>

            <div class="kpi-progress-section">
                <div class="kpi-progress-ring-wrap">
                    <svg width="56" height="56" viewBox="0 0 56 56">
                        <circle class="kpi-ring-bg" cx="28" cy="28" r="25"/>
                        <circle class="kpi-ring-fill" cx="28" cy="28" r="25"
                                data-offset="@strokeOffset"
                                style="stroke-dashoffset:157"/>
                    </svg>
                    <div class="kpi-ring-pct">@pct%</div>
                </div>
                <div class="kpi-progress-info">
                    <div class="kpi-progress-label">Tiến độ tổng thể</div>
                    <div class="kpi-progress-value">@pct<small style="font-size:12px;color:var(--muted);font-weight:500">%</small></div>
                </div>
            </div>

            <div class="kpi-kr-list">
                @foreach (var kr in kpi.KeyResults)
                {
                    var krPct  = (int)kr.ClampedProgress;
                    string fillClass = krPct >= 70 ? "green" : krPct >= 40 ? "" : "red";
                    <div class="kpi-kr-item">
                        <div class="kpi-kr-row">
                            <span class="kpi-kr-title" title="@kr.Title">@kr.Title</span>
                            <span class="kpi-kr-pct">@krPct%</span>
                        </div>
                        <div class="kpi-track">
                            <div class="kpi-fill @fillClass" data-w="@krPct%"></div>
                        </div>
                    </div>
                }
            </div>

            <div class="kpi-card-actions">
                <a href="@Url.Action("Detail","Kpi",new{id=kpi.Id})" class="kpi-btn kpi-btn-ghost">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    Chi tiết
                </a>
                @if (!isManager)
                {
                    <a href="@Url.Action("CheckIn","Kpi",new{id=kpi.Id})" class="kpi-btn kpi-btn-primary">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Check-in
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // progress bars
    setTimeout(() => {
      document.querySelectorAll('.kpi-fill[data-w]').forEach(el => {
        el.style.width = el.dataset.w;
      });
      // rings
      document.querySelectorAll('.kpi-ring-fill[data-offset]').forEach(el => {
        el.style.strokeDashoffset = el.dataset.offset;
      });
    }, 200);
  });
</script>
}
