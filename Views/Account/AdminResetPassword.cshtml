@model OmniBizAI.ViewModels.AdminResetPasswordViewModel
@{ ViewData["Title"] = "Đặt lại mật khẩu người dùng"; ViewData["Breadcrumb"] = "<a href='/Users' style='color:var(--apple-blue);text-decoration:none'>Nhân sự</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Đặt lại mật khẩu</span>"; }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-shield-halved"></i> Đặt lại mật khẩu người dùng</h5>
            </div>
            <div class="card-body-custom">
                <div class="d-flex align-items-center gap-3 mb-4 p-3" style="background:var(--parchment);border-radius:var(--r-sm)">
                    <div style="width:42px;height:42px;border-radius:50%;background:var(--apple-blue);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem">
                        @Model.UserName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div style="font-weight:600;font-size:.88rem">@Model.FullName</div>
                        <div style="font-size:.78rem;color:var(--text-muted)">@Model.UserName</div>
                    </div>
                </div>

                <form asp-action="AdminResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="UserName" type="hidden" />
                    <input asp-for="FullName" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill" style="font-weight:600;border-radius:10px">
                            <i class="fa-solid fa-check me-2"></i>Đặt lại mật khẩu
                        </button>
                        <a asp-controller="Users" asp-action="Index" class="btn btn-light" style="border-radius:10px">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
