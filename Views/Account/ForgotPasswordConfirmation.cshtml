@{ Layout = null; ViewData["Title"] = "Đã gửi liên kết"; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đã gửi liên kết - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes pulse { 0%,100% { transform:scale(1); } 50% { transform:scale(1.05); } }
        .check-anim { animation: pulse 2s ease-in-out infinite; }
        .step-item { display:flex; align-items:flex-start; gap:12px; margin-bottom:16px; }
        .step-num { width:24px; height:24px; border-radius:50%; background:var(--apple-blue); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.68rem; font-weight:700; flex-shrink:0; margin-top:2px; }
        .step-text { font-size:.82rem; color:var(--text-secondary); line-height:1.5; }
        .resend-timer { font-size:.78rem; color:var(--text-muted); margin-top:12px; }
    </style>
</head>
<body>
<div class="login-page">
    <div class="login-card text-center" style="animation: slideUp .5s ease-out; max-width:460px">
        <!-- Icon -->
        <div class="check-anim" style="width:64px;height:64px;background:rgba(52,199,89,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
            <i class="fa-solid fa-envelope-circle-check" style="font-size:26px;color:var(--success)"></i>
        </div>

        <h1 style="font-size:1.3rem;font-weight:700;color:var(--text-primary);margin-bottom:8px">Kiểm tra email của bạn</h1>
        <p style="font-size:.88rem;color:var(--text-secondary);margin-bottom:24px;line-height:1.5">
            Nếu tài khoản tồn tại trong hệ thống, chúng tôi đã gửi liên kết đặt lại mật khẩu đến email của bạn.
        </p>

        <!-- Steps guide -->
        <div style="text-align:left;background:var(--parchment);border-radius:var(--r-md);padding:16px;margin-bottom:20px">
            <div class="step-item">
                <div class="step-num">1</div>
                <div class="step-text">Mở hộp thư email của bạn (kiểm tra cả <strong>thư mục spam</strong>)</div>
            </div>
            <div class="step-item">
                <div class="step-num">2</div>
                <div class="step-text">Nhấn vào nút <strong>"Đặt lại mật khẩu"</strong> trong email</div>
            </div>
            <div class="step-item" style="margin-bottom:0">
                <div class="step-num">3</div>
                <div class="step-text">Tạo mật khẩu mới. Liên kết có hiệu lực trong <strong>2 giờ</strong></div>
            </div>
        </div>

        <!-- Demo mode: show reset link directly -->
        @if (TempData["ResetLink"] != null)
        {
            <div style="background:rgba(0,102,204,.05);border:1px solid rgba(0,102,204,.12);border-radius:var(--r-sm);padding:14px;margin-bottom:20px;text-align:left">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa-solid fa-flask" style="color:var(--apple-blue);font-size:.75rem"></i>
                    <span style="font-size:.72rem;color:var(--apple-blue);font-weight:700">Chế độ Demo</span>
                    <span style="font-size:.65rem;color:var(--text-muted)">(SMTP chưa cấu hình)</span>
                </div>
                <div style="font-size:.72rem;color:var(--text-secondary);margin-bottom:6px">
                    <i class="fa-solid fa-at me-1"></i>Email: <strong>@TempData["ResetEmail"]</strong>
                </div>
                <a href="@TempData["ResetLink"]" class="btn btn-sm btn-primary w-100" style="border-radius:8px;font-size:.78rem;font-weight:600">
                    <i class="fa-solid fa-external-link me-1"></i>Mở trang đặt lại mật khẩu
                </a>
                <div style="margin-top:8px">
                    <details style="font-size:.68rem;color:var(--text-muted)">
                        <summary style="cursor:pointer">Xem URL đầy đủ</summary>
                        <code style="word-break:break-all;font-size:.62rem;display:block;margin-top:4px;padding:8px;background:var(--parchment);border-radius:6px">@TempData["ResetLink"]</code>
                    </details>
                </div>
            </div>
        }

        <!-- Action buttons -->
        <a asp-action="Login" class="btn btn-primary w-100 py-2 mb-3" style="font-weight:600;font-size:.88rem;border-radius:10px;text-decoration:none">
            <i class="fa-solid fa-right-to-bracket me-2"></i>Quay lại đăng nhập
        </a>

        <!-- Resend -->
        <div class="resend-timer" id="resendArea">
            <span>Không nhận được email? </span>
            <button type="button" class="btn btn-link p-0" style="font-size:.78rem;color:var(--apple-blue);text-decoration:none;font-weight:600" id="resendBtn" disabled onclick="resend()">
                Gửi lại (<span id="countdown">120</span>s)
            </button>
        </div>

        <!-- Resend form (hidden) -->
        <form asp-action="ForgotPassword" method="post" id="resendForm" style="display:none">
            @Html.AntiForgeryToken()
            <input name="Email" id="resendEmail" value="" />
        </form>

        <div class="mt-3">
            <a asp-action="ForgotPassword" style="font-size:.78rem;color:var(--text-muted);text-decoration:none">
                <i class="fa-solid fa-arrow-rotate-left me-1"></i>Dùng email khác
            </a>
        </div>
    </div>
</div>
<script>
// Countdown timer for resend button
(function() {
    let sec = 120;
    const btn = document.getElementById('resendBtn');
    const span = document.getElementById('countdown');
    const interval = setInterval(() => {
        sec--;
        span.textContent = sec;
        if (sec <= 0) {
            clearInterval(interval);
            btn.disabled = false;
            btn.innerHTML = 'Gửi lại';
        }
    }, 1000);
})();

function resend() {
    const email = prompt('Nhập email hoặc tên đăng nhập:');
    if (email) {
        document.getElementById('resendEmail').value = email;
        document.getElementById('resendForm').submit();
    }
}
</script>
</body>
</html>
