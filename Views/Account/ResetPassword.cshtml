@model OmniBizAI.ViewModels.ResetPasswordViewModel
@{ Layout = null; ViewData["Title"] = "Đặt lại mật khẩu"; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        .pw-strength { height:4px; border-radius:2px; margin-top:6px; background:var(--divider); overflow:hidden; }
        .pw-strength-bar { height:100%; border-radius:2px; transition:width .3s ease, background .3s ease; width:0; }
        .login-input-group { position:relative; }
        .login-input-group .form-control { padding-right:42px; }
        .password-toggle { position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:.85rem; padding:4px; z-index:5; }
        .password-toggle:hover { color:var(--text-primary); }
        .pw-rules { font-size:.7rem; color:var(--text-muted); margin-top:8px; }
        .pw-rule { display:flex; align-items:center; gap:6px; margin-bottom:3px; }
        .pw-rule.pass { color:var(--success); }
        .pw-rule i { width:12px; text-align:center; }
        .error-expired { background:rgba(255,149,0,.06); border:1px solid rgba(255,149,0,.15); border-radius:var(--r-sm); padding:14px; margin-bottom:16px; }
        .match-indicator { font-size:.7rem; margin-top:4px; }
    </style>
</head>
<body>
<div class="login-page">
    <div class="login-card" style="animation: slideUp .5s ease-out; max-width:440px">
        <div style="width:56px;height:56px;background:rgba(0,102,204,.08);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
            <i class="fa-solid fa-shield-halved" style="font-size:22px;color:var(--apple-blue)"></i>
        </div>
        <h1 style="font-size:1.3rem;font-weight:700;color:var(--text-primary);margin-bottom:6px;text-align:center">Đặt lại mật khẩu</h1>
        <p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:24px;text-align:center">
            Tạo mật khẩu mới cho tài khoản <strong>@Model.Email</strong>
        </p>

        @* Token expired banner *@
        @if (ViewData["TokenExpired"] != null)
        {
            <div class="error-expired">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa-solid fa-clock-rotate-left" style="color:var(--warning)"></i>
                    <strong style="font-size:.85rem;color:var(--warning)">Liên kết đã hết hạn</strong>
                </div>
                <p style="font-size:.82rem;color:var(--text-secondary);margin:0 0 10px">
                    Liên kết đặt lại mật khẩu có hiệu lực trong 2 giờ. Vui lòng yêu cầu một liên kết mới.
                </p>
                <a asp-action="ForgotPassword" class="btn btn-sm btn-warning w-100" style="border-radius:8px;font-weight:600;font-size:.82rem">
                    <i class="fa-solid fa-paper-plane me-1"></i>Yêu cầu liên kết mới
                </a>
            </div>
        }

        @* Validation errors *@
        @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div style="background:rgba(255,59,48,.05);border:1px solid rgba(255,59,48,.12);border-radius:var(--r-sm);padding:10px 14px;margin-bottom:16px">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div style="font-size:.82rem;color:var(--danger)"><i class="fa-solid fa-circle-exclamation me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ResetPassword" method="post" id="resetForm">
            @Html.AntiForgeryToken()
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="mb-3">
                <label class="form-label fw-bold">Mật khẩu mới</label>
                <div class="login-input-group">
                    <input asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới" id="newPw" oninput="checkAll()" autocomplete="new-password" />
                    <button type="button" class="password-toggle" onclick="togglePw('newPw','pwIcon1')"><i class="fa-solid fa-eye" id="pwIcon1"></i></button>
                </div>
                <div class="pw-strength"><div class="pw-strength-bar" id="pwBar"></div></div>
                <small id="pwLabel" style="font-size:.7rem;color:var(--text-muted)"></small>

                <!-- Password rules checklist -->
                <div class="pw-rules" id="pwRules">
                    <div class="pw-rule" id="rule-len"><i class="fa-solid fa-circle"></i> Tối thiểu 3 ký tự</div>
                    <div class="pw-rule" id="rule-upper"><i class="fa-solid fa-circle"></i> Có chữ hoa (khuyến khích)</div>
                    <div class="pw-rule" id="rule-digit"><i class="fa-solid fa-circle"></i> Có số (khuyến khích)</div>
                    <div class="pw-rule" id="rule-special"><i class="fa-solid fa-circle"></i> Có ký tự đặc biệt (khuyến khích)</div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                <div class="login-input-group">
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" id="confirmPw" oninput="checkMatch()" autocomplete="new-password" />
                    <button type="button" class="password-toggle" onclick="togglePw('confirmPw','pwIcon2')"><i class="fa-solid fa-eye" id="pwIcon2"></i></button>
                </div>
                <div class="match-indicator" id="matchLabel"></div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2" style="font-weight:600;font-size:.88rem;border-radius:10px" id="submitBtn">
                <i class="fa-solid fa-check me-2"></i>Đặt lại mật khẩu
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Login" style="font-size:.82rem;color:var(--apple-blue);text-decoration:none">
                <i class="fa-solid fa-arrow-left me-1"></i>Quay lại đăng nhập
            </a>
        </div>
    </div>
</div>
<script>
function togglePw(inputId, iconId) {
    const inp = document.getElementById(inputId);
    const ico = document.getElementById(iconId);
    if (inp.type === 'password') { inp.type = 'text'; ico.className = 'fa-solid fa-eye-slash'; }
    else { inp.type = 'password'; ico.className = 'fa-solid fa-eye'; }
}

function setRule(id, pass) {
    const el = document.getElementById(id);
    el.className = 'pw-rule' + (pass ? ' pass' : '');
    el.querySelector('i').className = pass ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle';
}

function checkAll() {
    const pw = document.getElementById('newPw').value;
    const bar = document.getElementById('pwBar');
    const label = document.getElementById('pwLabel');

    // Rules
    setRule('rule-len', pw.length >= 3);
    setRule('rule-upper', /[A-Z]/.test(pw));
    setRule('rule-digit', /[0-9]/.test(pw));
    setRule('rule-special', /[^A-Za-z0-9]/.test(pw));

    // Strength
    let score = 0;
    if (pw.length >= 3) score++;
    if (pw.length >= 6) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    const levels = [
        { w:'20%', bg:'var(--danger)', t:'Rất yếu' },
        { w:'40%', bg:'var(--danger)', t:'Yếu' },
        { w:'60%', bg:'var(--warning)', t:'Trung bình' },
        { w:'80%', bg:'var(--apple-blue)', t:'Khá' },
        { w:'100%', bg:'var(--success)', t:'Mạnh' }
    ];
    const lvl = levels[Math.min(score, 4)];
    bar.style.width = pw.length ? lvl.w : '0';
    bar.style.background = lvl.bg;
    label.textContent = pw.length ? lvl.t : '';

    checkMatch();
}

function checkMatch() {
    const pw = document.getElementById('newPw').value;
    const cf = document.getElementById('confirmPw').value;
    const label = document.getElementById('matchLabel');

    if (!cf) { label.innerHTML = ''; return; }
    if (pw === cf) {
        label.innerHTML = '<i class="fa-solid fa-circle-check me-1" style="color:var(--success)"></i><span style="color:var(--success)">Mật khẩu khớp</span>';
    } else {
        label.innerHTML = '<i class="fa-solid fa-circle-xmark me-1" style="color:var(--danger)"></i><span style="color:var(--danger)">Mật khẩu không khớp</span>';
    }
}

// Submit loading
document.getElementById('resetForm').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Đang xử lý...';
});
</script>
</body>
</html>
