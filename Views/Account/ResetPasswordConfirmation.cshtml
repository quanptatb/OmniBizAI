@{ Layout = null; ViewData["Title"] = "Đặt lại thành công"; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt lại mật khẩu thành công - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes checkBounce { 0% { transform:scale(0); } 60% { transform:scale(1.2); } 100% { transform:scale(1); } }
        .check-icon { animation: checkBounce .5s ease-out .2s both; }
    </style>
</head>
<body>
<div class="login-page">
    <div class="login-card text-center" style="animation: slideUp .5s ease-out; max-width:420px">
        <!-- Animated success icon -->
        <div class="check-icon" style="width:72px;height:72px;background:rgba(52,199,89,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
            <i class="fa-solid fa-circle-check" style="font-size:32px;color:var(--success)"></i>
        </div>

        <h1 style="font-size:1.4rem;font-weight:700;color:var(--text-primary);margin-bottom:8px">Mật khẩu đã được đặt lại!</h1>
        <p style="font-size:.88rem;color:var(--text-secondary);margin-bottom:8px;line-height:1.5">
            Mật khẩu của bạn đã được cập nhật thành công.
        </p>
        <p style="font-size:.82rem;color:var(--text-muted);margin-bottom:28px">
            Bạn có thể đăng nhập ngay bằng mật khẩu mới.
        </p>

        <!-- Security tips -->
        <div style="background:var(--parchment);border-radius:var(--r-sm);padding:14px;margin-bottom:24px;text-align:left">
            <p style="font-size:.72rem;font-weight:700;color:var(--text-secondary);margin-bottom:8px">
                <i class="fa-solid fa-shield-halved me-1" style="color:var(--apple-blue)"></i>Mẹo bảo mật
            </p>
            <ul style="font-size:.75rem;color:var(--text-muted);margin:0;padding-left:16px;line-height:1.8">
                <li>Không chia sẻ mật khẩu với người khác</li>
                <li>Sử dụng mật khẩu mạnh có cả chữ, số và ký tự đặc biệt</li>
                <li>Đổi mật khẩu định kỳ mỗi 3-6 tháng</li>
            </ul>
        </div>

        <a asp-action="Login" class="btn btn-primary w-100 py-2" style="font-weight:700;font-size:.92rem;border-radius:12px;text-decoration:none;box-shadow:0 4px 12px rgba(0,102,204,.2)">
            <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập ngay
        </a>

        <p style="font-size:.7rem;color:var(--text-muted);margin-top:16px">
            Trang sẽ tự chuyển sau <span id="countdown" style="font-weight:700;color:var(--apple-blue)">10</span> giây
        </p>
    </div>
</div>
<script>
// Auto-redirect countdown
(function() {
    let sec = 10;
    const span = document.getElementById('countdown');
    const timer = setInterval(() => {
        sec--;
        span.textContent = sec;
        if (sec <= 0) {
            clearInterval(timer);
            window.location.href = '@Url.Action("Login", "Account")';
        }
    }, 1000);
})();
</script>
</body>
</html>
