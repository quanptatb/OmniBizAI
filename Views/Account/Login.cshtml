@model OmniBizAI.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <i class="fa-solid fa-brain"></i>
        </div>
        <h1 class="login-title">OmniBizAI</h1>
        <p class="login-subtitle">Hệ thống vận hành thông minh cho doanh nghiệp</p>

        <form asp-action="Login" method="post">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label fw-bold small text-uppercase text-muted">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                    <input asp-for="UserName" class="form-control bg-light border-start-0" placeholder="admin@omnibiz.demo" autofocus />
                </div>
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold small text-uppercase text-muted">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                    <input asp-for="Password" class="form-control bg-light border-start-0" placeholder="••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small">Ghi nhớ đăng nhập</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); border: none; border-radius: 10px;">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập
            </button>
        </form>

        <div class="mt-4 p-3 rounded border" style="background:#f8fafc;">
            <p class="text-muted small mb-2 fw-bold"><i class="fa-solid fa-bolt me-1 text-warning"></i>Đăng nhập nhanh:</p>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm btn-outline-danger demo-btn" data-user="admin@omnibiz.demo">
                    <i class="fa-solid fa-shield-halved me-1"></i>Admin
                </button>
                <button type="button" class="btn btn-sm btn-outline-primary demo-btn" data-user="giamdoc@omnibiz.demo">
                    <i class="fa-solid fa-crown me-1"></i>Giám đốc
                </button>
                <button type="button" class="btn btn-sm btn-outline-success demo-btn" data-user="manager.it@omnibiz.demo">
                    <i class="fa-solid fa-user-tie me-1"></i>Quản lý IT
                </button>
                <button type="button" class="btn btn-sm btn-outline-info demo-btn" data-user="staff@omnibiz.demo">
                    <i class="fa-solid fa-user me-1"></i>Nhân viên
                </button>
                <button type="button" class="btn btn-sm btn-outline-warning demo-btn" data-user="accountant@omnibiz.demo">
                    <i class="fa-solid fa-calculator me-1"></i>Kế toán
                </button>
            </div>
        </div>
    </div>
</div>
<script>
document.querySelectorAll('.demo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('UserName').value = btn.dataset.user;
        document.getElementById('Password').value = '123';
        // Flash effect
        btn.classList.remove('btn-outline-danger','btn-outline-primary','btn-outline-success','btn-outline-info','btn-outline-warning');
        btn.classList.add('btn-dark');
        btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>' + btn.textContent.trim();
        setTimeout(() => document.querySelector('form').submit(), 300);
    });
});
</script>
</body>
</html>
