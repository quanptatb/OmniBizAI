@model OmniBizAI.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <i class="fa-solid fa-brain"></i>
        </div>
        <h1 class="login-title">OmniBizAI</h1>
        <p class="login-subtitle">Hệ thống vận hành thông minh cho doanh nghiệp</p>

        <form asp-action="Login" method="post">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label">Tên đăng nhập</label>
                <input asp-for="UserName" class="form-control" placeholder="admin@omnibiz.demo" autofocus />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" class="form-control" placeholder="••••" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label" style="font-size:.82rem;color:var(--text-secondary)">Ghi nhớ đăng nhập</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2" style="font-weight:500;font-size:.88rem;">
                Đăng nhập
            </button>
        </form>

        <div class="mt-4 p-3" style="background:var(--parchment);border-radius:var(--r-md);border:1px solid var(--divider);">
            <p style="font-size:.75rem;color:var(--text-secondary);margin-bottom:10px;font-weight:600;">
                <i class="fa-solid fa-bolt me-1" style="color:var(--warning)"></i>Đăng nhập nhanh <span style="font-weight:400;opacity:.7">(mật khẩu: 123)</span>
            </p>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="sysadmin@omnibiz.vn" title="System Administrator – SYSTEM_ADMIN">
                    <i class="fa-solid fa-shield-halved me-1"></i>Sys Admin
                </button>
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="giamdoc@omnibiz.vn" title="Nguyễn Minh Tuấn – EXECUTIVE">
                    <i class="fa-solid fa-crown me-1"></i>Giám đốc
                </button>
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="tp.it@omnibiz.vn" title="Phạm Đức Anh – DEPARTMENT_MANAGER">
                    <i class="fa-solid fa-user-tie me-1"></i>TP IT
                </button>
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="tp.sales@omnibiz.vn" title="Hoàng Thị Mai – DEPARTMENT_MANAGER">
                    <i class="fa-solid fa-chart-line me-1"></i>TP Sales
                </button>
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="ketoan.truong@omnibiz.vn" title="Nguyễn Thị Hạnh – ACCOUNTANT">
                    <i class="fa-solid fa-calculator me-1"></i>Kế toán
                </button>
                <button type="button" class="btn btn-sm btn-light demo-btn" data-user="vu.ngoc.hai@omnibiz.vn" title="Vũ Ngọc Hải – STAFF (Kinh doanh)">
                    <i class="fa-solid fa-user me-1"></i>Nhân viên
                </button>
            </div>
        </div>
    </div>
</div>
<script>
document.querySelectorAll('.demo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('UserName').value = btn.dataset.user;
        document.getElementById('Password').value = '123';
        btn.style.background = 'var(--apple-blue)';
        btn.style.color = '#fff';
        btn.style.borderColor = 'var(--apple-blue)';
        setTimeout(() => document.querySelector('form').submit(), 250);
    });
});
</script>
</body>
</html>
