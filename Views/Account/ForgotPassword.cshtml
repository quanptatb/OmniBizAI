@model OmniBizAI.ViewModels.ForgotPasswordViewModel
@{ Layout = null; ViewData["Title"] = "Quên mật khẩu"; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@keyframes slideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
        .info-tip { background:rgba(0,102,204,.04); border:1px solid rgba(0,102,204,.1); border-radius:var(--r-sm); padding:12px; margin-bottom:20px; font-size:.78rem; color:var(--text-secondary); line-height:1.6; }
        .info-tip i { color:var(--apple-blue); margin-right:6px; }
        .error-box { background:rgba(255,59,48,.05); border:1px solid rgba(255,59,48,.12); border-radius:var(--r-sm); padding:10px 14px; margin-bottom:16px; }
        .error-box div { font-size:.82rem; color:var(--danger); }
    </style>
</head>
<body>
<div class="login-page">
    <div class="login-card" style="animation: slideUp .5s ease-out; max-width:440px">
        <div style="width:56px;height:56px;background:rgba(0,102,204,.08);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
            <i class="fa-solid fa-key" style="font-size:22px;color:var(--apple-blue)"></i>
        </div>
        <h1 style="font-size:1.3rem;font-weight:700;color:var(--text-primary);margin-bottom:6px;text-align:center">Quên mật khẩu</h1>
        <p style="font-size:.85rem;color:var(--text-secondary);margin-bottom:20px;text-align:center">
            Nhập email hoặc tên đăng nhập để nhận liên kết đặt lại mật khẩu
        </p>

        @* Error display *@
        @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="error-box">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="fa-solid fa-circle-exclamation me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        @* Info tip *@
        <div class="info-tip">
            <i class="fa-solid fa-circle-info"></i>
            Chúng tôi sẽ gửi một email chứa liên kết để đặt lại mật khẩu. Liên kết có hiệu lực trong <strong>2 giờ</strong>.
        </div>

        <form asp-action="ForgotPassword" method="post" id="forgotForm">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-bold">Email hoặc tên đăng nhập</label>
                <div style="position:relative">
                    <i class="fa-solid fa-envelope" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:.82rem"></i>
                    <input asp-for="Email" class="form-control" placeholder="email@company.com hoặc username" style="padding-left:36px" autofocus autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 mb-3" style="font-weight:600;font-size:.88rem;border-radius:10px" id="submitBtn">
                <i class="fa-solid fa-paper-plane me-2"></i>Gửi liên kết đặt lại
            </button>

            <div style="text-align:center">
                <a asp-action="Login" style="font-size:.82rem;color:var(--apple-blue);text-decoration:none;font-weight:500">
                    <i class="fa-solid fa-arrow-left me-1"></i>Quay lại đăng nhập
                </a>
            </div>
        </form>

        <!-- Security note -->
        <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--divider);text-align:center">
            <p style="font-size:.72rem;color:var(--text-muted);margin:0;line-height:1.5">
                <i class="fa-solid fa-shield-halved me-1"></i>
                Nếu bạn không có email, hãy liên hệ quản trị viên để được hỗ trợ đặt lại mật khẩu.
            </p>
        </div>
    </div>
</div>
<script>
// Submit loading state
document.getElementById('forgotForm').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Đang gửi...';
});

// Client-side email validation feedback
document.querySelector('[name="Email"]').addEventListener('input', function() {
    const val = this.value.trim();
    this.style.borderColor = val.length > 2 ? 'var(--apple-blue)' : '';
});
</script>
</body>
</html>
