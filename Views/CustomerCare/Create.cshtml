@model OmniBizAI.ViewModels.CustomerCareCreateViewModel
@{
    ViewData["Title"] = "Tạo tương tác CSKH";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <a href='/CustomerCare' style='color:var(--apple-blue);text-decoration:none'>Chăm sóc KH</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Tạo mới</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-headset"></i> Tạo tương tác chăm sóc khách hàng</h5>
                <a asp-action="Index" class="btn btn-sm btn-light border" style="border-radius:8px"><i class="fa-solid fa-list me-1"></i>Danh sách</a>
            </div>
            <div class="card-body-custom">
                <form method="post" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <!-- Customer -->
                        <div class="col-md-6">
                            <label asp-for="CustomerId" class="form-label fw-bold">Khách hàng <span class="text-danger">*</span></label>
                            <select asp-for="CustomerId" class="form-select" style="border-radius:10px" id="customerSelect">
                                <option value="">— Chọn khách hàng —</option>
                                @foreach (var c in Model.Customers)
                                {
                                    <option value="@c.Value" selected="@(Model.PreselectedCustomerId?.ToString() == c.Value)">@c.Text</option>
                                }
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger small"></span>
                        </div>
                        <!-- Contact -->
                        <div class="col-md-6">
                            <label asp-for="CustomerContactId" class="form-label fw-bold">Người liên hệ</label>
                            <select asp-for="CustomerContactId" class="form-select" style="border-radius:10px" id="contactSelect">
                                <option value="">— Chọn liên hệ —</option>
                                @foreach (var c in Model.Contacts)
                                {
                                    <option value="@c.Value">@c.Text</option>
                                }
                            </select>
                        </div>
                        <!-- Type -->
                        <div class="col-md-4">
                            <label asp-for="Type" class="form-label fw-bold">Loại tương tác <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select" style="border-radius:10px">
                                <option value="Call">📞 Cuộc gọi</option>
                                <option value="Email">📧 Email</option>
                                <option value="Meeting">🤝 Cuộc họp</option>
                                <option value="Visit">🏢 Thăm viếng</option>
                                <option value="Note">📝 Ghi chú</option>
                                <option value="Complaint">⚠️ Khiếu nại</option>
                                <option value="Feedback">💬 Phản hồi</option>
                            </select>
                        </div>
                        <!-- Priority -->
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label fw-bold">Mức độ ưu tiên</label>
                            <select asp-for="Priority" class="form-select" style="border-radius:10px">
                                <option value="Low">Thấp</option>
                                <option value="Normal" selected>Bình thường</option>
                                <option value="High">Cao</option>
                                <option value="Urgent">Khẩn cấp</option>
                            </select>
                        </div>
                        <!-- Assigned -->
                        <div class="col-md-4">
                            <label asp-for="AssignedToUserId" class="form-label fw-bold">Giao cho</label>
                            <select asp-for="AssignedToUserId" class="form-select" style="border-radius:10px">
                                <option value="">— Tự giao cho tôi —</option>
                                @foreach (var u in Model.Users)
                                {
                                    <option value="@u.Value">@u.Text</option>
                                }
                            </select>
                        </div>
                        <!-- Subject -->
                        <div class="col-md-12">
                            <label asp-for="Subject" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                            <input asp-for="Subject" class="form-control" placeholder="VD: Gọi xác nhận đơn hàng..." style="border-radius:10px" />
                            <span asp-validation-for="Subject" class="text-danger small"></span>
                        </div>
                        <!-- Description -->
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nội dung tương tác..." style="border-radius:10px;resize:vertical"></textarea>
                        </div>
                        <!-- Schedule -->
                        <div class="col-md-6">
                            <label asp-for="ScheduledAt" class="form-label fw-bold">Lịch hẹn</label>
                            <input asp-for="ScheduledAt" type="datetime-local" class="form-control" style="border-radius:10px" />
                            <div class="text-muted small mt-1"><i class="fa-solid fa-info-circle me-1"></i>Để trống nếu thực hiện ngay</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DurationMinutes" class="form-label fw-bold">Thời lượng (phút)</label>
                            <input asp-for="DurationMinutes" type="number" min="1" max="480" class="form-control" placeholder="VD: 30" style="border-radius:10px" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end pt-4 mt-3" style="border-top:1px solid var(--divider)">
                        <a asp-action="Index" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-check me-2"></i>Tạo tương tác</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('customerSelect')?.addEventListener('change', async function () {
            const customerId = this.value;
            const contactSelect = document.getElementById('contactSelect');
            contactSelect.innerHTML = '<option value="">— Đang tải... —</option>';
            if (!customerId) { contactSelect.innerHTML = '<option value="">— Chọn liên hệ —</option>'; return; }
            try {
                const res = await fetch('/CustomerCare/GetContacts?customerId=' + customerId);
                const contacts = await res.json();
                contactSelect.innerHTML = '<option value="">— Chọn liên hệ —</option>';
                contacts.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.value;
                    opt.textContent = c.text;
                    contactSelect.appendChild(opt);
                });
            } catch { contactSelect.innerHTML = '<option value="">— Lỗi tải —</option>'; }
        });
    </script>
}
