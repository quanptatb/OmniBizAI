@model OmniBizAI.ViewModels.VendorListViewModel
@{ ViewData["Title"] = "Nhà cung cấp"; ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Nhà cung cấp</span>"; }

@{ var activeCount = Model.Items.Count(v => v.IsActive); }
<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon orange"><i class="fa-solid fa-truck"></i></div><div class="stat-value">@Model.TotalCount</div><div class="stat-label">Tổng NCC</div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-check-circle"></i></div><div class="stat-value">@activeCount</div><div class="stat-label">Hoạt động</div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon red"><i class="fa-solid fa-circle-xmark"></i></div><div class="stat-value">@(Model.TotalCount - activeCount)</div><div class="stat-label">Ngừng</div></div></div>
</div>

<div class="content-card mb-4"><div class="card-body-custom">
    <form method="get" class="row g-2">
        <div class="col-md-7"><input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Tìm theo tên hoặc mã..." /></div>
        <div class="col-md-2"><button type="submit" class="btn btn-outline-primary w-100"><i class="fa-solid fa-search me-1"></i>Tìm</button></div>
        <div class="col-md-3 text-end"><a asp-action="Create" class="btn btn-primary w-100"><i class="fa-solid fa-plus me-2"></i>Thêm NCC</a></div>
    </form>
</div></div>

<div class="content-card"><div class="card-body-custom p-0">
    <table class="data-table">
        <thead><tr><th class="ps-3">Mã</th><th>Tên NCC</th><th>MST</th><th>Email</th><th>SĐT</th><th>Đơn hàng</th><th>Trạng thái</th><th class="pe-3">Thao tác</th></tr></thead>
        <tbody>
            @foreach (var v in Model.Items)
            {
                <tr>
                    <td class="ps-3" style="font-weight:600;color:var(--apple-blue)">@v.Code</td>
                    <td><a asp-action="Details" asp-route-id="@v.Id" style="font-weight:500;color:var(--text-primary);text-decoration:none">@v.Name</a></td>
                    <td style="color:var(--text-secondary);font-size:.82rem">@(v.TaxCode ?? "—")</td>
                    <td style="font-size:.82rem">@(v.Email ?? "—")</td>
                    <td style="font-size:.82rem">@(v.PhoneNumber ?? "—")</td>
                    <td><span class="badge bg-light text-dark">@v.PurchaseOrderCount PO</span></td>
                    <td><span class="status-badge-soft @(v.IsActive ? "badge-on-track" : "badge-late")"><span class="status-dot"></span>@(v.IsActive ? "Hoạt động" : "Ngừng")</span></td>
                    <td class="pe-3">
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-outline-primary btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-outline-primary btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-pen"></i></a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any()) { <tr><td colspan="8" class="text-center py-4" style="color:var(--text-muted)">Chưa có nhà cung cấp</td></tr> }
        </tbody>
    </table>
</div></div>
