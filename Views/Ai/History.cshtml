@{
    ViewData["Title"] = "Lịch sử AI (Generation History)";
}

<section class="page-header">
    <div>
        <span class="eyebrow"><i class="bi bi-clock-history"></i> AI Copilot</span>
        <h1>Lịch sử AI (Generation History)</h1>
        <p>Theo dõi lịch sử các câu hỏi, báo cáo và dữ liệu đã được AI tạo ra.</p>
    </div>
    <button class="btn-app text-danger" data-demo-toast><i class="bi bi-trash"></i> Xóa lịch sử cũ</button>
</section>

<div class="data-table-container">
    <div class="table-actions">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Tìm theo prompt hoặc module..." class="form-control form-control-sm" />
        </div>
        <select class="form-select form-select-sm" style="width: 150px;">
            <option value="">Tất cả module</option>
            <option value="Finance">Finance</option>
            <option value="KPI">KPI/OKR</option>
            <option value="Workflow">Workflow</option>
        </select>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Thời gian</th>
                <th>Người dùng</th>
                <th>Module / Loại Prompt</th>
                <th>Dữ liệu đầu vào (Prompt)</th>
                <th>Đánh giá</th>
                <th class="text-end">Chi tiết</th>
            </tr>
        </thead>
        <tbody>
