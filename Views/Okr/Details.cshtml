@model OmniBizAI.ViewModels.OkrDetailViewModel
@{ ViewData["Title"] = "Chi tiết OKR"; ViewData["Breadcrumb"] = "<a href='/Okr' style='color:var(--apple-blue);text-decoration:none'>OKR</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chi tiết</span>"; }

<!-- Header with actions -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title mb-1">@Model.ObjectiveName</h4>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-primary">@Model.Level</span>
            <span class="badge bg-info">@Model.Cycle</span>
            <span class="badge" style="background:@(Model.Status == "Active" ? "var(--success)" : Model.Status == "Completed" ? "var(--apple-blue)" : Model.Status == "Draft" ? "var(--text-muted)" : "var(--danger)");color:#fff">@Model.Status</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-pen me-1"></i>Sửa</a>
        @if (Model.Status == "Draft") {
            <form asp-action="Activate" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success btn-sm"><i class="fa-solid fa-play me-1"></i>Kích hoạt</button>
            </form>
        }
        @if (Model.Status == "Active") {
            <form asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-stop me-1"></i>Đóng</button>
            </form>
        }
        <a asp-action="Index" class="btn btn-light btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Quay lại</a>
    </div>
</div>

<!-- Progress bar -->
<div class="content-card mb-4">
    <div class="card-body-custom">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 style="font-weight:600;margin:0">Tiến độ tổng thể</h5>
            <span style="font-size:1.2rem;font-weight:700;color:var(--apple-blue)">@Model.TotalProgress%</span>
        </div>
        <div class="progress" style="height:12px;border-radius:var(--r-md)">
            <div class="progress-bar @OmniBizAI.Helpers.ProgressHelper.GetProgressColorClass(Model.TotalProgress)" style="width:@Math.Min(Model.TotalProgress,100)%"></div>
        </div>
    </div>
</div>

<!-- Key Results with update form -->
<div class="content-card mb-4">
    <div class="card-header-custom"><h5><i class="fa-solid fa-key" style="color:var(--warning)"></i> Key Results (@Model.KeyResults.Count)</h5></div>
    <div class="card-body-custom p-0">
        <table class="data-table">
            <thead><tr><th class="ps-3">Key Result</th><th class="text-center">ĐV</th><th class="text-end">Mục tiêu</th><th class="text-end">Thực tế</th><th style="width:200px">Tiến độ</th><th class="pe-3">Cập nhật</th></tr></thead>
            <tbody>
                @foreach (var kr in Model.KeyResults) {
                    <tr>
                        <td class="ps-3" style="font-weight:500">@kr.KeyResultName @if(kr.IsInverse){<span class="badge bg-warning text-dark" style="font-size:.6rem">↓</span>}</td>
                        <td class="text-center" style="font-size:.82rem">@kr.Unit</td>
                        <td class="text-end" style="font-weight:600">@kr.TargetValue.ToString("N0")</td>
                        <td class="text-end">@kr.CurrentValue.ToString("N0")</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:6px;border-radius:var(--r-sm)"><div class="progress-bar @OmniBizAI.Helpers.ProgressHelper.GetProgressColorClass(kr.Progress)" style="width:@Math.Min(kr.Progress,100)%"></div></div>
                                <span style="font-size:.78rem;font-weight:600;min-width:40px">@kr.Progress%</span>
                            </div>
                        </td>
                        <td class="pe-3">
                            @if (Model.Status == "Active") {
                                <form asp-action="UpdateKeyResult" method="post" class="d-flex gap-1">@Html.AntiForgeryToken()
                                    <input type="hidden" name="KeyResultId" value="@kr.Id" />
                                    <input type="hidden" name="OkrId" value="@Model.Id" />
                                    <input type="number" name="CurrentValue" value="@kr.CurrentValue" class="form-control form-control-sm" style="width:80px;font-size:.78rem" step="1" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" style="font-size:.68rem;padding:2px 6px"><i class="fa-solid fa-check"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Links -->
<div class="row g-3">
    @if (Model.MissionLinks.Any()) {
        <div class="col-md-4"><div class="content-card h-100"><div class="card-header-custom"><h5><i class="fa-solid fa-star" style="color:var(--warning)"></i> Sứ mệnh</h5></div><div class="card-body-custom"><ul class="list-unstyled mb-0">@foreach(var m in Model.MissionLinks){<li class="mb-1" style="font-size:.85rem"><i class="fa-solid fa-check-circle text-success me-1"></i>@m</li>}</ul></div></div></div>
    }
    @if (Model.DepartmentLinks.Any()) {
        <div class="col-md-4"><div class="content-card h-100"><div class="card-header-custom"><h5><i class="fa-solid fa-sitemap" style="color:var(--apple-blue)"></i> Phòng ban</h5></div><div class="card-body-custom"><ul class="list-unstyled mb-0">@foreach(var d in Model.DepartmentLinks){<li class="mb-1" style="font-size:.85rem"><i class="fa-solid fa-building me-1" style="color:var(--apple-blue)"></i>@d</li>}</ul></div></div></div>
    }
    @if (Model.EmployeeLinks.Any()) {
        <div class="col-md-4"><div class="content-card h-100"><div class="card-header-custom"><h5><i class="fa-solid fa-users" style="color:var(--success)"></i> Nhân viên</h5></div><div class="card-body-custom"><ul class="list-unstyled mb-0">@foreach(var e in Model.EmployeeLinks){<li class="mb-1" style="font-size:.85rem"><i class="fa-solid fa-user me-1" style="color:var(--apple-blue)"></i>@e</li>}</ul></div></div></div>
    }
</div>
