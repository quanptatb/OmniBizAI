@model OmniBizAI.ViewModels.OkrEditViewModel
@{ ViewData["Title"] = "Chỉnh sửa OKR"; ViewData["Breadcrumb"] = "<a href='/Okr' style='color:var(--apple-blue);text-decoration:none'>OKR</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>"; }
<div class="content-card" style="max-width:560px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-pen"></i> Chỉnh sửa OKR</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Edit">@Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-12"><label class="form-label">Tên mục tiêu <span class="text-danger">*</span></label><input asp-for="ObjectiveName" class="form-control" /><span asp-validation-for="ObjectiveName" class="text-danger" style="font-size:.78rem"></span></div>
                <div class="col-md-6">
                    <label class="form-label">Cấp độ</label>
                    <select asp-for="Level" class="form-select">
                        @foreach (var l in EnumHelper.GetSelectList<OkrLevel>(Model.Level.ToString()))
                        { <option value="@l.Value" selected="@l.Selected">@l.Text</option> }
                    </select>
                </div>
                <div class="col-md-6"><label class="form-label">Chu kỳ</label><input asp-for="Cycle" class="form-control" placeholder="Q2 2026" /></div>
            </div>
            <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Lưu</button><a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">Hủy</a></div>
        </form>
    </div>
</div>
