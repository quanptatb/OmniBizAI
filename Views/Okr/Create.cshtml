@model OmniBizAI.ViewModels.OkrCreateViewModel
@{ ViewData["Title"] = "Tạo OKR mới"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-plus-circle me-2"></i>Tạo OKR mới</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<form asp-action="Create" method="post">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent"><h5 class="mb-0">Thông tin mục tiêu</h5></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="ObjectiveName" class="form-label">Tên mục tiêu <span class="text-danger">*</span></label>
                    <input asp-for="ObjectiveName" class="form-control" placeholder="VD: Tăng doanh thu Q2 lên 20%" />
                    <span asp-validation-for="ObjectiveName" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Level" class="form-label">Cấp độ</label>
                    <select asp-for="Level" class="form-select">
                        <option value="Company">Công ty</option>
                        <option value="Department">Phòng ban</option>
                        <option value="Individual">Cá nhân</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="Cycle" class="form-label">Chu kỳ</label>
                    <input asp-for="Cycle" class="form-control" placeholder="VD: Q2-2026" />
                </div>
            </div>
        </div>
    </div>

    <!-- Key Results -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-key me-2"></i>Key Results</h5>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addKeyResult()"><i class="bi bi-plus me-1"></i>Thêm KR</button>
        </div>
        <div class="card-body" id="keyResultsContainer">
            <div class="kr-row row g-3 mb-3 align-items-end" data-index="0">
                <div class="col-md-5">
                    <label class="form-label">Tên Key Result</label>
                    <input name="KeyResults[0].KeyResultName" class="form-control" placeholder="VD: Doanh thu đạt 5 tỷ" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Đơn vị</label>
                    <input name="KeyResults[0].Unit" class="form-control" placeholder="VNĐ, %, ..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Mục tiêu</label>
                    <input name="KeyResults[0].TargetValue" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-4">
                        <input name="KeyResults[0].IsInverse" type="checkbox" value="true" class="form-check-input" />
                        <label class="form-check-label">Chỉ số nghịch</label>
                    </div>
                </div>
                <div class="col-md-1">
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.kr-row').remove()"><i class="bi bi-trash"></i></button>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Tạo OKR</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
<script>
let krIndex = 1;
function addKeyResult() {
    const container = document.getElementById('keyResultsContainer');
    const html = `<div class="kr-row row g-3 mb-3 align-items-end" data-index="${krIndex}">
        <div class="col-md-5"><label class="form-label">Tên Key Result</label><input name="KeyResults[${krIndex}].KeyResultName" class="form-control" required /></div>
        <div class="col-md-2"><label class="form-label">Đơn vị</label><input name="KeyResults[${krIndex}].Unit" class="form-control" /></div>
        <div class="col-md-2"><label class="form-label">Mục tiêu</label><input name="KeyResults[${krIndex}].TargetValue" type="number" step="0.01" class="form-control" required /></div>
        <div class="col-md-2"><div class="form-check mt-4"><input name="KeyResults[${krIndex}].IsInverse" type="checkbox" value="true" class="form-check-input" /><label class="form-check-label">Chỉ số nghịch</label></div></div>
        <div class="col-md-1"><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.kr-row').remove()"><i class="bi bi-trash"></i></button></div>
    </div>`;
    container.insertAdjacentHTML('beforeend', html);
    krIndex++;
}
</script>
}
