@{
    ViewData["Title"] = "Trang chủ";
    ViewData["Breadcrumb"] = "<span>Trang chủ</span>";
}

<div class="text-center py-5">
    <div style="width:64px;height:64px;background:var(--surface-black);border-radius:var(--r-lg);display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
        <i class="fa-solid fa-brain" style="font-size:28px;color:#fff"></i>
    </div>
    <h1 style="font-size:2rem;font-weight:600;letter-spacing:-0.03em;color:var(--text-primary);margin-bottom:8px">OmniBizAI</h1>
    <p style="font-size:1rem;color:var(--text-secondary);max-width:480px;margin:0 auto 24px">
        Hệ thống vận hành thông minh — quản lý KPI, OKR, quy trình và tài chính doanh nghiệp.
    </p>
    <a asp-controller="Dashboard" asp-action="Index" class="btn-primary-custom" style="font-size:.88rem;padding:10px 28px">
        <i class="fa-solid fa-gauge-high me-2"></i>Vào Dashboard
    </a>
</div>
