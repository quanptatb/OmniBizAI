@model OmniBizAI.ViewModels.ProcurementCreateViewModel
@{ ViewData["Title"] = "Tạo đề xuất mua sắm"; ViewData["Breadcrumb"] = "<span>Tài chính</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Procurement' style='color:var(--apple-blue);text-decoration:none'>Mua sắm</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Tạo mới</span>"; }
<div class="content-card" style="max-width:780px"><div class="card-header-custom"><h5><i class="fa-solid fa-cart-shopping"></i> Tạo đề xuất mua sắm</h5></div><div class="card-body-custom">
    <form method="post" asp-action="Create">@Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-12"><label class="form-label">Tiêu đề <span class="text-danger">*</span></label><input asp-for="Title" class="form-input" placeholder="Mô tả nhu cầu mua sắm..." /><span asp-validation-for="Title" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-6"><label class="form-label">Phòng ban</label><select asp-for="OrganizationUnitId" class="form-input"><option value="">-- Chọn --</option>@foreach(var d in Model.Departments){<option value="@d.Value">@d.Text</option>}</select></div>
            <div class="col-md-6"><label class="form-label">Cần trước ngày</label><input asp-for="NeededByDate" class="form-input" type="date" /></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn-primary-custom"><i class="fa-solid fa-check me-1"></i>Tạo đề xuất</button><a asp-action="Index" class="btn-outline-custom">Hủy</a></div>
    </form>
</div></div>
