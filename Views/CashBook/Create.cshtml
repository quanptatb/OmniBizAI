@model OmniBizAI.ViewModels.CashTransactionCreateViewModel
@{
    var isIncome = Model.TransactionType == "Income";
    ViewData["Title"] = isIncome ? "Ghi nhận thu" : "Ghi nhận chi";
    ViewData["Breadcrumb"] = "<a href='/CashBook' style='color:var(--apple-blue);text-decoration:none'>Sổ thu chi</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>" + (isIncome ? "Ghi nhận thu" : "Ghi nhận chi") + "</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5>
                    @if (isIncome)
                    { <i class="fa-solid fa-arrow-down" style="color:var(--success)"></i> }
                    else
                    { <i class="fa-solid fa-arrow-up" style="color:var(--danger)"></i> }
                    @(isIncome ? "Ghi nhận khoản thu" : "Ghi nhận khoản chi")
                </h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="TransactionType" />

                    <div class="row g-4 mb-4">
                        <!-- Type Switch -->
                        <div class="col-12">
                            <div class="d-flex gap-2">
                                <a asp-action="Create" asp-route-type="Income" class="btn @(isIncome ? "btn-success" : "btn-outline-secondary") flex-grow-1" style="border-radius:10px;padding:12px">
                                    <i class="fa-solid fa-arrow-down me-2"></i>Thu
                                </a>
                                <a asp-action="Create" asp-route-type="Expense" class="btn @(!isIncome ? "btn-danger" : "btn-outline-secondary") flex-grow-1" style="border-radius:10px;padding:12px">
                                    <i class="fa-solid fa-arrow-up me-2"></i>Chi
                                </a>
                            </div>
                        </div>

                        <!-- Category -->
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Danh mục <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" style="border-radius:8px" id="categorySelect">
                                <option value="">-- Chọn danh mục --</option>
                                @if (isIncome)
                                {
                                    <option value="Bán hàng">Bán hàng</option>
                                    <option value="Dịch vụ">Dịch vụ</option>
                                    <option value="Lãi vay">Lãi vay / Đầu tư</option>
                                    <option value="Hoàn thuế">Hoàn thuế</option>
                                    <option value="Thu khác">Thu khác</option>
                                }
                                else
                                {
                                    <option value="Lương">Lương & Phúc lợi</option>
                                    <option value="Mua sắm">Mua sắm vật tư</option>
                                    <option value="Dịch vụ">Chi phí dịch vụ</option>
                                    <option value="Thuê mặt bằng">Thuê mặt bằng</option>
                                    <option value="Điện nước">Điện / Nước / Internet</option>
                                    <option value="Vận chuyển">Vận chuyển</option>
                                    <option value="Marketing">Marketing / Quảng cáo</option>
                                    <option value="Bảo trì">Bảo trì / Sửa chữa</option>
                                    <option value="Thuế">Thuế & Phí</option>
                                    <option value="Chi khác">Chi phí khác</option>
                                }
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <!-- Amount -->
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Số tiền <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Amount" type="number" step="1000" min="0" class="form-control" style="border-radius:8px 0 0 8px;font-size:1.1rem;font-weight:700" placeholder="0" />
                                <span class="input-group-text" style="border-radius:0 8px 8px 0;font-weight:600">₫</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Mô tả <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="2" style="border-radius:8px" placeholder="Nội dung giao dịch..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Date + Payment Method -->
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Ngày giao dịch</label>
                            <input asp-for="TransactionDate" type="date" class="form-control" style="border-radius:8px" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Phương thức thanh toán</label>
                            <select asp-for="PaymentMethod" class="form-select" style="border-radius:8px">
                                <option value="">-- Chọn --</option>
                                <option value="Cash">Tiền mặt</option>
                                <option value="BankTransfer">Chuyển khoản</option>
                                <option value="Card">Thẻ</option>
                                <option value="EWallet">Ví điện tử</option>
                                <option value="Other">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Số tham chiếu</label>
                            <input asp-for="ReferenceNo" class="form-control" style="border-radius:8px" placeholder="Hóa đơn, biên lai..." />
                        </div>

                        <!-- Relations -->
                        @if (isIncome)
                        {
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold">Khách hàng</label>
                                <select asp-for="CustomerId" class="form-select" style="border-radius:8px">
                                    <option value="">-- Không chọn --</option>
                                    @foreach (var c in Model.Customers) { <option value="@c.Value">@c.Text</option> }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold">Nhà cung cấp</label>
                                <select asp-for="VendorId" class="form-select" style="border-radius:8px">
                                    <option value="">-- Không chọn --</option>
                                    @foreach (var v in Model.Vendors) { <option value="@v.Value">@v.Text</option> }
                                </select>
                            </div>
                        }
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">Phòng ban</label>
                            <select asp-for="OrganizationUnitId" class="form-select" style="border-radius:8px">
                                <option value="">-- Không chọn --</option>
                                @foreach (var d in Model.Departments) { <option value="@d.Value">@d.Text</option> }
                            </select>
                        </div>

                        @if (!isIncome)
                        {
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold">Ngân sách</label>
                                <select asp-for="BudgetId" class="form-select" style="border-radius:8px">
                                    <option value="">-- Không chọn --</option>
                                    @foreach (var b in Model.Budgets) { <option value="@b.Value">@b.Text</option> }
                                </select>
                            </div>
                        }

                        <!-- Note -->
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">Ghi chú</label>
                            <textarea asp-for="Note" class="form-control" rows="2" style="border-radius:8px" placeholder="Ghi chú thêm (tùy chọn)..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2" style="border-top:1px solid var(--divider);padding-top:16px">
                        <a asp-action="Index" class="btn btn-light" style="border-radius:8px">Hủy bỏ</a>
                        <button type="submit" class="btn @(isIncome ? "btn-success" : "btn-danger")" style="border-radius:8px">
                            <i class="fa-solid @(isIncome ? "fa-arrow-down" : "fa-arrow-up") me-1"></i>Ghi nhận @(isIncome ? "thu" : "chi")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
