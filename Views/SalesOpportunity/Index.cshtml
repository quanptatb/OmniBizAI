@model OmniBizAI.ViewModels.SalesOpportunityListViewModel
@{
    ViewData["Title"] = "Cơ hội bán hàng";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Cơ hội bán hàng</span>";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(52,199,89,.12);color:#1d7a37">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(255,59,48,.08);color:#c33">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Pipeline Visual -->
<div class="content-card mb-4 animate-fade-in">
    <div class="card-body-custom py-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            @foreach (var (stage, label, count, color) in new[] {
                ("Lead", "Tiềm năng", Model.LeadCount, "#94a3b8"),
                ("Qualified", "Đủ ĐK", Model.QualifiedCount, "#007AFF"),
                ("Proposal", "Đề xuất", Model.ProposalCount, "#5856d6"),
                ("Negotiation", "Đàm phán", Model.NegotiationCount, "#ff9500"),
                ("ClosedWon", "Thắng", Model.ClosedWonCount, "#34c759"),
                ("ClosedLost", "Thua", Model.ClosedLostCount, "#ff3b30")
            })
            {
                <a asp-action="Index" asp-route-stage="@stage" style="text-decoration:none;flex:1;min-width:80px;text-align:center;padding:12px 8px;border-radius:12px;background:@(color)08;border:2px solid @(Model.StageFilter == stage ? color : "transparent");transition:.2s">
                    <div style="font-size:1.3rem;font-weight:800;color:@color">@count</div>
                    <div style="font-size:.68rem;color:var(--text-muted);font-weight:600">@label</div>
                </a>
                @if (stage != "ClosedLost") { <i class="fa-solid fa-chevron-right" style="color:var(--text-muted);font-size:.6rem;opacity:.5"></i> }
            }
        </div>
    </div>
</div>

<!-- Value Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-chart-line"></i></div>
            <div class="stat-value">@Model.TotalPipelineValue.ToString("N0") ₫</div><div class="stat-label">Giá trị Pipeline</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card"><div class="stat-icon purple"><i class="fa-solid fa-scale-balanced"></i></div>
            <div class="stat-value">@Model.WeightedValue.ToString("N0") ₫</div><div class="stat-label">Giá trị có trọng số</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-trophy"></i></div>
            <div class="stat-value">@Model.TotalCount</div><div class="stat-label">Tổng cơ hội</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="content-card mb-4">
    <div class="card-body-custom py-3">
        <form method="get" class="d-flex gap-3 align-items-end flex-wrap">
            <div class="flex-grow-1" style="min-width:180px">
                <label class="form-label text-muted small fw-bold">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius:8px 0 0 8px"><i class="fa-solid fa-search" style="font-size:.75rem;color:var(--text-muted)"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control bg-light border-start-0" placeholder="Tiêu đề, mã..." style="border-radius:0 8px 8px 0" />
                </div>
            </div>
            <div style="min-width:120px">
                <label class="form-label text-muted small fw-bold">Nhiệt độ</label>
                <select name="temp" class="form-select" style="border-radius:8px">
                    <option value="">Tất cả</option>
                    @foreach (var t in new[] { ("Hot","🔥 Nóng"), ("Warm","☀️ Ấm"), ("Cold","❄️ Lạnh") })
                    {
                        <option value="@t.Item1" selected="@(Model.TempFilter == t.Item1)">@t.Item2</option>
                    }
                </select>
            </div>
            <div style="min-width:160px">
                <label class="form-label text-muted small fw-bold">Khách hàng</label>
                <select name="customer" class="form-select" style="border-radius:8px">
                    <option value="">Tất cả</option>
                    @foreach (var c in Model.Customers) { <option value="@c.Value" selected="@(Model.CustomerFilter?.ToString() == c.Value)">@c.Text</option> }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" style="border-radius:8px"><i class="fa-solid fa-filter me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-light border" style="border-radius:8px"><i class="fa-solid fa-rotate-left"></i></a>
            </div>
            <div class="ms-auto">
                <a asp-action="Create" class="btn btn-primary" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-plus me-2"></i>Tạo cơ hội</a>
            </div>
        </form>
    </div>
</div>

<!-- List -->
<div class="content-card animate-fade-in">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-handshake-angle"></i> Cơ hội bán hàng <span class="badge" style="background:var(--apple-blue);color:#fff">@Model.Items.Count</span></h5>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-handshake-angle fa-3x mb-3 opacity-25"></i>
            <h5 class="text-muted" style="font-weight:600">Chưa có cơ hội nào</h5>
            <a asp-action="Create" class="btn btn-primary mt-2" style="border-radius:10px"><i class="fa-solid fa-plus me-2"></i>Tạo cơ hội đầu tiên</a>
        </div>
    }

    @foreach (var item in Model.Items)
    {
        var (stageColor, stageLabel) = item.Stage switch
        {
            "Lead" => ("#94a3b8", "Tiềm năng"),
            "Qualified" => ("#007AFF", "Đủ ĐK"),
            "Proposal" => ("#5856d6", "Đề xuất"),
            "Negotiation" => ("#ff9500", "Đàm phán"),
            "ClosedWon" => ("#34c759", "Thắng ✓"),
            "ClosedLost" => ("#ff3b30", "Thua ✗"),
            _ => ("#94a3b8", item.Stage)
        };
        var tempIcon = item.Temperature switch { "Hot" => "🔥", "Warm" => "☀️", "Cold" => "❄️", _ => "" };

        <div class="d-flex gap-3 align-items-start px-4 py-3" style="border-bottom:1px solid var(--divider)">
            <div style="width:40px;height:40px;border-radius:50%;background:@(stageColor)12;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <span style="font-size:.85rem">@tempIcon</span>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <a asp-action="Details" asp-route-id="@item.Id" style="font-weight:600;font-size:.9rem;color:var(--text-primary);text-decoration:none">@item.Title</a>
                        <code style="font-size:.65rem;background:rgba(0,122,255,.06);color:var(--apple-blue);padding:1px 6px;border-radius:4px;margin-left:4px">@item.Code</code>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge rounded-pill" style="background:@(stageColor)12;color:@stageColor;font-size:.65rem;padding:3px 10px">@stageLabel</span>
                        <span style="font-weight:700;color:var(--text-primary);font-size:.88rem">@item.EstimatedValue.ToString("N0") ₫</span>
                    </div>
                </div>
                <div class="d-flex gap-3 mt-1 text-muted" style="font-size:.78rem;flex-wrap:wrap">
                    <span><i class="fa-solid fa-building me-1"></i>@item.CustomerName</span>
                    @if (item.AssignedToName != null) { <span><i class="fa-solid fa-user-check me-1"></i>@item.AssignedToName</span> }
                    @if (item.Source != null) { <span><i class="fa-solid fa-bullseye me-1"></i>@item.Source</span> }
                    @if (item.ExpectedCloseDate.HasValue) { <span><i class="fa-regular fa-calendar me-1"></i>@item.ExpectedCloseDate.Value.ToString("dd/MM/yyyy")</span> }
                    <span><i class="fa-solid fa-percent me-1"></i>@item.Probability%</span>
                </div>
            </div>
        </div>
    }
</div>
