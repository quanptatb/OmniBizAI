@model OmniBizAI.ViewModels.SalesOpportunityCreateViewModel
@{
    ViewData["Title"] = "Tạo cơ hội bán hàng";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <a href='/SalesOpportunity' style='color:var(--apple-blue);text-decoration:none'>Cơ hội BH</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Tạo mới</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-handshake-angle"></i> Tạo cơ hội bán hàng</h5>
                <a asp-action="Index" class="btn btn-sm btn-light border" style="border-radius:8px"><i class="fa-solid fa-list me-1"></i>Danh sách</a>
            </div>
            <div class="card-body-custom">
                <form method="post" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <!-- Customer -->
                        <div class="col-md-6">
                            <label asp-for="CustomerId" class="form-label fw-bold">Khách hàng <span class="text-danger">*</span></label>
                            <select asp-for="CustomerId" class="form-select" style="border-radius:10px" id="customerSelect">
                                <option value="">— Chọn khách hàng —</option>
                                @foreach (var c in Model.Customers) { <option value="@c.Value">@c.Text</option> }
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger small"></span>
                        </div>
                        <!-- Contact -->
                        <div class="col-md-6">
                            <label asp-for="CustomerContactId" class="form-label fw-bold">Người liên hệ</label>
                            <select asp-for="CustomerContactId" class="form-select" style="border-radius:10px" id="contactSelect">
                                <option value="">— Chọn liên hệ —</option>
                                @foreach (var c in Model.Contacts) { <option value="@c.Value">@c.Text</option> }
                            </select>
                        </div>
                        <!-- Title -->
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="VD: Triển khai hệ thống ERP cho ABC..." style="border-radius:10px" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <!-- Value + Probability -->
                        <div class="col-md-4">
                            <label asp-for="EstimatedValue" class="form-label fw-bold">Giá trị ước tính (₫)</label>
                            <input asp-for="EstimatedValue" type="number" min="0" step="1000000" class="form-control" placeholder="VD: 500000000" style="border-radius:10px" />
                            <span asp-validation-for="EstimatedValue" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Probability" class="form-label fw-bold">Xác suất thắng (%)</label>
                            <input asp-for="Probability" type="number" min="0" max="100" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Temperature" class="form-label fw-bold">Nhiệt độ</label>
                            <select asp-for="Temperature" class="form-select" style="border-radius:10px">
                                <option value="Hot">🔥 Nóng</option>
                                <option value="Warm" selected>☀️ Ấm</option>
                                <option value="Cold">❄️ Lạnh</option>
                            </select>
                        </div>
                        <!-- Source + Close Date -->
                        <div class="col-md-4">
                            <label asp-for="Source" class="form-label fw-bold">Nguồn</label>
                            <input asp-for="Source" class="form-control" placeholder="VD: Giới thiệu, Website..." style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpectedCloseDate" class="form-label fw-bold">Dự kiến chốt</label>
                            <input asp-for="ExpectedCloseDate" type="date" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AssignedToUserId" class="form-label fw-bold">Phụ trách</label>
                            <select asp-for="AssignedToUserId" class="form-select" style="border-radius:10px">
                                <option value="">— Tự giao cho tôi —</option>
                                @foreach (var u in Model.Users) { <option value="@u.Value">@u.Text</option> }
                            </select>
                        </div>
                        <!-- Description -->
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Chi tiết cơ hội..." style="border-radius:10px;resize:vertical"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end pt-4 mt-3" style="border-top:1px solid var(--divider)">
                        <a asp-action="Index" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-check me-2"></i>Tạo cơ hội</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('customerSelect')?.addEventListener('change', async function () {
            const cid = this.value;
            const sel = document.getElementById('contactSelect');
            sel.innerHTML = '<option value="">— Đang tải... —</option>';
            if (!cid) { sel.innerHTML = '<option value="">— Chọn liên hệ —</option>'; return; }
            try {
                const res = await fetch('/SalesOpportunity/GetContacts?customerId=' + cid);
                const data = await res.json();
                sel.innerHTML = '<option value="">— Chọn liên hệ —</option>';
                data.forEach(c => { const o = document.createElement('option'); o.value = c.value; o.textContent = c.text; sel.appendChild(o); });
            } catch { sel.innerHTML = '<option value="">— Lỗi —</option>'; }
        });
    </script>
}
