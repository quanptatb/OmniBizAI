@model OmniBizAI.ViewModels.SalesOpportunityEditViewModel
@{
    ViewData["Title"] = "Sửa cơ hội";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <a href='/SalesOpportunity' style='color:var(--apple-blue);text-decoration:none'>Cơ hội BH</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <a href='/SalesOpportunity/Details/" + Model.Id + "' style='color:var(--apple-blue);text-decoration:none'>Chi tiết</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Sửa</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-pen-to-square"></i> Sửa cơ hội bán hàng</h5>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-light border" style="border-radius:8px"><i class="fa-solid fa-eye me-1"></i>Chi tiết</a>
            </div>
            <div class="card-body-custom">
                <!-- Customer context -->
                <div style="background:var(--bg-secondary);border-radius:10px;padding:12px 16px;margin-bottom:20px">
                    <span class="text-muted small">Khách hàng:</span> <strong>@Model.CustomerName</strong>
                </div>

                <form method="post" asp-action="Edit">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="CustomerId" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CustomerContactId" class="form-label fw-bold">Liên hệ</label>
                            <select asp-for="CustomerContactId" class="form-select" style="border-radius:10px">
                                <option value="">— Chọn —</option>
                                @foreach (var c in Model.Contacts) { <option value="@c.Value">@c.Text</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedToUserId" class="form-label fw-bold">Phụ trách</label>
                            <select asp-for="AssignedToUserId" class="form-select" style="border-radius:10px">
                                <option value="">— Không đổi —</option>
                                @foreach (var u in Model.Users) { <option value="@u.Value">@u.Text</option> }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" style="border-radius:10px" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EstimatedValue" class="form-label fw-bold">Giá trị (₫)</label>
                            <input asp-for="EstimatedValue" type="number" min="0" step="1000000" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Probability" class="form-label fw-bold">Xác suất (%)</label>
                            <input asp-for="Probability" type="number" min="0" max="100" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Temperature" class="form-label fw-bold">Nhiệt độ</label>
                            <select asp-for="Temperature" class="form-select" style="border-radius:10px">
                                <option value="Hot">🔥 Nóng</option>
                                <option value="Warm">☀️ Ấm</option>
                                <option value="Cold">❄️ Lạnh</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Source" class="form-label fw-bold">Nguồn</label>
                            <input asp-for="Source" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ExpectedCloseDate" class="form-label fw-bold">Dự kiến chốt</label>
                            <input asp-for="ExpectedCloseDate" type="date" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3" style="border-radius:10px;resize:vertical"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end pt-4 mt-3" style="border-top:1px solid var(--divider)">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-check me-2"></i>Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
