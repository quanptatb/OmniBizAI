@model OmniBizAI.ViewModels.MaintenanceDashboardViewModel
@{
    ViewData["Title"] = "Quản Lý Bảo Trì";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1 text-gray-800"><i class="fas fa-tools text-danger me-2"></i>Trung Tâm Bảo Trì</h2>
        <p class="text-muted small mb-0">Quản lý toàn bộ hoạt động bảo trì thiết bị và xử lý sự cố</p>
    </div>
    <a asp-action="ReportIncident" class="btn btn-danger btn-sm">
        <i class="fas fa-exclamation-triangle me-1"></i>Báo Cáo Sự Cố
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-2 col-md-4">
        <a asp-action="Incidents" asp-route-status="Open" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 py-3 text-center bg-danger text-white rounded-3">
                <div class="card-body py-1">
                    <div class="display-5 fw-bold">@Model.OpenIncidentCount</div>
                    <div class="small opacity-75">Sự cố mở</div>
                    @if (Model.CriticalIncidentCount > 0)
                    {
                        <div class="badge bg-white text-danger mt-1">@Model.CriticalIncidentCount Nghiêm trọng</div>
                    }
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4">
        <a asp-action="PmSchedules" asp-route-overdueOnly="true" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 py-3 text-center @(Model.OverduePmCount > 0 ? "bg-warning" : "bg-light") rounded-3">
                <div class="card-body py-1 @(Model.OverduePmCount > 0 ? "text-dark" : "text-muted")">
                    <div class="display-5 fw-bold">@Model.OverduePmCount</div>
                    <div class="small">PM quá hạn</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4">
        <a asp-action="PmSchedules" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 py-3 text-center bg-primary text-white rounded-3">
                <div class="card-body py-1">
                    <div class="display-5 fw-bold">@Model.DueSoonPmCount</div>
                    <div class="small opacity-75">PM 7 ngày tới</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-2 col-md-4">
        <a asp-action="SpareParts" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 py-3 text-center @(Model.LowStockPartCount > 0 ? "bg-warning" : "bg-light") rounded-3">
                <div class="card-body py-1 @(Model.LowStockPartCount > 0 ? "text-dark" : "text-muted")">
                    <div class="display-5 fw-bold">@Model.LowStockPartCount</div>
                    <div class="small">PT tồn kho thấp</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-xl-4 col-md-8">
        <div class="card border-0 shadow-sm h-100 rounded-3">
            <div class="card-body d-flex align-items-center gap-3 flex-wrap">
                <div class="text-center px-3">
                    <div class="fs-3 fw-bold @(Model.SensorWarningCount > 0 ? "text-danger" : "text-success")">
                        <i class="fas @(Model.SensorWarningCount > 0 ? "fa-exclamation-circle" : "fa-check-circle")"></i>
                    </div>
                    <div class="small text-muted">IoT / Cảm biến</div>
                    <div class="small @(Model.SensorWarningCount > 0 ? "text-danger fw-bold" : "text-success")">
                        @(Model.SensorWarningCount > 0 ? $"{Model.SensorWarningCount} cảnh báo" : "Bình thường")
                    </div>
                </div>
                <div class="vr"></div>
                <div class="d-flex flex-column gap-1">
                    <a asp-action="PmSchedules" class="btn btn-sm btn-outline-primary">📋 Kế hoạch PM</a>
                    <a asp-action="SpareParts" class="btn btn-sm btn-outline-secondary">🔩 Phụ tùng kho</a>
                    <a asp-action="Incidents" class="btn btn-sm btn-outline-danger">🚨 Danh sách sự cố</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Sự cố gần đây -->
    <div class="col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold text-danger"><i class="fas fa-fire me-2"></i>Sự Cố Gần Đây</h6>
                <a asp-action="ReportIncident" class="btn btn-sm btn-danger">+ Báo cáo</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentIncidents.Any())
                {
                    <div class="text-center text-muted py-4"><i class="fas fa-check-circle text-success fa-2x mb-2 d-block"></i>Không có sự cố nào!</div>
                }
                @foreach (var i in Model.RecentIncidents)
                {
                    var sevColor = i.Severity switch { "Critical" => "danger", "High" => "warning", "Medium" => "primary", _ => "secondary" };
                    var sevLabel = i.Severity switch { "Critical" => "Nghiêm trọng", "High" => "Cao", "Medium" => "Trung bình", _ => "Thấp" };
                    var statusColor = i.Status switch { "Open" => "danger", "InProgress" => "primary", _ => "success" };
                    <div class="d-flex align-items-start p-3 border-bottom gap-3">
                        <span class="badge bg-@sevColor mt-1">@sevLabel</span>
                        <div class="flex-grow-1">
                            <a asp-action="IncidentDetail" asp-route-id="@i.Id" class="fw-bold text-dark text-decoration-none">@i.Title</a>
                            <div class="text-muted small">
                                <i class="fas fa-cog me-1"></i>@i.EquipmentName
                                @if (i.DowntimeHours.HasValue && i.DowntimeHours > 0) { <span class="ms-2"><i class="fas fa-clock me-1"></i>@i.DowntimeHours h ngừng máy</span> }
                            </div>
                            <div class="text-muted small">@i.OccurredAt?.LocalDateTime.ToString("dd/MM HH:mm")</div>
                        </div>
                        <span class="badge bg-@statusColor">
                            @(i.Status switch { "Open" => "Mở", "InProgress" => "Đang xử lý", "Resolved" => "Đã xử lý", _ => i.Status })
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- PM sắp tới -->
    <div class="col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold text-primary"><i class="fas fa-calendar-check me-2"></i>Bảo Trì Định Kỳ Sắp Tới</h6>
                <a asp-action="CreatePmSchedule" class="btn btn-sm btn-primary">+ Tạo</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.UpcomingPmTasks.Any())
                {
                    <div class="text-center text-muted py-4">Không có công việc PM nào sắp tới.</div>
                }
                @foreach (var pm in Model.UpcomingPmTasks)
                {
                    var today = DateOnly.FromDateTime(DateTime.Today);
                    var days = pm.NextDueDate.HasValue ? (pm.NextDueDate.Value.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days : 999;
                    <div class="d-flex align-items-center p-3 border-bottom gap-2">
                        <div class="text-center" style="min-width:54px">
                            @if (pm.IsOverdue)
                            {
                                <span class="badge bg-danger rounded-pill px-2">Quá hạn</span>
                            }
                            else if (days == 0)
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-2">Hôm nay</span>
                            }
                            else
                            {
                                <span class="badge bg-primary rounded-pill px-2">@days ngày</span>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold small">@pm.TaskName</div>
                            <div class="text-muted" style="font-size:12px">@pm.EquipmentName</div>
                        </div>
                        <a asp-action="ExecutePm" asp-route-id="@pm.Id" class="btn btn-xs btn-outline-success btn-sm py-0 px-2">
                            <i class="fas fa-play"></i>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
