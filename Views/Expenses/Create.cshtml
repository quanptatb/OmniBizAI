@model OmniBizAI.ViewModels.ExpenseCreateViewModel
@{ ViewData["Title"] = "Ghi nhận chi phí"; ViewData["Breadcrumb"] = "<span>Tài chính</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Expenses' style='color:var(--apple-blue);text-decoration:none'>Chi phí</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Ghi nhận</span>"; }
<div class="content-card" style="max-width:580px"><div class="card-header-custom"><h5><i class="fa-solid fa-receipt"></i> Ghi nhận chi phí</h5></div><div class="card-body-custom">
    <form method="post" asp-action="Create">@Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-12"><label class="form-label">Mô tả <span class="text-danger">*</span></label><input asp-for="Description" class="form-input" /><span asp-validation-for="Description" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-6"><label class="form-label">Số tiền <span class="text-danger">*</span></label><input asp-for="Amount" class="form-input" type="number" step="1000" /><span asp-validation-for="Amount" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-6"><label class="form-label">Ngày chi</label><input asp-for="ExpenseDate" class="form-input" type="date" /></div>
            <div class="col-12"><label class="form-label">Ngân sách</label><select asp-for="BudgetId" class="form-input"><option value="">-- Chọn --</option>@foreach(var b in Model.Budgets){<option value="@b.Value">@b.Text</option>}</select></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn-primary-custom"><i class="fa-solid fa-check me-1"></i>Ghi nhận</button><a asp-action="Index" class="btn-outline-custom">Hủy</a></div>
    </form>
</div></div>
