@model OmniBizAI.ViewModels.CustomerDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Customers' style='color:var(--apple-blue);text-decoration:none'>Khách hàng</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>" + Model.Code + "</span>";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(52,199,89,.12);color:#1d7a37">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(255,59,48,.08);color:#c33">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-address-card"></i></div><div class="stat-value">@Model.Contacts.Count</div><div class="stat-label">Liên hệ</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-building"></i></div><div class="stat-value">@Model.Sites.Count</div><div class="stat-label">Chi nhánh</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon orange"><i class="fa-solid fa-file-lines"></i></div><div class="stat-value">@Model.OperationRequestCount</div><div class="stat-label">Yêu cầu VH</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon @(Model.IsActive ? "green" : "red")"><i class="fa-solid @(Model.IsActive ? "fa-circle-check" : "fa-circle-xmark")"></i></div><div class="stat-value">@(Model.IsActive ? "HĐ" : "Ngừng")</div><div class="stat-label">Trạng thái</div></div></div>
</div>

<!-- Info Card -->
<div class="content-card mb-4 animate-fade-in">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-building"></i> Thông tin khách hàng</h5>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm" style="border-radius:8px"><i class="fa-solid fa-pen me-1"></i>Sửa</a>
            <form asp-action="Toggle" asp-route-id="@Model.Id" method="post" class="d-inline">@Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm @(Model.IsActive ? "btn-outline-warning" : "btn-outline-success")" style="border-radius:8px">
                    <i class="fa-solid fa-toggle-on me-1"></i>@(Model.IsActive ? "Tắt" : "Bật")
                </button>
            </form>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa khách hàng này?')">@Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:8px"><i class="fa-solid fa-trash me-1"></i>Xóa</button>
            </form>
        </div>
    </div>
    <div class="card-body-custom">
        <div class="row g-3">
            <div class="col-md-3">
                <label style="font-size:.68rem;color:var(--text-muted);font-weight:600;text-transform:uppercase">Mã KH</label>
                <div style="font-weight:700;font-family:monospace;color:var(--apple-blue)">@Model.Code</div>
            </div>
            <div class="col-md-5">
                <label style="font-size:.68rem;color:var(--text-muted);font-weight:600;text-transform:uppercase">Tên khách hàng</label>
                <div style="font-weight:600;font-size:1.05rem">@Model.Name</div>
            </div>
            <div class="col-md-4">
                <label style="font-size:.68rem;color:var(--text-muted);font-weight:600;text-transform:uppercase">Mã số thuế</label>
                <div>@(Model.TaxCode ?? "—")</div>
            </div>
            <div class="col-md-4">
                <label style="font-size:.68rem;color:var(--text-muted);font-weight:600;text-transform:uppercase">Ngành nghề</label>
                <div>@(Model.Industry ?? "—")</div>
            </div>
            <div class="col-md-4">
                <label style="font-size:.68rem;color:var(--text-muted);font-weight:600;text-transform:uppercase">Ngày tạo</label>
                <div>@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Contacts -->
    <div class="col-lg-6">
        <div class="content-card h-100 animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-user-group"></i> Người liên hệ <span class="badge" style="background:var(--apple-blue);color:#fff;font-size:.68rem">@Model.Contacts.Count</span></h5>
                <a asp-action="AddContact" asp-route-id="@Model.Id" asp-route-name="@Model.Name" class="btn btn-sm btn-primary" style="border-radius:8px"><i class="fa-solid fa-plus me-1"></i>Thêm</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Contacts.Any())
                {
                    <div class="text-center py-4"><i class="fa-solid fa-user-group fa-2x mb-2 opacity-25"></i><br/><span class="text-muted small">Chưa có liên hệ</span></div>
                }
                @foreach (var c in Model.Contacts)
                {
                    <div class="d-flex gap-3 align-items-start px-4 py-3" style="border-bottom:1px solid var(--divider)">
                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#007AFF,#5856d6);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <span style="color:#fff;font-weight:700;font-size:.75rem">@c.FullName[..1].ToUpper()</span>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold" style="font-size:.88rem">@c.FullName</span>
                                @if (c.IsPrimary) { <span class="badge bg-primary rounded-pill" style="font-size:.6rem;padding:2px 8px">Chính</span> }
                            </div>
                            @if (c.JobTitle != null) { <div style="font-size:.78rem;color:var(--text-secondary)">@c.JobTitle</div> }
                            <div class="d-flex gap-3 mt-1" style="font-size:.78rem">
                                @if (c.Email != null) { <span><i class="fa-solid fa-envelope me-1 text-muted"></i>@c.Email</span> }
                                @if (c.PhoneNumber != null) { <span><i class="fa-solid fa-phone me-1 text-muted"></i>@c.PhoneNumber</span> }
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            @if (!c.IsPrimary)
                            {
                                <form asp-action="TogglePrimary" method="post" class="d-inline">@Html.AntiForgeryToken()
                                    <input type="hidden" name="contactId" value="@c.Id" />
                                    <input type="hidden" name="customerId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" style="border-radius:6px;font-size:.65rem;padding:2px 6px" title="Đặt làm liên hệ chính"><i class="fa-solid fa-star"></i></button>
                                </form>
                            }
                            <form asp-action="DeleteContact" method="post" class="d-inline" onsubmit="return confirm('Xóa liên hệ này?')">@Html.AntiForgeryToken()
                                <input type="hidden" name="contactId" value="@c.Id" />
                                <input type="hidden" name="customerId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:6px;font-size:.65rem;padding:2px 6px" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sites -->
    <div class="col-lg-6">
        <div class="content-card h-100 animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-location-dot"></i> Chi nhánh / Địa điểm <span class="badge" style="background:var(--apple-blue);color:#fff;font-size:.68rem">@Model.Sites.Count</span></h5>
                <a asp-action="AddSite" asp-route-id="@Model.Id" asp-route-name="@Model.Name" class="btn btn-sm btn-primary" style="border-radius:8px"><i class="fa-solid fa-plus me-1"></i>Thêm</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Sites.Any())
                {
                    <div class="text-center py-4"><i class="fa-solid fa-location-dot fa-2x mb-2 opacity-25"></i><br/><span class="text-muted small">Chưa có chi nhánh</span></div>
                }
                @foreach (var s in Model.Sites)
                {
                    <div class="d-flex gap-3 align-items-start px-4 py-3" style="border-bottom:1px solid var(--divider)">
                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#34c759,#30d158);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fa-solid fa-building" style="color:#fff;font-size:.7rem"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold" style="font-size:.88rem">@s.Name</div>
                            <div class="d-flex gap-3 mt-1" style="font-size:.78rem;color:var(--text-secondary)">
                                @if (s.Address != null) { <span><i class="fa-solid fa-map-pin me-1"></i>@s.Address</span> }
                                @if (s.City != null) { <span><i class="fa-solid fa-city me-1"></i>@s.City</span> }
                            </div>
                        </div>
                        <form asp-action="DeleteSite" method="post" class="d-inline" onsubmit="return confirm('Xóa chi nhánh này?')">@Html.AntiForgeryToken()
                            <input type="hidden" name="siteId" value="@s.Id" />
                            <input type="hidden" name="customerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:6px;font-size:.65rem;padding:2px 6px" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
