@model OmniBizAI.ViewModels.CustomerEditViewModel
@{ ViewData["Title"] = "Chỉnh sửa KH"; ViewData["Breadcrumb"] = "<a href='/Customers' style='color:var(--apple-blue);text-decoration:none'>Khách hàng</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>"; }
<div class="content-card" style="max-width:560px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-pen"></i> Chỉnh sửa: @Model.Code</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Edit">@Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-4"><label class="form-label">Mã KH <span class="text-danger">*</span></label><input asp-for="Code" class="form-control" /><span asp-validation-for="Code" class="text-danger" style="font-size:.78rem"></span></div>
                <div class="col-md-8"><label class="form-label">Tên KH <span class="text-danger">*</span></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger" style="font-size:.78rem"></span></div>
                <div class="col-md-6"><label class="form-label">Mã số thuế</label><input asp-for="TaxCode" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label">Ngành nghề</label><input asp-for="Industry" class="form-control" /></div>
            </div>
            <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Lưu</button><a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">Hủy</a></div>
        </form>
    </div>
</div>
