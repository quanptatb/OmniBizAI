@model OmniBizAI.ViewModels.CustomerEditViewModel
@{
    ViewData["Title"] = "Sửa khách hàng";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Customers' style='color:var(--apple-blue);text-decoration:none'>Khách hàng</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Customers/Details/" + Model.Id + "' style='color:var(--apple-blue);text-decoration:none'>" + Model.Code + "</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Sửa</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-pen-to-square"></i> Sửa khách hàng</h5>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-light border" style="border-radius:8px"><i class="fa-solid fa-eye me-1"></i>Chi tiết</a>
            </div>
            <div class="card-body-custom">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger mb-3" style="border-radius:10px;border:none;background:rgba(255,59,48,.08);color:#c33">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["ErrorMessage"]
                    </div>
                }

                <form method="post" asp-action="Edit">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label fw-bold">Mã khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" style="border-radius:10px" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-bold">Tên khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" style="border-radius:10px" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TaxCode" class="form-label fw-bold">Mã số thuế</label>
                            <input asp-for="TaxCode" class="form-control" style="border-radius:10px" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Industry" class="form-label fw-bold">Ngành nghề</label>
                            <input asp-for="Industry" class="form-control" style="border-radius:10px" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end pt-4 mt-3" style="border-top:1px solid var(--divider)">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-check me-2"></i>Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
