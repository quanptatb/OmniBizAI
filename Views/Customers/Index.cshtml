@model OmniBizAI.ViewModels.CustomerListViewModel
@{ ViewData["Title"] = "Khách hàng"; ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Khách hàng</span>"; }

@{ var activeCount = Model.Items.Count(c => c.IsActive); var totalContacts = Model.Items.Sum(c => c.ContactCount); }
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-building"></i></div><div class="stat-value">@Model.TotalCount</div><div class="stat-label">Tổng khách hàng</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-check-circle"></i></div><div class="stat-value">@activeCount</div><div class="stat-label">Hoạt động</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon red"><i class="fa-solid fa-circle-xmark"></i></div><div class="stat-value">@(Model.TotalCount - activeCount)</div><div class="stat-label">Ngừng</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon purple"><i class="fa-solid fa-address-book"></i></div><div class="stat-value">@totalContacts</div><div class="stat-label">Liên hệ</div></div></div>
</div>

<div class="content-card mb-4"><div class="card-body-custom">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-5"><input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Tìm theo tên hoặc mã khách hàng..." /></div>
        <div class="col-md-2"><input type="text" name="industry" value="@Model.IndustryFilter" class="form-control" placeholder="Ngành nghề..." /></div>
        <div class="col-md-2"><button type="submit" class="btn btn-outline-primary w-100"><i class="fa-solid fa-search me-1"></i>Tìm</button></div>
        <div class="col-md-3 text-end"><a asp-action="Create" class="btn btn-primary w-100"><i class="fa-solid fa-plus me-2"></i>Thêm KH</a></div>
    </form>
</div></div>

<div class="content-card"><div class="card-body-custom p-0">
    <table class="data-table">
        <thead><tr><th class="ps-3">Mã</th><th>Tên khách hàng</th><th>MST</th><th>Ngành nghề</th><th>Liên hệ</th><th>Trạng thái</th><th class="pe-3">Thao tác</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="ps-3"><span style="font-weight:600;color:var(--apple-blue)">@item.Code</span></td>
                    <td><a asp-action="Details" asp-route-id="@item.Id" style="font-weight:500;color:var(--text-primary);text-decoration:none">@item.Name</a></td>
                    <td style="color:var(--text-secondary)">@(item.TaxCode ?? "—")</td>
                    <td style="color:var(--text-secondary)">@(item.Industry ?? "—")</td>
                    <td><span class="badge bg-light text-dark">@item.ContactCount liên hệ</span></td>
                    <td><span class="status-badge-soft @(item.IsActive ? "badge-on-track" : "badge-late")"><span class="status-dot"></span>@(item.IsActive ? "Hoạt động" : "Ngừng")</span></td>
                    <td class="pe-3">
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-pen"></i></a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any()) { <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted)">Chưa có khách hàng nào</td></tr> }
        </tbody>
    </table>
</div></div>
