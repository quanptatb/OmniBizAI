@model OmniBizAI.ViewModels.CustomerCreateViewModel
@{
    ViewData["Title"] = "Thêm khách hàng";
    ViewData["Breadcrumb"] = "<span>CRM</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Customers' style='color:var(--apple-blue);text-decoration:none'>Khách hàng</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Thêm mới</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-user-plus"></i> Thêm khách hàng mới</h5>
                <a asp-action="Index" class="btn btn-sm btn-light border" style="border-radius:8px"><i class="fa-solid fa-list me-1"></i>Danh sách</a>
            </div>
            <div class="card-body-custom">
                <form method="post" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Code" class="form-label fw-bold">Mã khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" placeholder="VD: KH001" style="border-radius:10px" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-bold">Tên khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Tên đầy đủ của khách hàng..." style="border-radius:10px" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TaxCode" class="form-label fw-bold">Mã số thuế</label>
                            <input asp-for="TaxCode" class="form-control" placeholder="Nhập MST..." style="border-radius:10px" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Industry" class="form-label fw-bold">Ngành nghề</label>
                            <input asp-for="Industry" class="form-control" placeholder="VD: Công nghệ, Sản xuất..." style="border-radius:10px" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end pt-4 mt-3" style="border-top:1px solid var(--divider)">
                        <a asp-action="Index" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600"><i class="fa-solid fa-check me-2"></i>Tạo khách hàng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
