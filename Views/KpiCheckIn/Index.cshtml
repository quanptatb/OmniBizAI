@model OmniBizAI.ViewModels.KpiCheckInListViewModel
@{
    ViewData["Title"] = "KPI Check-In";
    ViewData["Breadcrumb"] = "<span>KPI</span> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Check-In</span>";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(52,199,89,.12);color:#1d7a37">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(255,59,48,.08);color:#c33">
        <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fa-solid fa-hourglass-half"></i></div>
            <div class="stat-value">@Model.PendingCount</div>
            <div class="stat-label">Chờ duyệt</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
            <div class="stat-value">@Model.ApprovedCount</div>
            <div class="stat-label">Đã duyệt</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(255,59,48,.08);color:#ff3b30"><i class="fa-solid fa-circle-xmark"></i></div>
            <div class="stat-value">@Model.RejectedCount</div>
            <div class="stat-label">Từ chối</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(255,149,0,.08);color:#ff9500"><i class="fa-solid fa-clock"></i></div>
            <div class="stat-value">@Model.LateCount</div>
            <div class="stat-label">Trễ hạn</div>
        </div>
    </div>
</div>

<!-- Submit Form -->
<div class="content-card mb-4">
    <div class="card-header-custom"><h5><i class="fa-solid fa-plus-circle"></i> Tạo Check-In mới</h5></div>
    <div class="card-body-custom">
        <div class="small text-muted mb-3">Chọn KPI cần cập nhật, nhập giá trị mới nhất và thêm ghi chú ngắn (nếu có).</div>
        <form asp-action="Submit" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-5">
                <label class="form-label fw-bold">KPI Target</label>
                <select name="KpiTargetId" class="form-select" required>
                    <option value="">-- Chọn KPI --</option>
                    @foreach (var t in Model.AvailableTargets) { <option value="@t.Value">@t.Text</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">Giá trị tiến độ</label>
                <input name="ProgressValue" type="number" step="0.01" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Ghi chú</label>
                <input name="Comment" class="form-control" maxlength="1000" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary" style="border-radius:8px"><i class="fa-solid fa-paper-plane me-2"></i>Gửi check-in</button>
            </div>
        </form>
    </div>
</div>

<!-- Toolbar -->
<div class="content-card mb-4">
    <div class="card-body-custom py-3">
        <form method="get" class="d-flex gap-3 align-items-end flex-wrap">
            <div class="flex-grow-1" style="min-width:200px">
                <label class="form-label text-muted small fw-bold">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius:8px 0 0 8px"><i class="fa-solid fa-search" style="font-size:.75rem;color:var(--text-muted)"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control bg-light border-start-0" placeholder="KPI hoặc nhân viên..." style="border-radius:0 8px 8px 0" />
                </div>
            </div>
            <div style="min-width:160px">
                <label class="form-label text-muted small fw-bold">Trạng thái</label>
                <select name="reviewStatus" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="Pending" selected="@(Model.ReviewStatusFilter == "Pending")">⏳ Chờ duyệt</option>
                    <option value="Approved" selected="@(Model.ReviewStatusFilter == "Approved")">✅ Đã duyệt</option>
                    <option value="Rejected" selected="@(Model.ReviewStatusFilter == "Rejected")">❌ Từ chối</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" style="border-radius:8px"><i class="fa-solid fa-filter me-1"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-light border" style="border-radius:8px" title="Xóa bộ lọc"><i class="fa-solid fa-rotate-left"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="content-card animate-fade-in">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-clock-rotate-left"></i> Lịch sử Check-In <span class="badge" style="background:var(--apple-blue);color:#fff">@Model.TotalCount</span></h5>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="ps-4">KPI</th>
                    <th>Nhân viên</th>
                    <th class="text-center">Ngày</th>
                    <th class="text-end">Giá trị</th>
                    <th class="text-center">Review</th>
                    <th class="text-center">Điểm</th>
                    <th class="text-center pe-4" style="width:140px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted"><i class="fa-solid fa-clipboard-list fa-2x mb-2 opacity-50"></i><br/>Chưa có check-in nào.</td></tr>
                }
                @foreach (var item in Model.Items)
                {
                    var (badgeCls, statusTxt) = item.ReviewStatus switch
                    {
                        "Pending" => ("bg-warning-subtle text-warning border", "⏳ Chờ duyệt"),
                        "Approved" => ("bg-success-subtle text-success border", "✅ Đã duyệt"),
                        "Rejected" => ("bg-danger-subtle text-danger border", "❌ Từ chối"),
                        _ => ("", item.ReviewStatus)
                    };
                    <tr>
                        <td class="ps-4">
                            <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold" style="color:var(--text-primary);text-decoration:none">@item.KpiName</a>
                            <div><code style="background:rgba(0,122,255,.06);color:var(--apple-blue);padding:1px 6px;border-radius:4px;font-size:.7rem">@item.KpiCode</code></div>
                        </td>
                        <td style="font-size:.85rem">@item.UserName</td>
                        <td class="text-center" style="font-size:.85rem">
                            @item.CheckInDate.ToString("dd/MM/yyyy")
                            @if (item.IsLate) { <span class="badge bg-danger rounded-pill" style="font-size:.6rem;margin-left:4px">Trễ</span> }
                        </td>
                        <td class="text-end fw-bold" style="font-size:1rem">@item.ProgressValue.ToString("N2")</td>
                        <td class="text-center"><span class="badge @badgeCls rounded-pill" style="font-size:.68rem">@statusTxt</span></td>
                        <td class="text-center fw-bold" style="color:var(--apple-blue)">@(item.ReviewScore?.ToString("N1") ?? "—")</td>
                        <td class="text-center pe-4">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" style="border-radius:6px" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                                @if (item.ReviewStatus == "Pending")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" style="border-radius:6px" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--divider)">
            <span style="font-size:.82rem;color:var(--text-muted)">Tổng: <strong>@Model.TotalCount</strong> • Trang @Model.Page/@Model.TotalPages</span>
            <div class="d-flex gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?page=@i&search=@Model.SearchTerm&reviewStatus=@Model.ReviewStatusFilter"
                       class="btn btn-sm @(i == Model.Page ? "btn-primary" : "btn-light border")" style="border-radius:6px;min-width:32px">@i</a>
                }
            </div>
        </div>
    }
</div>
