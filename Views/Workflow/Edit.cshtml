@model OmniBizAI.ViewModels.WorkItemEditViewModel
@using OmniBizAI.Models.Entities.Enums
@{
    ViewData["Title"] = "Chỉnh sửa công việc";
    ViewData["Breadcrumb"] = "<a href='/Workflow/Kanban' style='color:var(--apple-blue);text-decoration:none'>Kanban</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <a href='/Workflow/Details/" + Model.Id + "' style='color:var(--apple-blue);text-decoration:none'>Chi tiết</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa công việc</h5>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-light border" style="border-radius:8px">
                    <i class="fa-solid fa-eye me-1"></i>Chi tiết
                </a>
            </div>
            <div class="card-body-custom">
                @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                {
                    <div style="background:rgba(255,59,48,.05);border:1px solid rgba(255,59,48,.12);border-radius:var(--r-sm);padding:12px 16px;margin-bottom:20px">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div style="font-size:.82rem;color:var(--danger)"><i class="fa-solid fa-circle-exclamation me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" maxlength="250" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="KanbanColumnId" class="form-label fw-bold">Cột Kanban</label>
                            <select asp-for="KanbanColumnId" class="form-select">
                                @foreach (var c in Model.ColumnOptions)
                                {
                                    <option value="@c.Value" selected="@(c.Value == Model.KanbanColumnId?.ToString())">@c.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label fw-bold">Ưu tiên</label>
                            <select asp-for="Priority" class="form-select">
                                @foreach (var p in Enum.GetValues<PriorityLevel>())
                                {
                                    <option value="@p" selected="@(p == Model.Priority)">@p</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="OrganizationUnitId" class="form-label fw-bold">Phòng ban</label>
                            <select asp-for="OrganizationUnitId" class="form-select">
                                <option value="">— Theo YCVH —</option>
                                @foreach (var dept in Model.Departments)
                                {
                                    <option value="@dept.Value" selected="@(dept.Value == Model.OrganizationUnitId?.ToString())">@dept.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DueDate" class="form-label fw-bold">Hạn xử lý</label>
                            <input asp-for="DueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedToUserId" class="form-label fw-bold">Người phụ trách</label>
                            <select asp-for="AssignedToUserId" class="form-select">
                                <option value="">— Chưa giao —</option>
                                @foreach (var user in Model.Assignees)
                                {
                                    <option value="@user.Value" selected="@(user.Value == Model.AssignedToUserId?.ToString())">@user.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4" maxlength="2000" style="resize:vertical"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between pt-3" style="border-top:1px solid var(--divider)">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa công việc này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius:8px">
                                <i class="fa-solid fa-trash me-1"></i>Xóa
                            </button>
                        </form>
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                            <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600">
                                <i class="fa-solid fa-check me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
