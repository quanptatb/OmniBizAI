@model OmniBizAI.ViewModels.ApprovalTaskListViewModel
@{
    ViewData["Title"] = "Phê duyệt";
    ViewData["Breadcrumb"] = "<span>Vận hành</span> <i class=\"fa-solid fa-chevron-right mx-2 text-muted fs-7\"></i> <span class=\"text-primary fw-bold\">Phê duyệt</span>";
}

<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item">
        <a class="nav-link active fw-bold" data-bs-toggle="tab" href="#pending">
            <i class="fa-solid fa-clock me-2 text-warning"></i>Chờ duyệt
            @if (Model.PendingTasks.Any())
            {
                <span class="badge bg-warning text-dark ms-2">@Model.PendingTasks.Count</span>
            }
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link fw-bold" data-bs-toggle="tab" href="#completed">
            <i class="fa-solid fa-check-double me-2 text-success"></i>Đã xử lý
        </a>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="pending">
        @if (!Model.PendingTasks.Any())
        {
            <div class="card glass-card text-center py-5">
                <div class="card-body">
                    <i class="fa-solid fa-circle-check fa-4x text-success mb-3 opacity-50"></i>
                    <h5 class="text-muted">Không có yêu cầu nào cần duyệt</h5>
                    <p class="text-muted small">Tất cả các yêu cầu đã được xử lý.</p>
                </div>
            </div>
        }

        @foreach (var task in Model.PendingTasks)
        {
            <div class="approval-card pending">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="fw-bold mb-1">
                            <a asp-controller="Operations" asp-action="Details" asp-route-id="@task.TargetId" class="text-decoration-none text-primary">@task.RequestNo</a>
                            — @task.RequestTitle
                        </h6>
                        <div class="d-flex gap-3 text-muted small">
                            <span><i class="fa-solid fa-code-branch me-1"></i>@task.StepName</span>
                            <span><i class="fa-solid fa-user-shield me-1"></i>@task.AssignedRole</span>
                            <span><i class="fa-regular fa-clock me-1"></i>@task.RequestCreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    </div>
                    @{
                        var priClass = task.RequestPriority switch { "Critical" => "bg-danger", "High" => "bg-warning text-dark", _ => "bg-light text-dark border" };
                    }
                    <span class="badge @priClass">@task.RequestPriority</span>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-success btn-sm px-3" onclick="openApprovalModal('@task.Id', 'Approve')">
                        <i class="fa-solid fa-check me-1"></i> Duyệt
                    </button>
                    <button class="btn btn-outline-danger btn-sm px-3" onclick="openApprovalModal('@task.Id', 'Reject')">
                        <i class="fa-solid fa-xmark me-1"></i> Từ chối
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="tab-pane fade" id="completed">
        @if (!Model.CompletedTasks.Any())
        {
            <div class="card glass-card text-center py-5">
                <div class="card-body">
                    <i class="fa-solid fa-inbox fa-4x text-muted mb-3 opacity-50"></i>
                    <h5 class="text-muted">Chưa có lịch sử xử lý</h5>
                </div>
            </div>
        }

        @foreach (var task in Model.CompletedTasks)
        {
            <div class="approval-card @(task.Status == "Approved" ? "approved" : "rejected")">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="fw-bold mb-1">@task.RequestNo — @task.RequestTitle</h6>
                        <div class="d-flex gap-3 text-muted small">
                            <span><i class="fa-solid fa-code-branch me-1"></i>@task.StepName</span>
                            <span>
                                <span class="badge @(task.Status == "Approved" ? "bg-success" : "bg-danger")">@task.Status</span>
                            </span>
                            @if (task.DecidedAt.HasValue)
                            {
                                <span><i class="fa-regular fa-clock me-1"></i>@task.DecidedAt.Value.ToString("HH:mm dd/MM/yyyy")</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(task.DecisionNote))
                        {
                            <div class="mt-2 p-2 bg-light rounded border text-sm"><i class="fa-solid fa-comment me-1"></i> @task.DecisionNote</div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Approval Modal -->
<div class="modal fade" id="approvalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="approvalForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="taskId" id="modalTaskId" />
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="modalTitle">Phê duyệt</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modalAction" />
                    <div class="mb-3" id="modalNoteGroup">
                        <label class="form-label fw-bold">Ghi chú / Lý do</label>
                        <textarea name="note" id="modalNote" class="form-control" rows="3" placeholder="Nhập lý do từ chối (tối thiểu 10 ký tự nếu từ chối)..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success" id="modalSubmitBtn">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('approvalForm')?.addEventListener('submit', function(e) {
            const action = document.getElementById('modalAction').value;
            const taskId = document.getElementById('modalTaskId').value;
            const note = document.getElementById('modalNote').value;
            this.action = action === 'Approve' ? '/Approvals/Approve' : '/Approvals/Reject';
            if (action === 'Reject') {
                document.getElementById('modalNote').name = 'reason';
            }
        });
    </script>
}
