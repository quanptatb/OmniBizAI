@{
    ViewData["Title"] = "Cài đặt";
}

<section class="page-header">
    <div><span class="eyebrow"><i class="bi bi-sliders"></i> System settings</span><h1>Cài đặt hệ thống</h1><p>Cấu hình công ty, ngưỡng cảnh báo, AI provider, notification preferences, retention và tham số workflow.</p></div>
    <button class="btn-app" data-demo-toast><i class="bi bi-save"></i> Lưu thay đổi</button>
</section>

<section class="two-col-grid">
    <article class="panel">
        <div class="panel-header"><h2 class="panel-title"><i class="bi bi-building"></i> Company settings</h2></div>
        <div class="panel-body form-grid">
            <label>Tên công ty<input class="form-control" value="OmniBizAI Demo Company" /></label>
            <label>Tiền tệ<select class="form-select"><option>VND</option><option>USD</option></select></label>
            <label>Budget warning threshold<input class="form-control" value="80%" /></label>
            <label>High risk threshold<input class="form-control" value="70" /></label>
            <label>Idle session timeout<input class="form-control" value="60 phút" /></label>
            <label>Audit retention<input class="form-control" value="365 ngày" /></label>
        </div>
    </article>
    <aside class="panel">
        <div class="panel-header"><h2 class="panel-title"><i class="bi bi-cpu"></i> AI configuration</h2></div>
        <div class="panel-body stack-list">
            <label class="fw-bold">Provider<select class="form-select mt-2"><option>Groq</option><option>OpenAI</option><option>Claude</option></select></label>
            <label class="fw-bold">Model<input class="form-control mt-2" value="llama-3.3-70b-versatile" /></label>
            <div class="list-item"><div><strong>Spend Guardrail</strong><small>Chạy khi submit PaymentRequest</small></div><span class="status-badge success">On</span></div>
            <div class="list-item"><div><strong>KPI Insight</strong><small>Quét mỗi ngày lúc 08:00</small></div><span class="status-badge success">On</span></div>
        </div>
    </aside>
</section>
