// Safe helpers to query form values without throwing TypeErrors
function getFormVal(form, name, fallback = '') {
    if (!form) return fallback;
    const el = form.querySelector(`[name="${name}"]`);
    return el ? el.value : fallback;
}

function getFormChecked(form, name, fallback = false) {
    if (!form) return fallback;
    const el = form.querySelector(`[name="${name}"][type="checkbox"]`);
    return el ? el.checked : fallback;
}

// Convert Hex to RGBA safely to avoid slicing errors or crash on shorthand / empty values
function hexToRgba(hex, alpha) {
    if (!hex || typeof hex !== 'string') return `rgba(0, 102, 204, ${alpha})`;
    let cleanHex = hex.replace('#', '').trim();
    if (cleanHex.length === 3) {
        cleanHex = cleanHex[0] + cleanHex[0] + cleanHex[1] + cleanHex[1] + cleanHex[2] + cleanHex[2];
    }
    if (cleanHex.length !== 6) {
        return `rgba(0, 102, 204, ${alpha})`;
    }
    const r = parseInt(cleanHex.slice(0, 2), 16);
    const g = parseInt(cleanHex.slice(2, 4), 16);
    const b = parseInt(cleanHex.slice(4, 6), 16);
    if (isNaN(r) || isNaN(g) || isNaN(b)) {
        return `rgba(0, 102, 204, ${alpha})`;
    }
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

// Sync color picker ↔ text representation
function initColorSync() {
    document.querySelectorAll('#themeSettingsForm input[type=color]').forEach(cp => {
        const next = cp.nextElementSibling;
        if (next && next.type === 'text') {
            // Initial sync
            next.value = cp.value;
            // Event sync
            cp.addEventListener('input', () => {
                next.value = cp.value;
            });
        }
    });
}

// Update the live preview changes on layout and styling dynamically
function updateLivePreview() {
    try {
        const form = document.getElementById('themeSettingsForm');
        if (!form) {
            console.warn("Theme customization form '#themeSettingsForm' not found.");
            return;
        }
        
        // Read all fields using safe helpers
        const accent = getFormVal(form, 'AccentColor', '#0066cc');
        const hover = getFormVal(form, 'AccentHover', '#0071e3');
        const dark = getFormVal(form, 'AccentDark', '#2997ff');
        
        const canvas = getFormVal(form, 'CanvasColor', '#ffffff');
        const parchment = getFormVal(form, 'ParchmentColor', '#f5f5f7');
        const ink = getFormVal(form, 'InkColor', '#1d1d1f');
        
        const sidebarBg = getFormVal(form, 'SidebarBg', '#1d1d1f');
        const sidebarText = getFormVal(form, 'SidebarText', '#ffffff');
        
        const success = getFormVal(form, 'SuccessColor', '#34c759');
        const warning = getFormVal(form, 'WarningColor', '#ff9f0a');
        const danger = getFormVal(form, 'DangerColor', '#ff3b30');
        const info = getFormVal(form, 'InfoColor', '#5ac8fa');
        
        const darkMode = getFormChecked(form, 'DarkMode', false);
        
        const fontFamily = getFormVal(form, 'FontFamily', 'Inter');
        const fontSize = getFormVal(form, 'FontSize', '17');
        const borderRadius = getFormVal(form, 'BorderRadius', '12');
        const sidebarWidth = getFormVal(form, 'SidebarWidth', '260');
        
        const logoIcon = getFormVal(form, 'LogoIcon', 'fa-solid fa-brain');
        const brandName = getFormVal(form, 'BrandName', 'OmniBizAI');
        const brandTagline = getFormVal(form, 'BrandTagline', 'Smart Operations');

        // A. Apply live changes directly to system page's :root to make it interactive!
        const root = document.documentElement;
        root.style.setProperty('--apple-blue', accent);
        root.style.setProperty('--apple-blue-focus', hover);
        root.style.setProperty('--apple-blue-dark', dark);
        
        root.style.setProperty('--canvas', darkMode ? '#1c1c1e' : canvas);
        root.style.setProperty('--parchment', darkMode ? '#000000' : parchment);
        root.style.setProperty('--ink', darkMode ? '#f5f5f7' : ink);
        root.style.setProperty('--text-primary', darkMode ? '#f5f5f7' : ink);
        
        root.style.setProperty('--success', success);
        root.style.setProperty('--warning', warning);
        root.style.setProperty('--danger', danger);
        root.style.setProperty('--info', info);
        
        root.style.setProperty('--r-md', borderRadius + 'px');
        root.style.setProperty('--sidebar-w', sidebarWidth + 'px');
        
        // Set immediate active system sidebar backgrounds & colors
        const sidebarEl = document.getElementById('sidebar');
        if (sidebarEl) {
            sidebarEl.style.background = sidebarBg;
            sidebarEl.style.color = sidebarText;
            sidebarEl.querySelectorAll('.nav-item, .nav-section-label, .sidebar-brand, .brand-name, .brand-tagline').forEach(el => {
                el.style.color = sidebarText;
            });
            const activeItem = sidebarEl.querySelector('.nav-item.active');
            if (activeItem) {
                activeItem.style.background = 'rgba(255,255,255,0.15)';
            }
        }
        
        document.body.style.fontFamily = `'${fontFamily}', system-ui, -apple-system, sans-serif`;
        root.style.fontSize = fontSize + 'px';

        // Toggle simulated theme body classes
        if (darkMode) {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.body.style.background = '#000';
            document.body.style.color = '#f5f5f7';
            
            document.querySelectorAll('.content-card, .stat-card, .card, .glass-card').forEach(c => {
                c.style.background = '#1c1c1e';
                c.style.borderColor = '#38383a';
            });
            document.querySelectorAll('.card-header-custom').forEach(ch => {
                ch.style.background = '#2c2c2e';
                ch.style.borderColor = '#38383a';
            });
            document.querySelectorAll('.form-control, .form-select, .form-input').forEach(f => {
                if (!f.classList.contains('form-control-color')) {
                    f.style.background = '#2c2c2e';
                    f.style.color = '#f5f5f7';
                    f.style.borderColor = '#48484a';
                }
            });
        } else {
            document.documentElement.removeAttribute('data-theme');
            document.body.style.background = parchment;
            document.body.style.color = ink;
            
            document.querySelectorAll('.content-card, .stat-card, .card, .glass-card').forEach(c => {
                c.style.background = canvas;
                c.style.borderColor = 'rgba(0,0,0,0.08)';
            });
            document.querySelectorAll('.card-header-custom').forEach(ch => {
                ch.style.background = 'rgba(0,0,0,0.02)';
                ch.style.borderColor = 'rgba(0,0,0,0.08)';
            });
            document.querySelectorAll('.form-control, .form-select, .form-input').forEach(f => {
                if (!f.classList.contains('form-control-color')) {
                    f.style.background = '#ffffff';
                    f.style.color = '#1d1d1f';
                    f.style.borderColor = 'rgba(0,0,0,0.15)';
                }
            });
        }

        // B. Apply preview styling specific variables inside Preview Panel
        const previewPanel = document.getElementById('previewPanel');
        if (previewPanel) {
            previewPanel.style.setProperty('--accent', accent);
            previewPanel.style.setProperty('--accent-hover', hover);
            previewPanel.style.setProperty('--accent-dark', dark);
            previewPanel.style.setProperty('--canvas', darkMode ? '#1c1c1e' : canvas);
            previewPanel.style.setProperty('--parchment', darkMode ? '#000000' : parchment);
            previewPanel.style.setProperty('--ink', darkMode ? '#f5f5f7' : ink);
            previewPanel.style.setProperty('--sidebar-bg', sidebarBg);
            previewPanel.style.setProperty('--sidebar-text', sidebarText);
            previewPanel.style.setProperty('--radius', borderRadius + 'px');
            
            // Brand logo icon class
            const pIcon = previewPanel.querySelector('.brand-icon i');
            if (pIcon) pIcon.className = logoIcon;
            
            // Brand text inputs
            const pName = previewPanel.querySelector('.brand-name-preview');
            if (pName) pName.textContent = brandName;
            
            const pTagline = previewPanel.querySelector('.brand-tagline-preview');
            if (pTagline) pTagline.textContent = brandTagline;
            
            // Primary buttons preview backgrounds
            const pBtn = previewPanel.querySelector('.preview-btn-primary');
            if (pBtn) {
                pBtn.style.background = accent;
                pBtn.style.borderColor = accent;
            }
            
            // Stats icons color preview
            const pStatIcon = previewPanel.querySelector('.stat-icon.blue');
            if (pStatIcon) {
                pStatIcon.style.color = accent;
                pStatIcon.style.background = hexToRgba(accent, 0.12);
            }
        }
        
        // Update active badge in logo badge indicator
        const logoBadge = document.querySelector('.preview-logo-badge');
        if (logoBadge) {
            logoBadge.style.background = accent;
            const logoIconInBadge = logoBadge.querySelector('i');
            if (logoIconInBadge) logoIconInBadge.className = logoIcon;
        }
    } catch (err) {
        console.error("Error in updateLivePreview:", err);
    }
}

// Complete set preset theme values and triggers preview
function setPreset(themeKey) {
    try {
        console.log("Applying preset theme:", themeKey);
        const theme = presets[themeKey];
        if (!theme) {
            console.error("Preset theme key not found:", themeKey);
            return;
        }
        
        const form = document.getElementById('themeSettingsForm');
        if (!form) {
            console.error("Theme customization form '#themeSettingsForm' not found when setting preset.");
            return;
        }
        
        // Setter for colorpickers
        const setVal = (n, v) => { 
            const el = form.querySelector(`[name="${n}"][type="color"]`); 
            if(el) {
                el.value = v;
                const t = el.nextElementSibling;
                if(t && t.type === 'text') t.value = v;
            } 
        };
        
        // Setter for range inputs
        const setRange = (n, v) => {
            const el = form.querySelector(`input[name="${n}"][type="range"]`);
            if(el) {
                el.value = v;
                const t = el.nextElementSibling;
                if(t) t.textContent = v + 'px';
            }
        };
        
        // Setter for select inputs
        const setSel = (n, v) => {
            const el = form.querySelector(`select[name="${n}"]`);
            if(el) el.value = v;
        };
        
        // Load general values
        setVal('AccentColor', theme.AccentColor);
        setVal('AccentHover', theme.AccentHover);
        setVal('AccentDark', theme.AccentDark);
        setVal('CanvasColor', theme.CanvasColor);
        setVal('ParchmentColor', theme.ParchmentColor);
        setVal('InkColor', theme.InkColor);
        setVal('SidebarBg', theme.SidebarBg);
        setVal('SidebarText', theme.SidebarText);
        
        if (theme.SuccessColor) setVal('SuccessColor', theme.SuccessColor);
        if (theme.WarningColor) setVal('WarningColor', theme.WarningColor);
        if (theme.DangerColor) setVal('DangerColor', theme.DangerColor);
        if (theme.InfoColor) setVal('InfoColor', theme.InfoColor);
        
        // Dark mode check setting
        const cb = form.querySelector('[name="DarkMode"][type="checkbox"]');
        if(cb) {
            cb.checked = theme.DarkMode;
            const lbl = cb.nextElementSibling;
            if(lbl) lbl.textContent = theme.DarkMode ? "Bật" : "Tắt";
        }
        
        // Typography layout loading
        setSel('FontFamily', theme.FontFamily);
        setRange('FontSize', theme.FontSize);
        setRange('BorderRadius', theme.BorderRadius);
        setRange('SidebarWidth', theme.SidebarWidth);
        
        // Trigger Live update preview!
        updateLivePreview();
    } catch (err) {
        console.error("Error in setPreset:", err);
    }
}

// Bind live triggers to all input fields
function bindLiveTriggers() {
    document.querySelectorAll('#themeSettingsForm input, #themeSettingsForm select').forEach(input => {
        input.addEventListener('input', updateLivePreview);
        input.addEventListener('change', updateLivePreview);
    });
}

// Run once on load to establish bindings correctly
document.addEventListener('DOMContentLoaded', () => {
    initColorSync();
    bindLiveTriggers();
    updateLivePreview();
});
</script>
