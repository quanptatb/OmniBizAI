@model OmniBizAI.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "_AuthLayout";
}

<article class="panel auth-form-card">
    <div class="panel-header"><h2 class="panel-title"><i class="bi bi-shield-lock"></i> Mật khẩu mới</h2></div>
    <form asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="Token" />
        <div class="panel-body form-grid">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="color: var(--danger); font-size: 0.875rem;"></div>
            
            <label style="grid-column: 1 / -1;">
                Mật khẩu mới
                <input asp-for="Password" class="form-control" type="password" placeholder="Mật khẩu mới (ít nhất 6 ký tự)" />
                <span asp-validation-for="Password" class="text-danger" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem;"></span>
            </label>
            
            <label style="grid-column: 1 / -1;">
                Xác nhận mật khẩu
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem;"></span>
            </label>
        </div>
        <div class="panel-body border-top">
            <button type="submit" class="btn-app"><i class="bi bi-check2-circle"></i> Đặt lại mật khẩu</button>
        </div>
    </form>
</article>
