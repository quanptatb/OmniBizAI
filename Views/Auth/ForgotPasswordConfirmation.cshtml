@{
    ViewData["Title"] = "Đã gửi email";
    Layout = "_AuthLayout";
}

<article class="panel auth-form-card" style="text-align: center;">
    <div class="panel-body py-5" style="padding: 3rem 2rem;">
        <i class="bi bi-envelope-check text-success" style="font-size: 4rem; color: var(--success); opacity: 0.9;"></i>
        <h3 class="mt-4 mb-2" style="font-weight: 700;">Kiểm tra email của bạn</h3>
        <p class="text-muted" style="color: var(--gray-500); line-height: 1.6;">Nếu email tồn tại trong hệ thống, chúng tôi đã gửi một liên kết để khôi phục mật khẩu. Vui lòng kiểm tra cả hộp thư rác (Spam).</p>
        <div class="mt-4 pt-2">
            <a class="btn-primary-soft d-inline-flex align-items-center gap-2" asp-action="Login">
                <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
            </a>
        </div>
    </div>
</article>
