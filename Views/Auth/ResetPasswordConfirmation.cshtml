@{
    ViewData["Title"] = "Đặt lại thành công";
    Layout = "_AuthLayout";
}

<article class="panel auth-form-card" style="text-align: center;">
    <div class="panel-body py-5" style="padding: 3rem 2rem;">
        <i class="bi bi-shield-check text-success" style="font-size: 4rem; color: var(--success); opacity: 0.9;"></i>
        <h3 class="mt-4 mb-2" style="font-weight: 700;">Hoàn tất!</h3>
        <p class="text-muted" style="color: var(--gray-500); line-height: 1.6;">Mật khẩu của bạn đã được thay đổi an toàn. Vui lòng đăng nhập lại với mật khẩu mới.</p>
        <div class="mt-4 pt-2">
            <a class="btn-app d-inline-flex align-items-center gap-2" asp-action="Login">
                Đi đến Đăng nhập <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</article>
