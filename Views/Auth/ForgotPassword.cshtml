@model OmniBizAI.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<article class="panel auth-form-card">
    <div class="panel-header"><h2 class="panel-title"><i class="bi bi-key"></i> Lấy lại mật khẩu</h2></div>
    <form asp-action="ForgotPassword" method="post">
        <div class="panel-body form-grid">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="color: var(--danger); font-size: 0.875rem;"></div>
            <label style="grid-column: 1 / -1;">
                Email đã đăng ký
                <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" />
                <span asp-validation-for="Email" class="text-danger" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem;"></span>
            </label>
        </div>
        <div class="panel-body border-top">
            <button type="submit" class="btn-app"><i class="bi bi-send"></i> Gửi liên kết</button>
            <a class="btn-ghost ms-2" asp-controller="Auth" asp-action="Login"><i class="bi bi-arrow-left"></i> Quay lại</a>
        </div>
    </form>
</article>
