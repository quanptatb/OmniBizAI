@model OmniBizAI.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<section class="auth-card-stack">
    <article class="panel auth-form-card">
        <div class="panel-header">
            <h2 class="panel-title"><i class="bi bi-box-arrow-in-right"></i> Đăng nhập hệ thống</h2>
        </div>
        <div class="panel-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" style="padding: 1rem; border-radius: 8px; background: rgba(34, 197, 94, 0.1); color: var(--success); margin-bottom: 1.5rem;">
                    <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                </div>
            }
            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="color: var(--danger); font-size: 0.875rem;"></div>
                <div class="form-grid">
                    <label>
                        Email
                        <input asp-for="Email" class="form-control" placeholder="Email của bạn" />
                        <span asp-validation-for="Email" class="text-danger" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem;"></span>
                    </label>
                    <label>
                        Mật khẩu
                        <input asp-for="Password" class="form-control" type="password" placeholder="Mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem;"></span>
                    </label>
                </div>
                <div class="mt-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <label class="d-flex align-items-center gap-2" style="font-weight: 500; font-size: 0.875rem; color: var(--gray-600); cursor: pointer;">
                        <input asp-for="RememberMe" type="checkbox" style="width: 1.1rem; height: 1.1rem; accent-color: var(--primary);" /> Ghi nhớ 7 ngày
                    </label>
                    <a class="text-primary" asp-action="ForgotPassword" style="font-size: 0.875rem; text-decoration: none; font-weight: 500;">Quên mật khẩu?</a>
                </div>
                <div class="mt-4"><button type="submit" class="btn-app w-100 justify-content-center"><i class="bi bi-shield-check"></i> Đăng nhập</button></div>
            </form>
        </div>
    </article>
    <aside class="panel auth-note-card">
        <div class="panel-header"><h2 class="panel-title"><i class="bi bi-people"></i> Tài khoản demo theo vai trò</h2></div>
        <div class="panel-body stack-list">
            @if (Model.DemoAccounts.Count == 0)
            {
                <div class="list-item">
                    <div><strong>Chưa có tài khoản demo</strong><small>Seed dữ liệu sẽ tạo tài khoản demo khi ứng dụng khởi động.</small></div>
                    <span class="status-badge warning">Empty</span>
                </div>
            }
            else
            {
                @foreach (var account in Model.DemoAccounts)
                {
                    <button class="demo-account-row" type="button" data-demo-email="@account.Email" data-demo-password="@OmniBizAI.Data.DemoIdentitySeeder.DemoPassword">
                        <span>
                            <strong>@account.RoleDisplayName</strong>
                            <small>@account.Email</small>
                        </span>
                        <span class="status-badge info">@account.RoleName</span>
                    </button>
                }
                <div class="demo-password-note">
                    <i class="bi bi-key"></i>
                    <span>Mật khẩu mặc định cho tất cả tài khoản demo: <strong>@OmniBizAI.Data.DemoIdentitySeeder.DemoPassword</strong></span>
                </div>
            }
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('[data-demo-email]').forEach((button) => {
            button.addEventListener('click', () => {
                const emailInput = document.getElementById('Email');
                const passwordInput = document.getElementById('Password');

                if (emailInput && passwordInput) {
                    emailInput.value = button.dataset.demoEmail || '';
                    passwordInput.value = button.dataset.demoPassword || '';
                    passwordInput.focus();
                }
            });
        });
    </script>
}
