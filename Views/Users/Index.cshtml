@model OmniBizAI.ViewModels.UserListViewModel
@{
    ViewData["Title"] = "Quản lý Người dùng";
    ViewData["Breadcrumb"] = "<span>Tổ chức</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>Người dùng</span>";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius:12px;border:none;background:rgba(52,199,89,.12);color:#1d7a37">
        <i class="fa-solid fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card content-card mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label text-muted small fw-bold">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa-solid fa-search"></i></span>
                    <input type="text" name="search" value="@Model.SearchTerm" class="form-control bg-light" placeholder="Tên, email...">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small fw-bold">Trạng thái</label>
                <select name="status" class="form-select bg-light">
                    @foreach (var s in EnumHelper.GetSelectList<UserStatus>(Model.StatusFilter, includeAll: true))
                    { <option value="@s.Value" selected="@s.Selected">@s.Text</option> }
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-filter me-2"></i>Lọc</button>
                <a asp-action="Index" class="btn btn-light border"><i class="fa-solid fa-rotate-left"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card content-card">
    <div class="card-header-custom">
        <h5><i class="fa-solid fa-users"></i> Danh sách người dùng <span class="badge" style="background:var(--apple-blue);color:#fff">@Model.TotalCount</span></h5>
        <a asp-action="Create" class="btn btn-primary btn-sm" style="border-radius:8px"><i class="fa-solid fa-user-plus me-1"></i>Thêm mới</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Phòng ban</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Items)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="topbar-avatar" style="width:38px;height:38px;font-size:.8rem;">@u.FullName.Substring(0, 1).ToUpper()</div>
                                    <div>
                                        <a asp-action="Details" asp-route-id="@u.Id" class="fw-bold" style="color:var(--text-primary);text-decoration:none">@u.FullName</a>
                                        <div class="text-muted small">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>@u.Department</td>
                            <td><span class="badge bg-primary-subtle text-primary border">@u.Roles</span></td>
                            <td>
                                <span class="badge @(u.Status == "Active" ? "bg-success" : u.Status == "Locked" ? "bg-danger" : "bg-secondary") rounded-pill">@(EnumHelper.Label<UserStatus>(u.Status))</span>
                            </td>
                            <td class="text-muted small">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary" title="Chi tiết" style="border-radius:6px">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa" style="border-radius:6px">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <a asp-controller="Account" asp-action="AdminResetPassword" asp-route-id="@u.Id" class="btn btn-sm btn-outline-info" title="Đặt lại mật khẩu" style="border-radius:6px">
                                        <i class="fa-solid fa-key"></i>
                                    </a>
                                    <form asp-action="ToggleLock" asp-route-id="@u.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(u.Status == "Active" ? "btn-outline-warning" : "btn-outline-success")" title="@(u.Status == "Active" ? "Khóa" : "Mở khóa")" style="border-radius:6px">
                                            <i class="fa-solid @(u.Status == "Active" ? "fa-lock" : "fa-unlock")"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="fa-solid fa-users fa-3x mb-3 d-block opacity-50"></i>Không tìm thấy người dùng</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
