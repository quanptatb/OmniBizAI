@model OmniBizAI.ViewModels.UserCreateViewModel
@{
    ViewData["Title"] = "Thêm Người dùng";
    ViewData["Breadcrumb"] = "<span>Tổ chức</span> <i class=\"fa-solid fa-chevron-right mx-2 text-muted fs-7\"></i> <span class=\"text-primary fw-bold\">Thêm người dùng</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card content-card border-top border-primary border-3">
            <div class="card-header bg-transparent border-bottom p-4">
                <h4 class="card-title mb-0"><i class="fa-solid fa-user-plus me-2 text-primary"></i>Thêm người dùng mới</h4>
                <p class="text-muted small mt-1 mb-0">Hệ thống sẽ tạo tài khoản Identity và hồ sơ AppUser đồng thời.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control bg-light" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control bg-light" placeholder="user@omnibiz.vn" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="Password" type="password" class="form-control bg-light" placeholder="Tối thiểu 8 ký tự" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JobTitle" class="form-label fw-bold">Chức danh</label>
                            <input asp-for="JobTitle" class="form-control bg-light" placeholder="VD: Nhân viên kinh doanh" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrganizationUnitId" class="form-label fw-bold">Phòng ban</label>
                            <select asp-for="OrganizationUnitId" class="form-select bg-light">
                                <option value="">-- Chưa phân bổ --</option>
                                @foreach (var d in Model.DepartmentOptions)
                                {
                                    <option value="@d.Value">@d.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-bold">Vai trò <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select bg-light">
                                @foreach (var r in Model.RoleOptions)
                                {
                                    <option value="@r.Value">@r.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="border-top pt-4 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border px-4">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-save me-2"></i>Tạo người dùng</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
