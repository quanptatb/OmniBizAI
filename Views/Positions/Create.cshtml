@model OmniBizAI.ViewModels.PositionCreateViewModel
@{ ViewData["Title"] = "Thêm chức vụ"; ViewData["Breadcrumb"] = "<span>Nhân sự</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Positions' style='color:var(--apple-blue);text-decoration:none'>Chức vụ</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Thêm mới</span>"; }
<div class="content-card" style="max-width:580px"><div class="card-header-custom"><h5><i class="fa-solid fa-user-tie"></i> Thêm chức vụ</h5></div><div class="card-body-custom">
    <form method="post" asp-action="Create">@Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Mã <span class="text-danger">*</span></label><input asp-for="Code" class="form-input" /><span asp-validation-for="Code" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-8"><label class="form-label">Tên chức vụ <span class="text-danger">*</span></label><input asp-for="Name" class="form-input" /><span asp-validation-for="Name" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-4"><label class="form-label">Cấp</label><input asp-for="Level" class="form-input" type="number" min="0" max="10" /></div>
            <div class="col-md-4"><label class="form-label">Phòng ban</label><select asp-for="OrganizationUnitId" class="form-input"><option value="">-- Toàn công ty --</option>@foreach(var d in Model.Departments){<option value="@d.Value">@d.Text</option>}</select></div>
            <div class="col-md-4 d-flex align-items-end"><div class="form-check" style="padding-top:8px"><input asp-for="IsManagerial" class="form-check-input" type="checkbox" /><label class="form-check-label" style="font-size:.85rem">Vị trí quản lý</label></div></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn-primary-custom"><i class="fa-solid fa-check me-1"></i>Tạo chức vụ</button><a asp-action="Index" class="btn-outline-custom">Hủy</a></div>
    </form>
</div></div>
