@model OmniBizAI.ViewModels.PositionListViewModel
@{ ViewData["Title"] = "Chức vụ"; ViewData["Breadcrumb"] = "<span>Nhân sự</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chức vụ</span>"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="page-title mb-1">Quản lý chức vụ</h4><p class="text-muted mb-0" style="font-size:.82rem">@Model.TotalCount chức vụ</p></div>
    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus me-2"></i>Thêm chức vụ</a>
</div>
<div class="content-card"><div class="card-body-custom p-0">
    <table class="data-table">
        <thead><tr><th class="ps-3">Mã</th><th>Tên chức vụ</th><th>Cấp</th><th>Phòng ban</th><th>Quản lý</th><th class="pe-3">Thao tác</th></tr></thead>
        <tbody>
            @foreach (var p in Model.Items) {
                <tr>
                    <td class="ps-3" style="font-weight:600;color:var(--apple-blue)">@p.Code</td>
                    <td style="font-weight:500">@p.Name</td>
                    <td><span class="badge bg-light text-dark">Cấp @p.Level</span></td>
                    <td style="color:var(--text-secondary);font-size:.82rem">@(p.Department ?? "Toàn công ty")</td>
                    <td>@if(p.IsManagerial){<span class="badge bg-primary" style="font-size:.68rem"><i class="fa-solid fa-crown me-1"></i>Quản lý</span>}else{<span style="color:var(--text-muted)">—</span>}</td>
                    <td class="pe-3">
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-primary btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-pen"></i></a>
                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa chức vụ @p.Name?')">
                                <button type="submit" class="btn btn-outline-danger btn-sm" style="font-size:.68rem;padding:2px 8px"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any()) { <tr><td colspan="6" class="text-center py-4" style="color:var(--text-muted)">Chưa có chức vụ</td></tr> }
        </tbody>
    </table>
</div></div>
