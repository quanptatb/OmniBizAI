@model OmniBizAI.ViewModels.PositionEditViewModel
@{ ViewData["Title"] = "Chỉnh sửa chức vụ"; ViewData["Breadcrumb"] = "<a href='/Positions' style='color:var(--apple-blue);text-decoration:none'>Chức vụ</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>"; }

<div class="content-card" style="max-width:520px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-pen"></i> Chỉnh sửa chức vụ</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Edit">@Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Mã chức vụ <span class="text-danger">*</span></label>
                    <input asp-for="Code" class="form-control" />
                    <span asp-validation-for="Code" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Tên chức vụ <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Cấp bậc</label>
                    <input asp-for="Level" type="number" class="form-control" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phòng ban</label>
                    <select asp-for="OrganizationUnitId" class="form-select">
                        <option value="">— Tất cả —</option>
                        @foreach (var d in Model.Departments) { <option value="@d.Value">@d.Text</option> }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsManagerial" type="checkbox" class="form-check-input" />
                        <label class="form-check-label" asp-for="IsManagerial">Quản lý</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Lưu</button>
                <a asp-action="Index" class="btn btn-light">Hủy</a>
            </div>
        </form>
    </div>
</div>
