<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] | OmniBizAI</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="~/css/AdminLayout.css" />
@RenderSection("Styles", required: false)
</head>
<body>

<aside class="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-icon">
      <img src="~/images/Logo.png" alt="Logo" />
    </div>
    <span class="sb-logo-text">OmniBizAI</span>
  </div>
  <nav class="sb-body">
    <div class="sb-section-label">Chính</div>
    <a class="sb-item active" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></div>
      <span class="sb-label">Tổng quan</span>
      <span class="sb-tooltip">Tổng quan</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></div>
      <span class="sb-label">KPI / OKR</span>
      <span class="sb-tooltip">KPI / OKR</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
      <span class="sb-label">Trợ lý AI</span>
      <span class="sb-badge" style="background: linear-gradient(45deg, #8b5cf6, #ec4899)">Mới</span>
      <span class="sb-tooltip">Trợ lý AI</span>
    </a>
    <div class="sb-section-label">Kinh doanh</div>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></div>
      <span class="sb-label">Đơn hàng</span>
      <span class="sb-tooltip">Đơn hàng</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg></div>
      <span class="sb-label">Sản phẩm</span>
      <span class="sb-tooltip">Sản phẩm</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg></div>
      <span class="sb-label">Hàng chờ duyệt</span>
      <span class="sb-badge">5</span>
      <span class="sb-tooltip">Hàng chờ duyệt (5)</span>
    </a>
    <div class="sb-section-label">Tài chính</div>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <span class="sb-label">Ngân sách</span>
      <span class="sb-tooltip">Ngân sách</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg></div>
      <span class="sb-label">Giao dịch</span>
      <span class="sb-tooltip">Giao dịch</span>
    </a>
    <div class="sb-section-label">Quản lý</div>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
      <span class="sb-label">Nhân viên</span>
      <span class="sb-tooltip">Nhân viên</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
      <span class="sb-label">Khách hàng</span>
      <span class="sb-tooltip">Khách hàng</span>
    </a>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>
      <span class="sb-label">Báo cáo</span>
      <span class="sb-tooltip">Báo cáo</span>
    </a>
    <div class="sb-section-label">Hệ thống</div>
    <a class="sb-item" href="#">
      <div class="sb-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
      <span class="sb-label">Cài đặt</span>
      <span class="sb-tooltip">Cài đặt</span>
    </a>
  </nav>

</aside>

<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <div class="breadcrumb">
        <span>Trang chủ</span>
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
        <strong>@ViewData["Title"]</strong>
      </div>
      <div class="search-bar">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="text" placeholder="Tìm kiếm...">
      </div>
    </div>
    <div class="topbar-right">
      <div class="icon-btn"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg><span class="notif-dot"></span></div>
      <div class="icon-btn"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg></div>
      
      <div class="topbar-divider"></div>
      
      <div class="topbar-user" onclick="toggleUserMenu()">
        <div class="topbar-avatar">QT</div>
        <div class="topbar-user-info">
          <div class="topbar-user-name">Quản trị viên</div>
        </div>
        <svg class="chevron" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        
        <div class="user-dropdown" id="userDropdown">
          <a href="#" class="dropdown-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Hồ sơ cá nhân
          </a>
          <a href="#" class="dropdown-item">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Cài đặt
          </a>
          <div class="dropdown-divider"></div>
          <a href="#" onclick="showLogoutModal(event)" class="dropdown-item text-red">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Đăng xuất
          </a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">
    @RenderBody()
  </div>
</div>

<!-- Logout Modal -->
<div id="logoutModal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
    </div>
    <h3 class="modal-title">Đăng xuất</h3>
    <p class="modal-desc">Bạn có chắc chắn muốn đăng xuất khỏi hệ thống?</p>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeLogoutModal()">Huỷ</button>
      <a href="/Account/Login" class="btn btn-primary" style="background: var(--red); box-shadow: 0 4px 20px var(--red-bg);">Đăng xuất</a>
    </div>
  </div>
</div><script>
  function updateTime() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const d = String(now.getDate()).padStart(2,'0');
    const mo = String(now.getMonth()+1).padStart(2,'0');
    const y = now.getFullYear();
    const timeDisplay = document.getElementById('time-display');
    if (timeDisplay) {
        timeDisplay.textContent = `Cập nhật lúc ${h}:${m}, ${d}/${mo}/${y}`;
    }
  }
  updateTime();
  setInterval(updateTime, 60000);

  function toggleUserMenu() {
    document.getElementById('userDropdown').classList.toggle('active');
  }

  // Modal functions
  function showLogoutModal(e) {
    e.preventDefault();
    document.getElementById('logoutModal').classList.add('active');
    // Hide dropdown if open
    document.getElementById('userDropdown').classList.remove('active');
  }
  
  function closeLogoutModal() {
    document.getElementById('logoutModal').classList.remove('active');
  }

  // Close dropdown when clicking outside
  window.onclick = function(event) {
    if (!event.target.closest('.topbar-user')) {
      const dropdowns = document.getElementsByClassName("user-dropdown");
      for (let i = 0; i < dropdowns.length; i++) {
        if (dropdowns[i].classList.contains('active')) {
          dropdowns[i].classList.remove('active');
        }
      }
    }
  }
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
