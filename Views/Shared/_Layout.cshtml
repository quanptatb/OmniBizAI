@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser<Guid>> SignInManager
@inject UserManager<IdentityUser<Guid>> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="OmniBizAI - Hệ thống vận hành thông minh cho doanh nghiệp vừa và nhỏ" />
    <title>@ViewData["Title"] - OmniBizAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kpi-okr.css" asp-append-version="true" />
    @if (SignInManager.IsSignedIn(User)) { <link rel="stylesheet" href="@Url.Action("ThemeCss", "Settings")" /> }
    @await RenderSectionAsync("Styles", required: false)
    <script>
        (function(){
            var mode = localStorage.getItem('omnibiz-nav-mode') || 'classic';
            document.documentElement.setAttribute('data-nav-mode', mode);
            var s=localStorage.getItem('omnibiz-sidebar');
            if(s==='collapsed' && mode==='classic') document.documentElement.classList.add('sidebar-collapsed');
        })();
    </script>
</head>
<body class="app-body">
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            @{ var _themeVm = await ((OmniBizAI.Services.SettingsService)Context.RequestServices.GetService(typeof(OmniBizAI.Services.SettingsService))!).GetThemeAsync(); }
            <div class="sidebar-brand">
                <div class="brand-icon"><i class="@_themeVm.LogoIcon"></i></div>
                <div class="brand-text">
                    <span class="brand-name">@_themeVm.BrandName</span>
                    <span class="brand-tagline">@_themeVm.BrandTagline</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">TỔNG QUAN</div>
                <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span>Dashboard</span>
                </a>

                <div class="nav-section-label">VẬN HÀNH</div>
                <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "OperationPlans" ? "active" : "")"
                   asp-controller="OperationPlans" asp-action="Index">
                    <i class="fa-solid fa-calendar-alt"></i>
                    <span>Kế hoạch & Lịch trình</span>
                </a>
                <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Operations" ? "active" : "")"
                   asp-controller="Operations" asp-action="Index">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Yêu cầu vận hành</span>
                    <span class="nav-badge" id="pendingBadge" style="display:none"></span>
                </a>

                @if (User.IsInRole("STAFF") || User.IsInRole("DEPARTMENT_MANAGER") || User.IsInRole("EXECUTIVE") || User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
                {
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Workflow" ? "active" : "")"
                       asp-controller="Workflow" asp-action="Kanban">
                        <i class="fa-solid fa-table-columns"></i>
                        <span>Kanban workflow</span>
                    </a>
                }

                @if (User.IsInRole("DEPARTMENT_MANAGER") || User.IsInRole("EXECUTIVE") || User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
                {
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Approvals" ? "active" : "")"
                       asp-controller="Approvals" asp-action="MyTasks">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>Phê duyệt</span>
                    </a>
                }

                @if (User.IsInRole("ACCOUNTANT") || User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN") || User.IsInRole("EXECUTIVE") || User.IsInRole("DEPARTMENT_MANAGER") || User.IsInRole("STAFF"))
                {
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                    var financeOpen = currentController == "Finance" || currentController == "Expenses" || currentController == "Procurement" || currentController == "PurchaseOrders" || currentController == "GoodsReceipt" || currentController == "GoodsIssue" || currentController == "Inventory" || currentController == "CashBook";
                    var hrOpen = currentController == "Organization" || currentController == "Users" || currentController == "Employees" || currentController == "Positions" || currentController == "Leave";
                    var kpiOkrOpen = currentController == "MissionVision" || currentController == "Okr" || currentController == "KpiSetup" || currentController == "KpiCheckIn" || currentController == "Evaluation";
                    var crmOpen = currentController == "Customers" || currentController == "Vendors" || currentController == "Products";
                    var settingsOpen = currentController == "Settings";
                    var reportAction = ViewContext.RouteData.Values["action"]?.ToString();
                    var reportOpen = currentController == "Reports";

                    <div class="nav-section-label">TÀI CHÍNH & MUA SẮM</div>
                    <button type="button" class="nav-group-toggle @(financeOpen ? "expanded" : "")" data-nav-group-toggle data-target="financeBranch" aria-expanded="@(financeOpen.ToString().ToLower())">
                        <span class="left"><i class="fa-solid fa-wallet"></i><span>Tài chính</span></span>
                        <i class="fa-solid fa-chevron-down chev"></i>
                    </button>
                    <div id="financeBranch" class="nav-group-items @(financeOpen ? "open" : "")" data-nav-group>
                        <a class="nav-item @(currentController == "Finance" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Finance" asp-action="Index">
                            <i class="fa-solid fa-chart-line"></i><span>Tổng quan</span>
                        </a>
                        <a class="nav-item @(currentController == "Finance" && ViewContext.RouteData.Values["action"]?.ToString() == "Budgets" ? "active" : "")" asp-controller="Finance" asp-action="Budgets">
                            <i class="fa-solid fa-piggy-bank"></i><span>Ngân sách</span>
                        </a>
                        <a class="nav-item @(currentController == "Expenses" ? "active" : "")" asp-controller="Expenses" asp-action="Index">
                            <i class="fa-solid fa-receipt"></i><span>Chi phí</span>
                        </a>
                        <a class="nav-item @(currentController == "CashBook" ? "active" : "")" asp-controller="CashBook" asp-action="Index">
                            <i class="fa-solid fa-book-open"></i><span>Sổ thu chi</span>
                        </a>
                        <a class="nav-item @(currentController == "Finance" && ViewContext.RouteData.Values["action"]?.ToString() == "PaymentRequests" ? "active" : "")" asp-controller="Finance" asp-action="PaymentRequests">
                            <i class="fa-solid fa-file-invoice-dollar"></i><span>Đề nghị thanh toán</span>
                        </a>
                        <a class="nav-item @(currentController == "Procurement" ? "active" : "")" asp-controller="Procurement" asp-action="Index">
                            <i class="fa-solid fa-cart-shopping"></i><span>Đề xuất mua sắm</span>
                        </a>
                        <a class="nav-item @(currentController == "PurchaseOrders" ? "active" : "")" asp-controller="PurchaseOrders" asp-action="Index">
                            <i class="fa-solid fa-file-invoice"></i><span>Đơn mua hàng</span>
                        </a>
                        <a class="nav-item @(currentController == "GoodsReceipt" ? "active" : "")" asp-controller="GoodsReceipt" asp-action="Index">
                            <i class="fa-solid fa-warehouse"></i><span>Nhập kho</span>
                        </a>
                        <a class="nav-item @(currentController == "GoodsIssue" ? "active" : "")" asp-controller="GoodsIssue" asp-action="Index">
                            <i class="fa-solid fa-dolly"></i><span>Xuất kho</span>
                        </a>
                        <a class="nav-item @(currentController == "Inventory" ? "active" : "")" asp-controller="Inventory" asp-action="Index">
                            <i class="fa-solid fa-cubes"></i><span>Tồn kho & Cảnh báo</span>
                        </a>
                    </div>

                    <div class="nav-section-label">NHÂN SỰ & TỔ CHỨC</div>
                    <button type="button" class="nav-group-toggle @(hrOpen ? "expanded" : "")" data-nav-group-toggle data-target="hrBranch" aria-expanded="@(hrOpen.ToString().ToLower())">
                        <span class="left"><i class="fa-solid fa-users"></i><span>Nhân sự</span></span>
                        <i class="fa-solid fa-chevron-down chev"></i>
                    </button>
                    <div id="hrBranch" class="nav-group-items @(hrOpen ? "open" : "")" data-nav-group>
                        <a class="nav-item @(currentController == "Employees" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Employees" asp-action="Dashboard">
                            <i class="fa-solid fa-chart-line"></i><span>Tổng quan</span>
                        </a>
                        @if (User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
                        {
                            <a class="nav-item @(currentController == "Organization" ? "active" : "")" asp-controller="Organization" asp-action="Index">
                                <i class="fa-solid fa-sitemap"></i><span>Phòng ban</span>
                            </a>
                        }
                        <a class="nav-item @(currentController == "Employees" && ViewContext.RouteData.Values["action"]?.ToString() != "Dashboard" ? "active" : "")" asp-controller="Employees" asp-action="Index">
                            <i class="fa-solid fa-id-badge"></i><span>Nhân viên</span>
                        </a>
                        <a class="nav-item @(currentController == "Leave" ? "active" : "")" asp-controller="Leave" asp-action="Index">
                            <i class="fa-solid fa-calendar-check"></i><span>Nghỉ phép</span>
                        </a>
                        @if (User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
                        {
                            <a class="nav-item @(currentController == "Positions" ? "active" : "")" asp-controller="Positions" asp-action="Index">
                                <i class="fa-solid fa-user-tie"></i><span>Chức vụ</span>
                            </a>
                            <a class="nav-item @(currentController == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                                <i class="fa-solid fa-user-gear"></i><span>Tài khoản</span>
                            </a>
                        }
                    </div>

                    <div class="nav-section-label">KHÁCH HÀNG & ĐỐI TÁC</div>
                    <button type="button" class="nav-group-toggle @(crmOpen ? "expanded" : "")" data-nav-group-toggle data-target="crmBranch" aria-expanded="@(crmOpen.ToString().ToLower())">
                        <span class="left"><i class="fa-solid fa-handshake"></i><span>CRM</span></span>
                        <i class="fa-solid fa-chevron-down chev"></i>
                    </button>
                    <div id="crmBranch" class="nav-group-items @(crmOpen ? "open" : "")" data-nav-group>
                        <a class="nav-item @(currentController == "Customers" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Customers" asp-action="Dashboard">
                            <i class="fa-solid fa-chart-line"></i><span>Tổng quan</span>
                        </a>
                        <a class="nav-item @(currentController == "Customers" && ViewContext.RouteData.Values["action"]?.ToString() != "Dashboard" ? "active" : "")" asp-controller="Customers" asp-action="Index">
                            <i class="fa-solid fa-building"></i><span>Khách hàng</span>
                        </a>
                        <a class="nav-item @(currentController == "Vendors" ? "active" : "")" asp-controller="Vendors" asp-action="Index">
                            <i class="fa-solid fa-truck"></i><span>Nhà cung cấp</span>
                        </a>
                        <a class="nav-item @(currentController == "Products" ? "active" : "")" asp-controller="Products" asp-action="Index">
                            <i class="fa-solid fa-box"></i><span>Sản phẩm & DV</span>
                        </a>
                    </div>

                    <div class="nav-section-label">KPI / OKR & ĐÁNH GIÁ</div>
                    <button type="button" class="nav-group-toggle @(kpiOkrOpen ? "expanded" : "")" data-nav-group-toggle data-target="kpiOkrBranch" aria-expanded="@(kpiOkrOpen.ToString().ToLower())">
                        <span class="left"><i class="fa-solid fa-bullseye"></i><span>KPI / OKR</span></span>
                        <i class="fa-solid fa-chevron-down chev"></i>
                    </button>
                    <div id="kpiOkrBranch" class="nav-group-items @(kpiOkrOpen ? "open" : "")" data-nav-group>
                        <a class="nav-item @(currentController == "Okr" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Okr" asp-action="Dashboard">
                            <i class="fa-solid fa-chart-line"></i><span>Tổng quan</span>
                        </a>
                        <a class="nav-item @(currentController == "MissionVision" ? "active" : "")" asp-controller="MissionVision" asp-action="Index">
                            <i class="fa-solid fa-star"></i><span>Sứ mệnh & Tầm nhìn</span>
                        </a>
                        <a class="nav-item @(currentController == "Okr" && ViewContext.RouteData.Values["action"]?.ToString() != "Dashboard" ? "active" : "")" asp-controller="Okr" asp-action="Index">
                            <i class="fa-solid fa-bullseye"></i><span>OKR</span>
                        </a>
                        <a class="nav-item @(currentController == "KpiSetup" ? "active" : "")" asp-controller="KpiSetup" asp-action="Index">
                            <i class="fa-solid fa-gauge-high"></i><span>Thiết lập KPI</span>
                        </a>
                        <a class="nav-item @(currentController == "KpiCheckIn" ? "active" : "")" asp-controller="KpiCheckIn" asp-action="Index">
                            <i class="fa-solid fa-clipboard-check"></i><span>Check-In</span>
                        </a>
                        <a class="nav-item @(currentController == "Evaluation" ? "active" : "")" asp-controller="Evaluation" asp-action="Index">
                            <i class="fa-solid fa-award"></i><span>Đánh giá</span>
                        </a>
                    </div>

                    <div class="nav-section-label">BÁO CÁO & AI</div>
                    <button type="button" class="nav-group-toggle @(reportOpen ? "expanded" : "")" data-nav-group-toggle data-target="reportBranch" aria-expanded="@(reportOpen.ToString().ToLower())">
                        <span class="left"><i class="fa-solid fa-chart-bar"></i><span>Báo cáo</span></span>
                        <i class="fa-solid fa-chevron-down chev"></i>
                    </button>
                    <div id="reportBranch" class="nav-group-items @(reportOpen ? "open" : "")" data-nav-group>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Executive" ? "active" : "")" asp-controller="Reports" asp-action="Executive">
                            <i class="fa-solid fa-crown"></i><span>Ban GĐ</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Dashboard" ? "active" : "")" asp-controller="Reports" asp-action="Dashboard">
                            <i class="fa-solid fa-cogs"></i><span>Vận hành</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Finance" ? "active" : "")" asp-controller="Reports" asp-action="Finance">
                            <i class="fa-solid fa-wallet"></i><span>Tài chính</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Hr" ? "active" : "")" asp-controller="Reports" asp-action="Hr">
                            <i class="fa-solid fa-users"></i><span>Nhân sự</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "KpiOkr" ? "active" : "")" asp-controller="Reports" asp-action="KpiOkr">
                            <i class="fa-solid fa-bullseye"></i><span>KPI/OKR</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Inventory" ? "active" : "")" asp-controller="Reports" asp-action="Inventory">
                            <i class="fa-solid fa-cubes"></i><span>Kho vận</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "CashFlow" ? "active" : "")" asp-controller="Reports" asp-action="CashFlow">
                            <i class="fa-solid fa-money-bill-transfer"></i><span>Thu chi</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "Crm" ? "active" : "")" asp-controller="Reports" asp-action="Crm">
                            <i class="fa-solid fa-handshake"></i><span>CRM</span>
                        </a>
                        <a class="nav-item @(currentController == "Reports" && reportAction == "ExportCenter" ? "active" : "")" asp-controller="Reports" asp-action="ExportCenter">
                            <i class="fa-solid fa-file-export"></i><span>Xuất báo cáo</span>
                        </a>
                    </div>
                    <a class="nav-item @(currentController == "AiInsights" && ViewContext.RouteData.Values["action"]?.ToString() != "Recommendations" ? "active" : "")" asp-controller="AiInsights" asp-action="Index">
                        <i class="fa-solid fa-robot"></i>
                        <span>AI Copilot</span>
                        <span class="nav-badge-ai">AI</span>
                    </a>
                    <a class="nav-item @(currentController == "AiInsights" && ViewContext.RouteData.Values["action"]?.ToString() == "Recommendations" ? "active" : "")" asp-controller="AiInsights" asp-action="Recommendations">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                        <span>AI Khuyến nghị</span>
                    </a>
                    <a class="nav-item @(currentController == "AnomalyAlerts" ? "active" : "")" asp-controller="AnomalyAlerts" asp-action="Index">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Cảnh báo bất thường</span>
                    </a>
                }

                @if (User.IsInRole("AUDITOR") || User.IsInRole("SYSTEM_ADMIN") || User.IsInRole("TENANT_ADMIN"))
                {
                    <div class="nav-section-label">HỆ THỐNG</div>
                    @if (User.IsInRole("TENANT_ADMIN") || User.IsInRole("SYSTEM_ADMIN"))
                    {
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" && ViewContext.RouteData.Values["action"]?.ToString() == "Company" ? "active" : "")"
                           asp-controller="Settings" asp-action="Company">
                            <i class="fa-solid fa-building-columns"></i>
                            <span>Cài đặt công ty</span>
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" && ViewContext.RouteData.Values["action"]?.ToString() == "Modules" ? "active" : "")"
                           asp-controller="Settings" asp-action="Modules">
                            <i class="fa-solid fa-puzzle-piece"></i>
                            <span>Quản lý modules</span>
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" && ViewContext.RouteData.Values["action"]?.ToString() == "Parameters" ? "active" : "")"
                           asp-controller="Settings" asp-action="Parameters">
                            <i class="fa-solid fa-sliders"></i>
                            <span>Tham số hệ thống</span>
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" && ViewContext.RouteData.Values["action"]?.ToString() == "EnumLabels" ? "active" : "")"
                           asp-controller="Settings" asp-action="EnumLabels">
                            <i class="fa-solid fa-tags"></i>
                            <span>Nhãn hệ thống</span>
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" && ViewContext.RouteData.Values["action"]?.ToString() == "Appearance" ? "active" : "")"
                           asp-controller="Settings" asp-action="Appearance">
                            <i class="fa-solid fa-palette"></i>
                            <span>Giao diện</span>
                        </a>
                        <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Backup" ? "active" : "")"
                           asp-controller="Backup" asp-action="Index">
                            <i class="fa-solid fa-database"></i>
                            <span>Sao lưu dữ liệu</span>
                        </a>
                    }
                    <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")"
                       asp-controller="Audit" asp-action="Index">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Nhật ký hệ thống</span>
                    </a>
                }

            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <div class="user-details">
                        <span class="user-email">@User.Identity?.Name</span>
                        <span class="user-role">@(User.IsInRole("SYSTEM_ADMIN") ? "Sys Admin" : User.IsInRole("TENANT_ADMIN") ? "Admin" : User.IsInRole("EXECUTIVE") ? "Executive" : User.IsInRole("DEPARTMENT_MANAGER") ? "Manager" : User.IsInRole("ACCOUNTANT") ? "Accountant" : "Staff")</span>
                    </div>
                </div>
                <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout" title="Đăng xuất">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </button>
                </form>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-wrapper">
            <!-- TOPBAR (Frosted Glass) -->
            <header class="topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <button class="app-launcher-toggle" id="appLauncherBtn" aria-label="App Launcher" style="display:none;" onclick="toggleAppLauncher()">
                        <i class="fa-solid fa-grip"></i>
                    </button>
                    <div class="topbar-breadcrumb">
                        @if (ViewData["Breadcrumb"] is not null)
                        {
                            @Html.Raw(ViewData["Breadcrumb"])
                        }
                        else
                        {
                            <span>@ViewData["Title"]</span>
                        }
                    </div>
                </div>
                <div class="topbar-actions">
                    <!-- Nav Mode Switcher -->
                    <div class="nav-mode-picker" style="position:relative">
                        <button class="topbar-btn" title="Đổi giao diện điều hướng" onclick="toggleNavModeMenu()">
                            <i class="fa-solid fa-object-ungroup"></i>
                        </button>
                        <div class="nav-mode-menu" id="navModeMenu" style="display:none;">
                            <button onclick="setNavMode('classic')"><i class="fa-solid fa-list"></i> Sidebar Cơ bản</button>
                            <button onclick="setNavMode('card-sidebar')"><i class="fa-solid fa-table-cells-large"></i> Sidebar dạng Thẻ</button>
                            <button onclick="setNavMode('launcher')"><i class="fa-solid fa-expand"></i> App Launcher</button>
                        </div>
                    </div>
                    <!-- Notification Bell -->
                    <div class="notif-wrapper" style="position:relative">
                        <button class="topbar-btn" id="notifBtn" title="Thông báo" onclick="toggleNotifPanel()">
                            <i class="fa-solid fa-bell"></i>
                            <span class="notif-dot" id="notifDot" style="display:none"></span>
                            <span class="notif-count-badge" id="notifCountBadge" style="display:none">0</span>
                        </button>
                        <!-- Notification Dropdown -->
                        <div class="notif-panel" id="notifPanel" style="display:none">
                            <div class="notif-panel-header">
                                <span style="font-weight:700;font-size:.92rem">Thông báo</span>
                                <div class="d-flex align-items-center gap-2">
                                    <button type="button" class="notif-panel-action" onclick="markAllNotifRead()" title="Đọc tất cả"><i class="fa-solid fa-check-double"></i></button>
                                    <a href="/Notifications" class="notif-panel-action" title="Xem tất cả"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                                </div>
                            </div>
                            <div class="notif-panel-body" id="notifPanelBody">
                                <div class="text-center py-4" style="color:var(--text-muted);font-size:.82rem">Đang tải...</div>
                            </div>
                        </div>
                    </div>
                    <!-- Profile Avatar -->
                    <a href="/Profile" class="topbar-user" title="Hồ sơ cá nhân" style="text-decoration:none">
                        <div class="topbar-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")</div>
                    </a>
                </div>
            </header>

            <!-- TOAST MESSAGES -->
            @if (TempData["SuccessMessage"] is not null)
            {
                <div class="alert-toast success" id="alertToast">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["SuccessMessage"]</span>
                    <button onclick="document.getElementById('alertToast').remove()" class="toast-close">&times;</button>
                </div>
            }
            @if (TempData["ErrorMessage"] is not null)
            {
                <div class="alert-toast error" id="alertToastErr">
                    <i class="fa-solid fa-circle-xmark"></i>
                    <span>@TempData["ErrorMessage"]</span>
                    <button onclick="document.getElementById('alertToastErr').remove()" class="toast-close">&times;</button>
                </div>
            }
            @if (TempData["ToastWarningMessage"] is not null)
            {
                <div class="alert-toast warning" id="alertToastWarn">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span>@TempData["ToastWarningMessage"]</span>
                    <button onclick="document.getElementById('alertToastWarn').remove()" class="toast-close">&times;</button>
                </div>
            }

            <main class="page-content">
                @RenderBody()
            </main>

            <footer style="padding:16px 24px;text-align:center;font-size:.72rem;color:var(--text-muted);border-top:1px solid var(--divider);">
                &copy; @DateTime.Now.Year OmniBizAI. All rights reserved.
            </footer>
        </div>

        <!-- APP LAUNCHER OVERLAY -->
        <div class="app-launcher-overlay" id="appLauncherOverlay">
            <div class="launcher-header">
                <h3><i class="fa-solid fa-grip"></i> Menu Chức Năng</h3>
                <button class="launcher-close" onclick="toggleAppLauncher()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="launcher-body">
                <!-- VẬN HÀNH -->
                <div class="launcher-section">
                    <h4>VẬN HÀNH</h4>
                    <div class="launcher-grid">
                        <a href="/Operations" class="launcher-card"><i class="fa-solid fa-list-check"></i><span>Yêu cầu vận hành</span></a>
                        <a href="/Workflow/Kanban" class="launcher-card"><i class="fa-solid fa-table-columns"></i><span>Kanban workflow</span></a>
                        <a href="/Approvals/MyTasks" class="launcher-card"><i class="fa-solid fa-circle-check"></i><span>Phê duyệt</span></a>
                    </div>
                </div>
                <!-- TÀI CHÍNH & MUA SẮM -->
                <div class="launcher-section">
                    <h4>TÀI CHÍNH & MUA SẮM</h4>
                    <div class="launcher-grid">
                        <a href="/Finance" class="launcher-card"><i class="fa-solid fa-chart-line"></i><span>Tài chính</span></a>
                        <a href="/Expenses" class="launcher-card"><i class="fa-solid fa-receipt"></i><span>Chi phí</span></a>
                        <a href="/CashBook" class="launcher-card"><i class="fa-solid fa-book-open"></i><span>Sổ thu chi</span></a>
                        <a href="/Procurement" class="launcher-card"><i class="fa-solid fa-cart-shopping"></i><span>Mua sắm</span></a>
                        <a href="/Inventory" class="launcher-card"><i class="fa-solid fa-cubes"></i><span>Kho vận</span></a>
                    </div>
                </div>
                <!-- NHÂN SỰ -->
                <div class="launcher-section">
                    <h4>NHÂN SỰ & TỔ CHỨC</h4>
                    <div class="launcher-grid">
                        <a href="/Employees" class="launcher-card"><i class="fa-solid fa-users"></i><span>Nhân sự</span></a>
                        <a href="/Leave" class="launcher-card"><i class="fa-solid fa-calendar-check"></i><span>Nghỉ phép</span></a>
                    </div>
                </div>
                <!-- CRM -->
                <div class="launcher-section">
                    <h4>KHÁCH HÀNG & ĐỐI TÁC</h4>
                    <div class="launcher-grid">
                        <a href="/Customers" class="launcher-card"><i class="fa-solid fa-building"></i><span>Khách hàng</span></a>
                        <a href="/Vendors" class="launcher-card"><i class="fa-solid fa-truck"></i><span>Nhà cung cấp</span></a>
                        <a href="/Products" class="launcher-card"><i class="fa-solid fa-box"></i><span>Sản phẩm & DV</span></a>
                    </div>
                </div>
                <!-- KPI / OKR -->
                <div class="launcher-section">
                    <h4>KPI / OKR</h4>
                    <div class="launcher-grid">
                        <a href="/Okr" class="launcher-card"><i class="fa-solid fa-bullseye"></i><span>OKR</span></a>
                        <a href="/KpiSetup" class="launcher-card"><i class="fa-solid fa-gauge-high"></i><span>KPI</span></a>
                        <a href="/Evaluation" class="launcher-card"><i class="fa-solid fa-award"></i><span>Đánh giá</span></a>
                    </div>
                </div>
                <!-- HỆ THỐNG & AI -->
                <div class="launcher-section">
                    <h4>HỆ THỐNG & BÁO CÁO</h4>
                    <div class="launcher-grid">
                        <a href="/Reports/Dashboard" class="launcher-card"><i class="fa-solid fa-chart-bar"></i><span>Báo cáo</span></a>
                        <a href="/AiInsights" class="launcher-card"><i class="fa-solid fa-robot"></i><span>AI Copilot</span></a>
                        <a href="/Settings/Company" class="launcher-card"><i class="fa-solid fa-sliders"></i><span>Cài đặt</span></a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
