@model OmniBizAI.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Tổng Quan";
    ViewData["Breadcrumb"] = "<span>Tổng quan</span>";
}

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-sm-6">
        <div class="card glass-card h-100 border-primary border-bottom border-3">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase small font-weight-bold">Tổng yêu cầu</p>
                    <h2 class="mb-0 text-primary">@Model.TotalOperationRequests</h2>
                </div>
                <div class="icon-shape bg-primary text-white rounded-circle p-3">
                    <i class="fa-solid fa-file-lines fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-3 col-sm-6">
        <div class="card glass-card h-100 border-warning border-bottom border-3">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase small font-weight-bold">Chờ duyệt</p>
                    <h2 class="mb-0 text-warning">@Model.PendingApprovals</h2>
                </div>
                <div class="icon-shape bg-warning text-white rounded-circle p-3">
                    <i class="fa-solid fa-clock fa-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-sm-6">
        <div class="card glass-card h-100 border-danger border-bottom border-3">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase small font-weight-bold">Quá hạn</p>
                    <h2 class="mb-0 text-danger">@Model.OverdueTasks</h2>
                </div>
                <div class="icon-shape bg-danger text-white rounded-circle p-3">
                    <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-sm-6">
        <div class="card glass-card h-100 border-success border-bottom border-3">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted mb-1 text-uppercase small font-weight-bold">Nhân sự</p>
                    <h2 class="mb-0 text-success">@Model.ActiveUsers</h2>
                </div>
                <div class="icon-shape bg-success text-white rounded-circle p-3">
                    <i class="fa-solid fa-users fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card glass-card h-100">
            <div class="card-header border-bottom-0 bg-transparent pb-0">
                <h5 class="card-title mb-0"><i class="fa-solid fa-chart-area me-2 text-primary"></i>Biểu đồ yêu cầu 6 tháng gần đây</h5>
            </div>
            <div class="card-body">
                <canvas id="trendChart" height="100"></canvas>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card glass-card h-100">
            <div class="card-header border-bottom-0 bg-transparent pb-0">
                <h5 class="card-title mb-0"><i class="fa-solid fa-chart-pie me-2 text-primary"></i>Trạng thái yêu cầu</h5>
            </div>
            <div class="card-body">
                <canvas id="statusChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card glass-card h-100">
            <div class="card-header border-bottom bg-transparent d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="fa-solid fa-list-check me-2 text-primary"></i>Yêu cầu gần đây</h5>
                <a asp-controller="Operations" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-sm">
                        <thead class="table-light text-muted">
                            <tr>
                                <th class="ps-3">Mã</th>
                                <th>Tiêu đề</th>
                                <th>Trạng thái</th>
                                <th class="pe-3">Ngày tạo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentRequests)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-primary">@item.RequestNo</td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 200px;" title="@item.Title">@item.Title</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(item.Status == "Completed" ? "success" : item.Status == "Pending" ? "warning" : "info") rounded-pill">@item.Status</span>
                                    </td>
                                    <td class="pe-3 text-muted">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                            @if (!Model.RecentRequests.Any())
                            {
                                <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card glass-card h-100">
            <div class="card-header border-bottom bg-transparent d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="fa-solid fa-shield-halved me-2 text-primary"></i>Nhật ký hệ thống</h5>
                <a asp-controller="Audit" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var audit in Model.RecentAudits)
                    {
                        <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-3 py-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm me-3 bg-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;">
                                    <i class="fa-solid fa-history"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 text-sm fw-bold">@audit.UserName <span class="text-muted fw-normal">đã @audit.Action</span></h6>
                                    <small class="text-muted">@audit.EntityType</small>
                                </div>
                            </div>
                            <small class="text-muted"><i class="fa-regular fa-clock me-1"></i>@audit.OccurredAt.ToString("HH:mm dd/MM")</small>
                        </li>
                    }
                    @if (!Model.RecentAudits.Any())
                    {
                        <li class="list-group-item bg-transparent text-center py-4 text-muted">Chưa có nhật ký</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Chart configuration
            const months = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Month));
            const created = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Created));
            const completed = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Completed));
            
            new Chart(document.getElementById('trendChart'), {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [
                        { label: 'Tạo mới', data: created, borderColor: '#0d6efd', backgroundColor: 'rgba(13, 110, 253, 0.1)', fill: true, tension: 0.4 },
                        { label: 'Hoàn thành', data: completed, borderColor: '#198754', backgroundColor: 'transparent', tension: 0.4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { beginAtZero: true } } }
            });

            const statuses = @Json.Serialize(Model.RequestsByStatus.Select(x => x.Status));
            const counts = @Json.Serialize(Model.RequestsByStatus.Select(x => x.Count));
            const bgColors = statuses.map(s => s === 'Completed' ? '#198754' : s === 'Pending' ? '#ffc107' : s === 'Cancelled' ? '#dc3545' : '#0dcaf0');

            new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: statuses,
                    datasets: [{ data: counts, backgroundColor: bgColors, borderWidth: 0 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, cutout: '70%' }
            });
        });
    </script>
}
