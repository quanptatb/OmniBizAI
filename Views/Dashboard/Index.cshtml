@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
}

<div class="page-header reveal d1">
  <div>
    <h1 class="page-title">Chào mừng trở lại, <span>Quản trị viên</span> 👋</h1>
    <p class="page-sub" id="time-display"></p>
  </div>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
  <div class="stat-card reveal d2">
    <div class="stat-header">
      <div><div class="stat-label">Nhân viên</div><div class="stat-value">124</div></div>
      <div class="stat-icon" style="background:var(--blue-bg); color:var(--blue)"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
    </div>
    <div class="stat-footer"><span class="stat-badge up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>+3</span><span class="stat-period">so với tháng trước</span></div>
  </div>
  <div class="stat-card reveal d3">
    <div class="stat-header">
      <div><div class="stat-label">Doanh thu</div><div class="stat-value">4.8 tỷ</div></div>
      <div class="stat-icon" style="background:var(--green-bg); color:var(--green)"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
    </div>
    <div class="stat-footer"><span class="stat-badge up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>+12.4%</span><span class="stat-period">so với tháng trước</span></div>
  </div>
  <div class="stat-card reveal d4">
    <div class="stat-header">
      <div><div class="stat-label">Đơn hàng</div><div class="stat-value">318</div></div>
      <div class="stat-icon" style="background:var(--amber-bg); color:var(--amber)"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></div>
    </div>
    <div class="stat-footer"><span class="stat-badge up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>+2.1%</span><span class="stat-period">so với tháng trước</span></div>
  </div>
  <div class="stat-card reveal d5">
    <div class="stat-header">
      <div><div class="stat-label">Khách hàng</div><div class="stat-value">2,047</div></div>
      <div class="stat-icon" style="background: rgba(244,114,182,0.08); color:var(--pink)"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
    </div>
    <div class="stat-footer"><span class="stat-badge up"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>+8.7%</span><span class="stat-period">so với tháng trước</span></div>
  </div>
</div>

<!-- Chart Section - NEW -->
<div class="chart-section reveal d6">
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-title">Doanh thu 7 ngày qua</div>
      <div class="chart-sub">So sánh với tuần trước</div>
    </div>
    <div class="chart-container">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-title">Lượt truy cập</div>
      <div class="chart-sub">Tuần này theo thiết bị</div>
    </div>
    <div class="chart-container">
      <canvas id="trafficChart"></canvas>
    </div>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-title">Đơn hàng theo danh mục</div>
      <div class="chart-sub">Phân bố tỷ lệ %</div>
    </div>
    <div class="chart-container">
      <canvas id="categoryChart"></canvas>
    </div>
  </div>
  <div class="chart-card">
    <div class="chart-header">
      <div class="chart-title">Nguồn khách hàng</div>
      <div class="chart-sub">Kênh thu hút</div>
    </div>
    <div class="chart-container">
      <canvas id="sourceChart"></canvas>
    </div>
  </div>
</div>

<!-- Bottom Grid -->
<div class="bottom-grid reveal d7">
  <div class="card">
    <div class="card-header">
      <div><div class="card-title">Đơn hàng gần đây</div><div class="card-sub">5 đơn mới nhất trong hệ thống</div></div>
      <a href="#" class="card-link">Xem tất cả <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg></a>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Sản phẩm</th><th>Giá trị</th><th>Trạng thái</th></tr></thead>
        <tbody>
          <tr><td><span class="order-id">#ORD-2841</span></td><td><div class="customer-cell"><div class="avi" style="background:rgba(96,165,250,0.12);color:var(--blue)">NL</div><div><div class="c-name">Nguyễn Lan Anh</div><div class="c-email">lan.anh@gmail.com</div></div></div></td><td>Laptop Dell XPS 15</td><td class="td-amount">32.500.000 ₫</td><td><span class="status s-done">Hoàn thành</span></td></tr>
          <tr><td><span class="order-id">#ORD-2840</span></td><td><div class="customer-cell"><div class="avi" style="background:rgba(167,139,250,0.12);color:#a78bfa">TM</div><div><div class="c-name">Trần Minh Tuấn</div><div class="c-email">minhtuan@outlook.com</div></div></div></td><td>iPhone 15 Pro Max</td><td>29.990.000 ₫</td><td><span class="status s-ship">Đang giao</span></td></tr>
          <tr><td><span class="order-id">#ORD-2839</span></td><td><div class="customer-cell"><div class="avi" style="background:var(--amber-bg);color:var(--amber)">PH</div><div><div class="c-name">Phạm Hoàng Nam</div><div class="c-email">hoangnam@yahoo.com</div></div></div></td><td>Samsung Galaxy S24</td><td>22.490.000 ₫</td><td><span class="status s-pend">Chờ duyệt</span></td></tr>
          <tr><td><span class="order-id">#ORD-2838</span></td><td><div class="customer-cell"><div class="avi" style="background:var(--red-bg);color:var(--red)">LT</div><div><div class="c-name">Lê Thị Hương</div><div class="c-email">thihuong@gmail.com</div></div></div></td><td>iPad Pro 12.9"</td><td>27.990.000 ₫</td><td><span class="status s-cancel">Đã huỷ</span></td></tr>
          <tr><td><span class="order-id">#ORD-2837</span></td><td><div class="customer-cell"><div class="avi" style="background:var(--green-bg);color:var(--green)">VK</div><div><div class="c-name">Võ Khánh Linh</div><div class="c-email">khanhlinh@vn.com</div></div></div></td><td>MacBook Air M3</td><td>34.990.000 ₫</td><td><span class="status s-done">Hoàn thành</span></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="side-col">
    <div class="card">
      <div class="card-header"><div><div class="card-title">Hiệu suất kho</div><div class="card-sub">Tháng 4 / 2026</div></div></div>
      <div class="perf-body">
        <div class="perf-item"><div class="perf-row"><span class="perf-name">Điện tử</span><span class="perf-val" style="color:var(--green)">82%</span></div><div class="track"><div class="fill" data-w="82%" style="background:linear-gradient(90deg,var(--green),#14b8a6)"></div></div></div>
        <div class="perf-item"><div class="perf-row"><span class="perf-name">Gia dụng</span><span class="perf-val" style="color:var(--blue)">65%</span></div><div class="track"><div class="fill" data-w="65%" style="background:linear-gradient(90deg,var(--blue),#818cf8)"></div></div></div>
        <div class="perf-item"><div class="perf-row"><span class="perf-name">Thời trang</span><span class="perf-val" style="color:var(--amber)">48%</span></div><div class="track"><div class="fill" data-w="48%" style="background:linear-gradient(90deg,var(--amber),#f97316)"></div></div></div>
        <div class="perf-item"><div class="perf-row"><span class="perf-name">Thực phẩm</span><span class="perf-val" style="color:#c084fc">91%</span></div><div class="track"><div class="fill" data-w="91%" style="background:linear-gradient(90deg,#a855f7,#ec4899)"></div></div></div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div><div class="card-title">Hoạt động</div><div class="card-sub">Nhật ký hôm nay</div></div></div>
      <div class="activity-body">
        <div class="timeline">
          <div class="tl-item"><div class="tl-dot green"></div><div class="tl-text"><strong>Lan Anh</strong> hoàn thành đơn <span class="highlight">#ORD-2841</span></div><div class="tl-time">5 phút trước</div></div>
          <div class="tl-item"><div class="tl-dot blue"></div><div class="tl-text"><strong>Admin</strong> thêm nhân viên mới: Đặng Hoà</div><div class="tl-time">18 phút trước</div></div>
          <div class="tl-item"><div class="tl-dot amber"></div><div class="tl-text">Kho <strong>Điện tử</strong> sắp hết hàng (còn 12 sp)</div><div class="tl-time">42 phút trước</div></div>
          <div class="tl-item"><div class="tl-dot red"></div><div class="tl-text">Đơn <span class="highlight">#ORD-2838</span> bị huỷ bởi khách hàng</div><div class="tl-time">1 giờ trước</div></div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  // Progress bars
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.fill[data-w]').forEach(el => {
        el.style.width = el.dataset.w;
      });
    }, 300);
  });

  // Revenue Chart (Line)
  const ctx1 = document.getElementById('revenueChart').getContext('2d');
  new Chart(ctx1, {
    type: 'line',
    data: {
      labels: ['21/4', '22/4', '23/4', '24/4', '25/4', '26/4', '27/4'],
      datasets: [{
        label: 'Doanh thu (triệu ₫)',
        data: [3.2, 3.8, 4.1, 3.5, 4.6, 5.2, 4.8],
        borderColor: '#6c63ff',
        backgroundColor: 'rgba(108, 99, 255, 0.05)',
        borderWidth: 2,
        pointBackgroundColor: '#8b85ff',
        pointBorderColor: '#0a0c12',
        pointRadius: 4,
        pointHoverRadius: 6,
        tension: 0.3,
        fill: true
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: '#5a6280', font: { size: 11 } } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      scales: {
        y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#5a6280' } },
        x: { grid: { display: false }, ticks: { color: '#5a6280' } }
      }
    }
  });

  // Category Chart (Doughnut)
  const ctx2 = document.getElementById('categoryChart').getContext('2d');
  new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: ['Điện tử', 'Gia dụng', 'Thời trang', 'Thực phẩm'],
      datasets: [{
        data: [42, 23, 18, 17],
        backgroundColor: ['#6c63ff', '#2dd4bf', '#fbbf24', '#f472b6'],
        borderWidth: 0,
        hoverOffset: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: '#5a6280', font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      cutout: '65%'
    }
  });

  // Traffic Chart (Bar)
  const ctx3 = document.getElementById('trafficChart').getContext('2d');
  new Chart(ctx3, {
    type: 'bar',
    data: {
      labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
      datasets: [{
        label: 'Mobile',
        data: [1200, 1900, 1500, 2100, 1800, 2500, 2200],
        backgroundColor: '#2dd4bf',
        borderRadius: 4
      }, {
        label: 'Desktop',
        data: [800, 1100, 900, 1400, 1200, 1600, 1300],
        backgroundColor: '#6c63ff',
        borderRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: '#5a6280', font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      scales: {
        y: { display: false, grid: { display: false } },
        x: { grid: { display: false }, ticks: { color: '#5a6280', font: { size: 11 } } }
      }
    }
  });

  // Source Chart (Doughnut)
  const ctx4 = document.getElementById('sourceChart').getContext('2d');
  new Chart(ctx4, {
    type: 'doughnut',
    data: {
      labels: ['Facebook', 'Google', 'Trực tiếp', 'Giới thiệu'],
      datasets: [{
        data: [35, 25, 20, 20],
        backgroundColor: ['#3b82f6', '#ef4444', '#6c63ff', '#2dd4bf'],
        borderWidth: 0,
        hoverOffset: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: '#5a6280', font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      cutout: '65%'
    }
  });
</script>
}