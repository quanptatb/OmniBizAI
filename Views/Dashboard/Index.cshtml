@model OmniBizAI.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumb"] = "<span>Tổng quan</span>";
}

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-sm-6 fade-in">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-file-lines"></i></div>
            <div class="stat-value">@Model.TotalOperationRequests</div>
            <div class="stat-label">Tổng yêu cầu</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-delay-1">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fa-solid fa-clock"></i></div>
            <div class="stat-value">@Model.PendingApprovals</div>
            <div class="stat-label">Chờ duyệt</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-delay-2">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="stat-value">@Model.OverdueTasks</div>
            <div class="stat-label">Quá hạn</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6 fade-in fade-in-delay-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-users"></i></div>
            <div class="stat-value">@Model.ActiveUsers</div>
            <div class="stat-label">Nhân sự</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-chart-area"></i> Biểu đồ yêu cầu 6 tháng</h5>
            </div>
            <div class="card-body-custom">
                <canvas id="trendChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-chart-pie"></i> Trạng thái yêu cầu</h5>
            </div>
            <div class="card-body-custom">
                <canvas id="statusChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-list-check"></i> Yêu cầu gần đây</h5>
                <a asp-controller="Operations" asp-action="Index" class="btn-outline-custom btn-sm" style="font-size:.75rem;padding:5px 14px;">Xem tất cả</a>
            </div>
            <div class="card-body-custom p-0">
                <table class="data-table">
                    <thead><tr><th class="ps-3">Mã</th><th>Tiêu đề</th><th>Trạng thái</th><th class="pe-3">Ngày tạo</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.RecentRequests)
                        {
                            <tr>
                                <td class="ps-3" style="font-weight:600;color:var(--apple-blue)">@item.RequestNo</td>
                                <td><div class="text-truncate" style="max-width:200px;" title="@item.Title">@item.Title</div></td>
                                <td>
                                    <span class="status-badge-soft @(item.Status == "Completed" ? "badge-on-track" : item.Status == "Pending" ? "badge-at-risk" : "badge-late")">
                                        <span class="status-dot"></span>@item.Status
                                    </span>
                                </td>
                                <td class="pe-3" style="color:var(--text-muted)">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                        @if (!Model.RecentRequests.Any())
                        {
                            <tr><td colspan="4" class="text-center py-4" style="color:var(--text-muted)">Chưa có dữ liệu</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-shield-halved"></i> Nhật ký hệ thống</h5>
                <a asp-controller="Audit" asp-action="Index" class="btn-outline-custom btn-sm" style="font-size:.75rem;padding:5px 14px;">Xem tất cả</a>
            </div>
            <div class="card-body-custom p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var audit in Model.RecentAudits)
                    {
                        <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center px-4 py-3" style="border-color:var(--divider)">
                            <div class="d-flex align-items-center">
                                <div style="width:32px;height:32px;background:rgba(0,102,204,.06);color:var(--apple-blue);border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;margin-right:12px;flex-shrink:0">
                                    <i class="fa-solid fa-history" style="font-size:.82rem"></i>
                                </div>
                                <div>
                                    <div style="font-size:.85rem;font-weight:600">@audit.UserName <span style="font-weight:400;color:var(--text-secondary)">đã @audit.Action</span></div>
                                    <small style="color:var(--text-muted)">@audit.EntityType</small>
                                </div>
                            </div>
                            <small style="color:var(--text-muted);white-space:nowrap"><i class="fa-regular fa-clock me-1"></i>@audit.OccurredAt.ToString("HH:mm dd/MM")</small>
                        </li>
                    }
                    @if (!Model.RecentAudits.Any())
                    {
                        <li class="list-group-item bg-transparent text-center py-4" style="color:var(--text-muted)">Chưa có nhật ký</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const months = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Month));
            const created = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Created));
            const completed = @Json.Serialize(Model.MonthlyTrend.Select(x => x.Completed));
            
            new Chart(document.getElementById('trendChart'), {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [
                        { label: 'Tạo mới', data: created, borderColor: '#0066cc', backgroundColor: 'rgba(0,102,204,0.06)', fill: true, tension: 0.4, borderWidth: 2, pointRadius: 3 },
                        { label: 'Hoàn thành', data: completed, borderColor: '#34c759', backgroundColor: 'transparent', tension: 0.4, borderWidth: 2, pointRadius: 3 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top', labels: { font: { family: 'Inter', size: 12 }, usePointStyle: true } } }, scales: { y: { beginAtZero: true, grid: { color: '#f0f0f0' } }, x: { grid: { display: false } } } }
            });

            const statuses = @Json.Serialize(Model.RequestsByStatus.Select(x => x.Status));
            const counts = @Json.Serialize(Model.RequestsByStatus.Select(x => x.Count));
            const bgColors = statuses.map(s => s === 'Completed' ? '#34c759' : s === 'Pending' ? '#ff9f0a' : s === 'Cancelled' ? '#ff3b30' : '#0066cc');

            new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: statuses,
                    datasets: [{ data: counts, backgroundColor: bgColors, borderWidth: 0 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { family: 'Inter', size: 12 }, usePointStyle: true, padding: 16 } } }, cutout: '72%' }
            });
        });
    </script>
}
