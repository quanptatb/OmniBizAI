@model OmniBizAI.ViewModels.EvaluationCreateViewModel
@{ ViewData["Title"] = "Tạo đánh giá"; ViewData["Breadcrumb"] = "<a href='/Evaluation' style='color:var(--apple-blue);text-decoration:none'>Đánh giá</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Tạo mới</span>"; }
<div class="content-card" style="max-width:560px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-star"></i> Tạo đánh giá hiệu suất</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Create">@Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nhân viên <span class="text-danger">*</span></label>
                    <select asp-for="UserId" class="form-select"><option value="">— Chọn nhân viên —</option>@foreach(var u in Model.Users){<option value="@u.Value">@u.Text</option>}</select>
                    <span asp-validation-for="UserId" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Kỳ đánh giá <span class="text-danger">*</span></label>
                    <select asp-for="EvaluationPeriodId" class="form-select"><option value="">— Chọn kỳ —</option>@foreach(var p in Model.Periods){<option value="@p.Value">@p.Text</option>}</select>
                    <span asp-validation-for="EvaluationPeriodId" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-4"><label class="form-label">Điểm tổng</label><input asp-for="TotalScore" type="number" step="0.1" class="form-control" placeholder="0-100" /></div>
                <div class="col-md-8"><label class="form-label">Xếp loại</label><input asp-for="Classification" class="form-control" placeholder="Xuất sắc / Tốt / Đạt..." /></div>
                <div class="col-12"><label class="form-label">Nhận xét</label><textarea asp-for="Comment" class="form-control" rows="3" placeholder="Nhận xét..."></textarea></div>
            </div>
            <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Tạo</button><a asp-action="Index" class="btn btn-light">Hủy</a></div>
        </form>
    </div>
</div>
