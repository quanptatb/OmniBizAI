@model OmniBizAI.ViewModels.MissionVisionEditViewModel
@{ ViewData["Title"] = "Chỉnh sửa"; ViewData["Breadcrumb"] = "<a href='/MissionVision' style='color:var(--apple-blue);text-decoration:none'>Sứ mệnh</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>"; }
<div class="content-card" style="max-width:560px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-pen"></i> Chỉnh sửa sứ mệnh / tầm nhìn</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Edit">@Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Loại</label>
                    <select asp-for="Type" class="form-select">
                        <option value="Vision">Tầm nhìn</option><option value="Mission">Sứ mệnh</option><option value="YearlyGoal">Mục tiêu chiến lược</option>
                    </select>
                </div>
                <div class="col-md-6"><label class="form-label">Năm mục tiêu</label><input asp-for="TargetYear" type="number" class="form-control" /></div>
                <div class="col-12"><label class="form-label">Nội dung <span class="text-danger">*</span></label><textarea asp-for="Content" class="form-control" rows="4"></textarea><span asp-validation-for="Content" class="text-danger" style="font-size:.78rem"></span></div>
                <div class="col-md-6"><label class="form-label">Mục tiêu tài chính</label><input asp-for="FinancialTarget" type="number" step="1000" class="form-control" /></div>
            </div>
            <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Lưu</button><a asp-action="Index" class="btn btn-light">Hủy</a></div>
        </form>
    </div>
</div>
