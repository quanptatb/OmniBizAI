@model OmniBizAI.Models.Entities.EmployeeProfile
@{
    ViewData["Title"] = "Link Employee Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="fw-bold text-primary">Link Employee Profile</h4>
                <p class="text-muted small">Link an existing User Account to an Employee Profile within a Department.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="UserId" class="form-label text-muted fw-semibold small">User Account</label>
                            <select asp-for="UserId" class="form-select rounded-3" asp-items="ViewBag.UserId">
                                <option value="">-- Select User --</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmployeeCode" class="form-label text-muted fw-semibold small">Employee Code</label>
                            <input asp-for="EmployeeCode" class="form-control rounded-3" />
                            <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label text-muted fw-semibold small">Department</label>
                            <select asp-for="DepartmentId" class="form-select rounded-3" asp-items="ViewBag.DepartmentId">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PositionName" class="form-label text-muted fw-semibold small">Position</label>
                            <input asp-for="PositionName" class="form-control rounded-3" />
                            <span asp-validation-for="PositionName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="JoinDate" class="form-label text-muted fw-semibold small">Join Date</label>
                            <input asp-for="JoinDate" type="date" class="form-control rounded-3" />
                            <span asp-validation-for="JoinDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
