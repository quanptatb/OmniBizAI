@model IEnumerable<OmniBizAI.Models.Entities.EmployeeProfile>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold mb-0 text-primary"><i class="bi bi-people"></i> Employees</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm px-4">
        + Link New Employee Profile
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>User Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Join Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 fw-semibold text-dark">@item.EmployeeCode</td>
                            <td class="fw-bold text-dark">@item.User?.FullName</td>
                            <td class="text-muted">@item.User?.Email</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary px-3 rounded-pill">@item.Department?.Name</span></td>
                            <td class="text-muted">@item.PositionName</td>
                            <td class="text-muted">@(item.JoinDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
