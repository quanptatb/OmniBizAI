@model OmniBizAI.ViewModels.WorkspaceCreateViewModel
@{ ViewData["Title"] = "Thêm Khu Vực"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0 text-gray-800">Thêm Khu Vực Làm Việc</h2>
    <a asp-action="Workspaces" class="btn btn-secondary btn-sm">← Quay lại</a>
</div>
<div class="row justify-content-center"><div class="col-lg-7">
<div class="card shadow">
    <div class="card-body">
        <form asp-action="CreateWorkspace" method="post">
            <div class="row mb-3">
                <div class="col-md-8"><label class="form-label fw-bold">Tên khu vực *</label><input asp-for="Name" class="form-control" placeholder="VD: Phòng A101, Xưởng Sản Xuất 1..." /><span asp-validation-for="Name" class="text-danger small"></span></div>
                <div class="col-md-4"><label class="form-label fw-bold">Loại *</label>
                    <select asp-for="Type" class="form-select">
                        <option value="Building">Tòa nhà</option><option value="Floor">Tầng</option>
                        <option value="Room">Phòng</option><option value="Zone">Khu vực</option>
                        <option value="Workshop">Xưởng</option><option value="Desk">Bàn làm việc</option>
                    </select>
                </div>
            </div>
            <div class="mb-3"><label class="form-label fw-bold">Vị trí / Địa chỉ</label><input asp-for="Location" class="form-control" placeholder="Tầng 2, Tòa nhà A..." /></div>
            <div class="row mb-3">
                <div class="col-md-6"><label class="form-label fw-bold">Diện tích (m²)</label><input asp-for="AreaSqm" type="number" step="0.1" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label fw-bold">Sức chứa (người)</label><input asp-for="Capacity" type="number" class="form-control" /></div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Thuộc khu vực cha</label>
                <select asp-for="ParentId" class="form-select">
                    <option value="">-- Không có (khu vực gốc) --</option>
                    @foreach (var p in Model.ParentWorkspaces) { <option value="@p.Value">@p.Text</option> }
                </select>
            </div>
            <div class="mb-4"><label class="form-label fw-bold">Ghi chú</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            <hr /><div class="text-end"><button type="submit" class="btn btn-info text-white px-4">Lưu Khu Vực</button></div>
        </form>
    </div>
</div>
</div></div>
