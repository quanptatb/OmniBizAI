@model OmniBizAI.ViewModels.WorkShiftCreateViewModel
@{ ViewData["Title"] = "Tạo Ca Làm Việc"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0 text-gray-800">Tạo Ca Làm Việc Mới</h2>
    <a asp-action="WorkShifts" class="btn btn-secondary btn-sm">← Quay lại</a>
</div>
<div class="row justify-content-center"><div class="col-lg-6">
<div class="card shadow">
    <div class="card-body">
        <form asp-action="CreateShift" method="post">
            <div class="mb-3"><label class="form-label fw-bold">Tên ca *</label><input asp-for="Name" class="form-control" placeholder="Ca sáng, Ca chiều, Ca đêm..." /><span asp-validation-for="Name" class="text-danger small"></span></div>
            <div class="row mb-3">
                <div class="col-md-6"><label class="form-label fw-bold">Giờ bắt đầu *</label><input asp-for="StartTime" type="time" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label fw-bold">Giờ kết thúc *</label><input asp-for="EndTime" type="time" class="form-control" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6"><label class="form-label fw-bold">Số giờ tiêu chuẩn</label><input asp-for="WorkHours" type="number" step="0.5" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label fw-bold">Loại ca</label>
                    <select asp-for="ShiftType" class="form-select">
                        <option value="Regular">Ca thường</option><option value="Overtime">Tăng ca</option><option value="Night">Ca đêm</option>
                    </select>
                </div>
            </div>
            <div class="mb-4"><label class="form-label fw-bold">Ghi chú</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            <hr /><div class="text-end"><button type="submit" class="btn btn-success px-4">Lưu Ca Làm Việc</button></div>
        </form>
    </div>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
