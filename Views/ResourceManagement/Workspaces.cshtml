@model List<OmniBizAI.ViewModels.WorkspaceItem>
@{
    ViewData["Title"] = "Cơ Sở Hạ Tầng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0 text-gray-800"><i class="fas fa-building text-info me-2"></i>Cơ Sở Hạ Tầng & Mặt Bằng</h2>
    <a asp-action="CreateWorkspace" class="btn btn-info btn-sm text-white"><i class="fas fa-plus me-1"></i>Thêm Khu Vực</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Filter -->
<div class="card shadow mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <input type="text" name="search" class="form-control form-control-sm" placeholder="Tìm theo tên, mã..." value="@ViewBag.Search" />
            </div>
            <div class="col-md-4">
                <select name="type" class="form-select form-select-sm">
                    <option value="">-- Tất cả loại --</option>
                    <option value="Building">Tòa nhà</option>
                    <option value="Floor">Tầng</option>
                    <option value="Room">Phòng</option>
                    <option value="Zone">Khu vực</option>
                    <option value="Workshop">Xưởng sản xuất</option>
                    <option value="Desk">Bàn làm việc</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-info btn-sm w-100">Lọc</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3">
    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="fas fa-building fa-3x mb-3 d-block text-gray-300"></i>
            Chưa có khu vực làm việc nào được đăng ký.
        </div>
    }
    @foreach (var ws in Model)
    {
        var iconClass = ws.Type switch {
            "Building" => "fa-building",
            "Floor" => "fa-layer-group",
            "Room" => "fa-door-open",
            "Zone" => "fa-map",
            "Workshop" => "fa-industry",
            "Desk" => "fa-desktop",
            _ => "fa-map-marker-alt"
        };
        <div class="col-md-4 col-lg-3">
            <div class="card shadow h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <div class="me-2 text-info"><i class="fas @iconClass fa-lg"></i></div>
                        <div>
                            <div class="fw-bold text-dark">@ws.Name</div>
                            <div class="text-muted small">@ws.Code</div>
                        </div>
                        <div class="ms-auto">
                            @if (ws.Status == "Active") { <span class="badge bg-success">Đang dùng</span> }
                            else if (ws.Status == "Maintenance") { <span class="badge bg-warning text-dark">Bảo trì</span> }
                            else { <span class="badge bg-secondary">Ngưng</span> }
                        </div>
                    </div>
                    <div class="text-muted small">
                        <div><i class="fas fa-tag me-1"></i>@ws.Type</div>
                        @if (!string.IsNullOrEmpty(ws.Location)) { <div><i class="fas fa-map-marker-alt me-1"></i>@ws.Location</div> }
                        @if (ws.AreaSqm.HasValue) { <div><i class="fas fa-ruler-combined me-1"></i>@ws.AreaSqm m²</div> }
                        @if (ws.Capacity.HasValue) { <div><i class="fas fa-users me-1"></i>Sức chứa: @ws.Capacity người</div> }
                    </div>
                    @if (!string.IsNullOrEmpty(ws.Notes))
                    {
                        <div class="mt-2 text-muted small fst-italic border-top pt-2">@ws.Notes</div>
                    }
                </div>
            </div>
        </div>
    }
</div>
