@model List<OmniBizAI.ViewModels.EmployeeCertificateItem>
@{
    ViewData["Title"] = "Chứng Chỉ & Năng Lực";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0 text-gray-800"><i class="fas fa-certificate text-warning me-2"></i>Chứng Chỉ & Năng Lực Nhân Viên</h2>
    <a asp-action="AddCertificate" class="btn btn-warning btn-sm"><i class="fas fa-plus me-1"></i>Thêm Chứng Chỉ</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Filter -->
<div class="card shadow mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="search" class="form-control form-control-sm" placeholder="Tìm theo tên chứng chỉ, nhân viên..." value="@ViewBag.Search" />
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select form-select-sm">
                    <option value="">-- Tất cả loại --</option>
                    <option value="Professional">Chuyên môn</option>
                    <option value="Safety">An toàn lao động</option>
                    <option value="Technical">Kỹ thuật</option>
                    <option value="Language">Ngoại ngữ</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check ms-2">
                    <input class="form-check-input" type="checkbox" name="expiredOnly" value="true" id="expiredOnly" @(ViewBag.ExpiredOnly == true ? "checked" : "") />
                    <label class="form-check-label text-danger" for="expiredOnly">Chỉ hiện đã hết hạn</label>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-warning btn-sm w-100">Lọc</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nhân viên</th>
                        <th>Chứng chỉ</th>
                        <th>Tổ chức cấp</th>
                        <th>Ngày cấp</th>
                        <th>Hết hạn</th>
                        <th>Loại</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-5">Chưa có chứng chỉ nào được đăng ký.</td></tr>
                    }
                    @foreach (var c in Model)
                    {
                        <tr class="@(c.IsExpired ? "table-danger" : c.IsExpiringSoon ? "table-warning" : "")">
                            <td class="fw-bold">@c.UserName</td>
                            <td>
                                <div class="fw-bold">@c.CertificateName</div>
                                @if (!string.IsNullOrEmpty(c.CertificateNumber))
                                {
                                    <div class="text-muted small"><code>@c.CertificateNumber</code></div>
                                }
                            </td>
                            <td class="text-muted small">@c.IssuingOrganization</td>
                            <td class="small">@c.IssuedDate?.ToString("dd/MM/yyyy")</td>
                            <td class="small @(c.IsExpired ? "text-danger fw-bold" : c.IsExpiringSoon ? "text-warning fw-bold" : "")">
                                @if (c.IsExpired) { <i class="fas fa-times-circle"></i> }
                                else if (c.IsExpiringSoon) { <i class="fas fa-exclamation-circle"></i> }
                                @c.ExpiryDate?.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                <span class="badge bg-secondary">
                                    @switch(c.Category){
                                        case "Professional": @("Chuyên môn") break;
                                        case "Safety": @("An toàn LĐ") break;
                                        case "Technical": @("Kỹ thuật") break;
                                        case "Language": @("Ngoại ngữ") break;
                                        default: @c.Category break;
                                    }
                                </span>
                            </td>
                            <td>
                                @if (c.IsExpired) { <span class="badge bg-danger">Hết hạn</span> }
                                else if (c.IsExpiringSoon) { <span class="badge bg-warning text-dark">Sắp hết hạn</span> }
                                else { <span class="badge bg-success">Còn hiệu lực</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
