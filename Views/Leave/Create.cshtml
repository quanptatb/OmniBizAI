@model OmniBizAI.ViewModels.LeaveCreateViewModel
@{ ViewData["Title"] = "Xin nghỉ phép"; ViewData["Breadcrumb"] = "<a href='/Leave' style='color:var(--apple-blue);text-decoration:none'>Nghỉ phép</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Tạo đơn</span>"; }

<div class="content-card" style="max-width:520px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-calendar-plus"></i> Xin nghỉ phép</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="Create">@Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Loại nghỉ phép <span class="text-danger">*</span></label>
                    <select asp-for="LeaveType" class="form-select">
                        @foreach (var lt in EnumHelper.GetSelectList<LeaveType>())
                        { <option value="@lt.Value">@lt.Text</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Từ ngày <span class="text-danger">*</span></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Đến ngày <span class="text-danger">*</span></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Lý do</label>
                    <textarea asp-for="Reason" class="form-control" rows="3" placeholder="Nhập lý do xin nghỉ..."></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-paper-plane me-1"></i>Gửi đơn</button>
                <a asp-action="Index" class="btn btn-light">Hủy</a>
            </div>
        </form>
    </div>
</div>
