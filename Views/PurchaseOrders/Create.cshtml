@model OmniBizAI.ViewModels.PurchaseOrderCreateViewModel
@{ ViewData["Title"] = "Tạo đơn mua hàng"; ViewData["Breadcrumb"] = "<span>Tài chính</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/PurchaseOrders' style='color:var(--apple-blue);text-decoration:none'>PO</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Tạo mới</span>"; }
<div class="content-card" style="max-width:780px"><div class="card-header-custom"><h5><i class="fa-solid fa-file-invoice"></i> Tạo đơn mua hàng</h5></div><div class="card-body-custom">
    <form method="post" asp-action="Create">@Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Nhà cung cấp <span class="text-danger">*</span></label><select asp-for="VendorId" class="form-input"><option value="">-- Chọn NCC --</option>@foreach(var v in Model.Vendors){<option value="@v.Value">@v.Text</option>}</select><span asp-validation-for="VendorId" class="text-danger" style="font-size:.78rem"></span></div>
            <div class="col-md-3"><label class="form-label">Ngày đặt</label><input asp-for="OrderDate" class="form-input" type="date" /></div>
            <div class="col-md-3"><label class="form-label">Từ đề xuất</label><select asp-for="ProcurementRequestId" class="form-input"><option value="">-- Không --</option>@foreach(var p in Model.ProcurementRequests){<option value="@p.Value">@p.Text</option>}</select></div>
        </div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn-primary-custom"><i class="fa-solid fa-check me-1"></i>Tạo PO</button><a asp-action="Index" class="btn-outline-custom">Hủy</a></div>
    </form>
</div></div>
