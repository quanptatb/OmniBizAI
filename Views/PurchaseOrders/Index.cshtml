@model OmniBizAI.ViewModels.PurchaseOrderListViewModel
@{ ViewData["Title"] = "Đơn mua hàng"; ViewData["Breadcrumb"] = "<span>Tài chính</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Đơn mua hàng</span>"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4 class="page-title mb-1">Đơn mua hàng (PO)</h4><p class="text-muted mb-0" style="font-size:.82rem">@Model.TotalCount đơn</p></div>
    <a asp-action="Create" class="btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>Tạo PO</a>
</div>
<div class="content-card"><div class="card-body-custom p-0">
    <table class="data-table">
        <thead><tr><th class="ps-3">Mã PO</th><th>Nhà cung cấp</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Số dòng</th><th>Trạng thái</th><th class="pe-3"></th></tr></thead>
        <tbody>
            @foreach (var po in Model.Items) {
                <tr>
                    <td class="ps-3"><a asp-action="Details" asp-route-id="@po.Id" style="font-weight:600;color:var(--apple-blue);text-decoration:none">@po.OrderNo</a></td>
                    <td style="font-weight:500">@po.VendorName</td><td style="font-size:.82rem">@po.OrderDate.ToString("dd/MM/yyyy")</td>
                    <td style="font-weight:500">@(po.TotalAmount?.ToString("N0") ?? "—") ₫</td><td>@po.LineCount</td>
                    <td><span class="status-badge-soft @(po.Status == "Completed" ? "badge-on-track" : po.Status == "Draft" ? "badge-at-risk" : "badge-at-risk")"><span class="status-dot"></span>@po.Status</span></td>
                    <td class="pe-3"><a asp-action="Details" asp-route-id="@po.Id" class="btn-outline-custom btn-sm" style="font-size:.72rem;padding:4px 12px"><i class="fa-solid fa-eye"></i></a></td>
                </tr>
            }
            @if (!Model.Items.Any()) { <tr><td colspan="7" class="text-center py-4" style="color:var(--text-muted)">Chưa có đơn mua hàng</td></tr> }
        </tbody>
    </table>
</div></div>
