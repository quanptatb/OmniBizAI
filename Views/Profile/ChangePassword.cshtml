@model OmniBizAI.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Đổi mật khẩu"; ViewData["Breadcrumb"] = "<a href='/Profile' style='color:var(--apple-blue);text-decoration:none'>Hồ sơ</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Đổi mật khẩu</span>"; }

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom"><h5><i class="fa-solid fa-key"></i> Đổi mật khẩu</h5></div>
            <div class="card-body-custom">
                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.82rem"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div style="position:relative">
                            <input asp-for="CurrentPassword" type="password" class="form-control" id="curPw" style="padding-right:42px" autocomplete="current-password" />
                            <button type="button" class="btn btn-sm" onclick="togglePw('curPw', this)" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:.78rem"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div style="position:relative">
                            <input asp-for="NewPassword" type="password" class="form-control" id="newPw" style="padding-right:42px" autocomplete="new-password" oninput="checkStrength()" />
                            <button type="button" class="btn btn-sm" onclick="togglePw('newPw', this)" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <div style="height:4px;border-radius:2px;margin-top:6px;background:var(--divider);overflow:hidden"><div id="pwBar" style="height:100%;border-radius:2px;transition:width .3s,background .3s;width:0"></div></div>
                        <small class="text-muted" id="pwLabel" style="font-size:.68rem"></small>
                        <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.78rem"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div style="position:relative">
                            <input asp-for="ConfirmPassword" type="password" class="form-control" id="cfPw" style="padding-right:42px" autocomplete="new-password" />
                            <button type="button" class="btn btn-sm" onclick="togglePw('cfPw', this)" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted)">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.78rem"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill" style="font-weight:600;border-radius:10px"><i class="fa-solid fa-check me-1"></i>Đổi mật khẩu</button>
                        <a asp-action="Index" class="btn btn-light" style="border-radius:10px">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePw(id, btn) {
    const inp = document.getElementById(id);
    const ico = btn.querySelector('i');
    if (inp.type === 'password') { inp.type = 'text'; ico.className = 'fa-solid fa-eye-slash'; }
    else { inp.type = 'password'; ico.className = 'fa-solid fa-eye'; }
}

function checkStrength() {
    const pw = document.getElementById('newPw').value;
    const bar = document.getElementById('pwBar');
    const label = document.getElementById('pwLabel');
    let score = 0;
    if (pw.length >= 3) score++;
    if (pw.length >= 6) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;
    const levels = [
        { w:'20%',bg:'var(--danger)',t:'Rất yếu' },{ w:'40%',bg:'var(--danger)',t:'Yếu' },
        { w:'60%',bg:'var(--warning)',t:'Trung bình' },{ w:'80%',bg:'var(--apple-blue)',t:'Khá' },
        { w:'100%',bg:'var(--success)',t:'Mạnh' }
    ];
    const lvl = levels[Math.min(score,4)];
    bar.style.width = pw.length ? lvl.w : '0';
    bar.style.background = lvl.bg;
    label.textContent = pw.length ? lvl.t : '';
}
</script>
}
