@model OmniBizAI.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Đổi mật khẩu"; ViewData["Breadcrumb"] = "<a href='/Profile' style='color:var(--apple-blue);text-decoration:none'>Hồ sơ</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Đổi mật khẩu</span>"; }
<div class="content-card" style="max-width:480px"><div class="card-header-custom"><h5><i class="fa-solid fa-key"></i> Đổi mật khẩu</h5></div><div class="card-body-custom">
    <form method="post" asp-action="ChangePassword">@Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:.82rem"></div>
        <div class="mb-3"><label class="form-label">Mật khẩu hiện tại <span class="text-danger">*</span></label><input asp-for="CurrentPassword" type="password" class="form-input" /><span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:.78rem"></span></div>
        <div class="mb-3"><label class="form-label">Mật khẩu mới <span class="text-danger">*</span></label><input asp-for="NewPassword" type="password" class="form-input" /><span asp-validation-for="NewPassword" class="text-danger" style="font-size:.78rem"></span></div>
        <div class="mb-3"><label class="form-label">Xác nhận mật khẩu mới <span class="text-danger">*</span></label><input asp-for="ConfirmPassword" type="password" class="form-input" /><span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.78rem"></span></div>
        <div class="d-flex gap-2 mt-4"><button type="submit" class="btn-primary-custom"><i class="fa-solid fa-check me-1"></i>Đổi mật khẩu</button><a asp-action="Index" class="btn-outline-custom">Hủy</a></div>
    </form>
</div></div>
