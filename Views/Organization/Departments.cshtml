@{
    ViewData["Title"] = "Phòng ban";
}

<section class="page-header">
    <div><span class="eyebrow"><i class="bi bi-houses"></i> Organization chart</span><h1>Phòng ban</h1><p>Quản lý cây phòng ban, manager, budget limit và phạm vi dữ liệu theo vai trò.</p></div>
    <button class="btn-app" data-modal-target="addDeptModal"><i class="bi bi-plus-circle"></i> Thêm phòng ban</button>
</section>

<div class="modal-overlay" id="addDeptModal">
    <div class="crud-modal">
        <div class="modal-header">
            <h3><i class="bi bi-diagram-3"></i> Thêm phòng ban mới</h3>
            <button class="btn-close" data-modal-close>&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Tên phòng ban *</label>
                <input type="text" class="form-control" placeholder="Ví dụ: Marketing" />
            </div>
            <div class="form-grid">
                <div class="form-group">
                    <label>Phòng ban cha (Tùy chọn)</label>
                    <select class="form-select">
                        <option>-- Chọn --</option>
                        <option>Board of Directors</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Manager / Trưởng phòng</label>
                    <select class="form-select">
                        <option>-- Chọn nhân viên --</option>
                        <option>Nguyễn Minh Anh</option>
                    </select>
                </div>
            </div>
            <div class="form-group mt-2">
                <label>Budget Limit / Giới hạn ngân sách</label>
                <input type="text" class="form-control" placeholder="Ví dụ: 500,000,000" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-ghost" data-modal-close>Hủy</button>
            <button class="btn-app" data-demo-toast><i class="bi bi-save"></i> Tạo phòng ban</button>
        </div>
    </div>
</div>

<section class="three-col-grid">
    <article class="module-card"><i class="bi bi-megaphone"></i><h3>Marketing</h3><p>12 nhân viên, budget limit 500 triệu, manager Nguyễn Minh Anh.</p></article>
    <article class="module-card"><i class="bi bi-briefcase"></i><h3>Sales</h3><p>18 nhân viên, KPI pipeline đang đạt 68% target.</p></article>
    <article class="module-card"><i class="bi bi-cpu"></i><h3>IT</h3><p>9 nhân viên, uptime KPI đạt 99.4%, software budget 80%.</p></article>
</section>

<article class="panel mt-3">
    <div class="panel-header"><h2 class="panel-title"><i class="bi bi-diagram-3"></i> Cấu trúc tổ chức</h2></div>
    <div class="panel-body timeline">
        <div class="timeline-step"><span>HQ</span><div><strong>OmniBizAI Company</strong><div class="text-muted">Director scope: toàn công ty</div></div></div>
        <div class="timeline-step"><span>M</span><div><strong>Marketing</strong><div class="text-muted">BudgetLimit 500,000,000 • Manager data scope</div></div></div>
        <div class="timeline-step"><span>S</span><div><strong>Sales</strong><div class="text-muted">Pipeline, revenue và KPI team</div></div></div>
        <div class="timeline-step"><span>IT</span><div><strong>IT</strong><div class="text-muted">System uptime, software cost và AI integration</div></div></div>
    </div>
</article>
