@model OmniBizAI.ViewModels.OrganizationUnitListViewModel
@{
    ViewData["Title"] = "Cơ cấu Tổ chức";
    ViewData["Breadcrumb"] = "<span>Tổ chức</span> <i class=\"fa-solid fa-chevron-right mx-2 text-muted fs-7\"></i> <span class=\"text-primary fw-bold\">Phòng ban</span>";
}

<div class="card glass-card">
    <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center py-3">
        <h5 class="card-title mb-0"><i class="fa-solid fa-sitemap me-2 text-primary"></i>Cây phòng ban</h5>
        <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus me-2"></i>Thêm phòng ban</a>
    </div>
    <div class="card-body p-4">
        @if (!Model.Tree.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fa-solid fa-building fa-4x mb-3 opacity-50"></i>
                <h5 class="text-muted">Chưa có phòng ban nào</h5>
                <p class="text-muted small">Bấm "Thêm phòng ban" để bắt đầu.</p>
            </div>
        }

        @foreach (var root in Model.Tree)
        {
            @await Html.PartialAsync("_OrgUnitNode", root)
        }
    </div>
</div>
