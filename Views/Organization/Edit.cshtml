@model OmniBizAI.ViewModels.OrgUnitEditViewModel
@{
    ViewData["Title"] = "Chỉnh sửa phòng ban";
    ViewData["Breadcrumb"] = "<a href='/Organization' style='color:var(--apple-blue);text-decoration:none'>Phòng ban</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Chỉnh sửa</span>";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="content-card animate-fade-in">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-building-circle-check"></i> Chỉnh sửa phòng ban</h5>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-light border" style="border-radius:8px">
                    <i class="fa-solid fa-eye me-1"></i>Chi tiết
                </a>
            </div>
            <div class="card-body-custom">
                @if (ViewData.ModelState.Values.Any(v => v.Errors.Any()))
                {
                    <div style="background:rgba(255,59,48,.05);border:1px solid rgba(255,59,48,.12);border-radius:var(--r-sm);padding:12px 16px;margin-bottom:20px">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div style="font-size:.82rem;color:var(--danger)"><i class="fa-solid fa-circle-exclamation me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label fw-bold">Mã phòng ban <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold">Tên phòng ban <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ParentId" class="form-label fw-bold">Thuộc đơn vị cha</label>
                            <select asp-for="ParentId" class="form-select">
                                <option value="">— Cấp cao nhất —</option>
                                @foreach (var opt in Model.ParentOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Value == Model.ParentId?.ToString())">@opt.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ManagerUserId" class="form-label fw-bold">Trưởng bộ phận</label>
                            <select asp-for="ManagerUserId" class="form-select">
                                <option value="">— Chưa chỉ định —</option>
                                @foreach (var opt in Model.UserOptions)
                                {
                                    <option value="@opt.Value" selected="@(opt.Value == Model.ManagerUserId?.ToString())">@opt.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <select asp-for="IsActive" class="form-select">
                                <option value="true" selected="@Model.IsActive">Hoạt động</option>
                                <option value="false" selected="@(!Model.IsActive)">Ngừng hoạt động</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between pt-3" style="border-top:1px solid var(--divider)">
                        <div>
                            <button type="button" class="btn btn-outline-danger btn-sm" style="border-radius:8px" onclick="confirmDelete()">
                                <i class="fa-solid fa-trash me-1"></i>Xóa phòng ban
                            </button>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-light border px-4" style="border-radius:10px">Hủy</a>
                            <button type="submit" class="btn btn-primary px-4" style="border-radius:10px;font-weight:600">
                                <i class="fa-solid fa-check me-2"></i>Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </form>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" id="deleteForm">
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function confirmDelete() {
    if (confirm('Bạn có chắc chắn muốn xóa phòng ban này?\n\nLưu ý: Phòng ban phải không có nhân viên hoặc đơn vị con.')) {
        document.getElementById('deleteForm').submit();
    }
}
</script>
}
