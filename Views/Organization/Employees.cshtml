@{
    ViewData["Title"] = "Nhân viên";
}

<section class="page-header">
    <div><span class="eyebrow"><i class="bi bi-people"></i> HR basic</span><h1>Hồ sơ nhân viên</h1><p>Quản lý employee code, phòng ban, vị trí, quản lý trực tiếp, user liên kết và trạng thái làm việc.</p></div>
    <button class="btn-app" data-demo-toast><i class="bi bi-person-plus"></i> Thêm nhân viên</button>
</section>

<section class="metric-grid">
    <article class="metric-card"><span class="metric-icon"><i class="bi bi-people-fill"></i></span><div class="metric-label">Nhân viên active</div><div class="metric-value">72</div><div class="metric-note">6 phòng ban</div></article>
    <article class="metric-card"><span class="metric-icon"><i class="bi bi-person-badge"></i></span><div class="metric-label">Manager</div><div class="metric-value">11</div><div class="metric-note">Có quyền duyệt</div></article>
    <article class="metric-card"><span class="metric-icon"><i class="bi bi-person-check"></i></span><div class="metric-label">Có user login</div><div class="metric-value">68</div><div class="metric-note text-success">94%</div></article>
    <article class="metric-card"><span class="metric-icon"><i class="bi bi-person-dash"></i></span><div class="metric-label">Inactive</div><div class="metric-value">4</div><div class="metric-note">Giữ lịch sử</div></article>
</section>

