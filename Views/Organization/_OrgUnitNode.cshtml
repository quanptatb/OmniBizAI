@model OmniBizAI.ViewModels.OrgUnitTreeItem

<div class="tree-node @(Model.Level == 0 ? "tree-node-root" : "")">
    <div class="tree-node-item d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="icon-shape bg-primary text-white" style="width:40px;height:40px;border-radius:10px;font-size:.85rem;">
                <i class="fa-solid @(Model.Level == 0 ? "fa-building" : Model.Level == 1 ? "fa-layer-group" : "fa-users")"></i>
            </div>
            <div>
                <div class="fw-bold">@Model.Name <span class="text-muted fw-normal small">(#@Model.Code)</span></div>
                <div class="d-flex gap-3 text-muted small mt-1">
                    <span><i class="fa-solid fa-user-tie me-1"></i>@(Model.ManagerName ?? "Chưa gán")</span>
                    <span><i class="fa-solid fa-users me-1"></i>@Model.EmployeeCount nhân viên</span>
                </div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary") rounded-pill">@(Model.IsActive ? "Hoạt động" : "Ngưng")</span>
            @if (Model.IsActive)
            {
                <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn ngưng hoạt động phòng ban này?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Ngưng hoạt động"><i class="fa-solid fa-power-off"></i></button>
                </form>
            }
        </div>
    </div>

    @if (Model.Children.Any())
    {
        @foreach (var child in Model.Children)
        {
            @await Html.PartialAsync("_OrgUnitNode", child)
        }
    }
</div>
