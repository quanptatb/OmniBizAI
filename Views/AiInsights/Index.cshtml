@model List<OmniBizAI.ViewModels.AiInsightListItem>
@{
    ViewData["Title"] = "AI Copilot";
    ViewData["Breadcrumb"] = "<span>AI</span> <i class=\"fa-solid fa-chevron-right mx-2\" style=\"font-size:.6rem;color:var(--text-muted)\"></i> <span>Copilot</span>";
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="ai-panel">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="icon-shape" style="width:44px;height:44px;border-radius:var(--r-md);background:var(--apple-blue);color:#fff">
                    <i class="fa-solid fa-robot" style="font-size:1.1rem"></i>
                </div>
                <div>
                    <h5 style="font-weight:600;margin:0">AI Copilot</h5>
                    <p style="color:var(--text-secondary);font-size:.82rem;margin:0">Phân tích dữ liệu vận hành và đưa ra đề xuất thông minh</p>
                </div>
            </div>

            <form id="aiAskForm">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Câu hỏi phân tích</label>
                    <textarea id="aiQuestion" class="form-control" rows="4" placeholder="VD: Phân tích tình hình yêu cầu vận hành trong tháng này. Có rủi ro gì cần chú ý?" maxlength="1000"></textarea>
                    <div class="d-flex justify-content-between mt-1">
                        <small style="color:var(--text-muted)">Tối đa 1000 ký tự</small>
                        <small style="color:var(--text-muted)" id="charCount">0/1000</small>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2" style="font-weight:500">
                    <i class="fa-solid fa-paper-plane me-1"></i>Gửi phân tích
                </button>
            </form>

            <div id="aiLoading" class="text-center py-4" style="display:none;color:var(--text-muted)">
                <div class="ai-spinner me-2"></div>
                <span>AI đang phân tích dữ liệu...</span>
            </div>

            <div id="aiAnswerArea"></div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="content-card">
            <div class="card-header-custom">
                <h5><i class="fa-solid fa-history"></i> Lịch sử phân tích</h5>
                <span class="badge" style="background:var(--apple-blue);color:#fff">@Model.Count kết quả</span>
            </div>
            <div class="card-body-custom p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5" style="color:var(--text-muted)">
                        <i class="fa-solid fa-robot fa-3x mb-3 opacity-50 d-block"></i>
                        <h5 style="font-weight:600;color:var(--text-secondary)">Chưa có kết quả phân tích</h5>
                        <p style="font-size:.85rem">Hãy đặt câu hỏi cho AI để bắt đầu.</p>
                    </div>
                }

                @foreach (var insight in Model)
                {
                    <div style="padding:20px 24px;border-bottom:1px solid var(--divider)">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                @{
                                    var riskCls = insight.RiskLevel.ToLower();
                                }
                                <span class="ai-risk-badge @riskCls">
                                    <i class="fa-solid @(riskCls == "high" ? "fa-fire" : riskCls == "medium" ? "fa-exclamation-triangle" : "fa-shield-halved")"></i>
                                    @insight.RiskLevel
                                </span>
                                <span class="badge" style="background:var(--parchment);color:var(--text-secondary);border:1px solid var(--divider)">@insight.ContextType</span>
                            </div>
                            <small style="color:var(--text-muted)"><i class="fa-regular fa-clock me-1"></i>@insight.CreatedAt.ToString("HH:mm dd/MM/yyyy")</small>
                        </div>
                        <p style="font-weight:500;color:var(--apple-blue);margin-bottom:4px;font-size:.88rem"><i class="fa-solid fa-question-circle me-1"></i>@insight.Question</p>
                        <p style="margin-bottom:4px;font-size:.85rem">@insight.Summary</p>
                        @if (!string.IsNullOrEmpty(insight.Recommendation))
                        {
                            <div style="padding:10px 14px;background:var(--parchment);border-radius:var(--r-sm);font-size:.82rem;margin-top:6px;white-space:pre-line">@insight.Recommendation</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const textarea = document.getElementById('aiQuestion');
        const counter = document.getElementById('charCount');
        if (textarea && counter) {
            textarea.addEventListener('input', () => counter.textContent = `${textarea.value.length}/1000`);
        }
    </script>
}
