@model OmniBizAI.ViewModels.KpiCreateViewModel
@{ ViewData["Title"] = "Tạo KPI mới"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3"><i class="bi bi-plus-circle me-2"></i>Tạo KPI mới</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<form asp-action="Create" method="post">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent"><h5 class="mb-0">Thông tin KPI</h5></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label">Tên KPI <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="VD: Doanh thu bán hàng tháng" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Unit" class="form-label">Đơn vị đo <span class="text-danger">*</span></label>
                    <input asp-for="Unit" class="form-control" placeholder="VNĐ, %, lượt, ..." />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-3">
                    <label asp-for="OwnerType" class="form-label">Loại</label>
                    <select asp-for="OwnerType" class="form-select">
                        <option value="Company">Công ty</option>
                        <option value="Department">Phòng ban</option>
                        <option value="User">Cá nhân</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="MeasureType" class="form-label">Phương thức đo</label>
                    <select asp-for="MeasureType" class="form-select">
                        <option value="Quantitative">Định lượng</option>
                        <option value="Qualitative">Định tính</option>
                        <option value="Behavioral">Hành vi</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="PropertyType" class="form-label">Tính chất</label>
                    <select asp-for="PropertyType" class="form-select">
                        <option value="Growth">Tăng trưởng</option>
                        <option value="Stability">Ổn định</option>
                        <option value="Reduction">Giảm thiểu</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="PeriodType" class="form-label">Tần suất</label>
                    <select asp-for="PeriodType" class="form-select">
                        <option value="Monthly">Hàng tháng</option>
                        <option value="Quarterly">Hàng quý</option>
                        <option value="Yearly">Hàng năm</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="OrganizationUnitId" class="form-label">Phòng ban</label>
                    <select asp-for="OrganizationUnitId" class="form-select"><option value="">-- Chọn --</option>@foreach (var d in Model.Departments) { <option value="@d.Value">@d.Text</option> }</select>
                </div>
                <div class="col-md-4">
                    <label asp-for="OkrObjectiveId" class="form-label">Gắn OKR</label>
                    <select asp-for="OkrObjectiveId" class="form-select"><option value="">-- Không --</option>@foreach (var o in Model.OkrObjectives) { <option value="@o.Value">@o.Text</option> }</select>
                </div>
                <div class="col-md-4">
                    <label asp-for="EvaluationPeriodId" class="form-label">Kỳ đánh giá</label>
                    <select asp-for="EvaluationPeriodId" class="form-select"><option value="">-- Chọn --</option>@foreach (var p in Model.Periods) { <option value="@p.Value">@p.Text</option> }</select>
                </div>
            </div>
        </div>
    </div>

    <!-- Target Settings -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-transparent"><h5 class="mb-0"><i class="bi bi-bullseye me-2"></i>Chỉ tiêu & Lịch check-in</h5></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><label asp-for="TargetValue" class="form-label">Giá trị mục tiêu</label><input asp-for="TargetValue" type="number" step="0.01" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="PassThreshold" class="form-label">Ngưỡng đạt</label><input asp-for="PassThreshold" type="number" step="0.01" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="FailThreshold" class="form-label">Ngưỡng không đạt</label><input asp-for="FailThreshold" type="number" step="0.01" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="CheckInFrequencyDays" class="form-label">Tần suất check-in (ngày)</label><input asp-for="CheckInFrequencyDays" type="number" class="form-control" placeholder="7" /></div>
                <div class="col-md-3"><label asp-for="PeriodStart" class="form-label">Ngày bắt đầu</label><input asp-for="PeriodStart" type="date" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="PeriodEnd" class="form-label">Ngày kết thúc</label><input asp-for="PeriodEnd" type="date" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="DeadlineTime" class="form-label">Giờ deadline</label><input asp-for="DeadlineTime" type="time" class="form-control" /></div>
                <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="ReminderEnabled" class="form-check-input" /><label asp-for="ReminderEnabled" class="form-check-label">Bật nhắc nhở</label></div></div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Tạo KPI</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>
