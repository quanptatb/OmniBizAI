@model OmniBizAI.ViewModels.BudgetListViewModel
@{
    ViewData["Title"] = "Quản lý Ngân sách";
    ViewData["Breadcrumb"] = "<a href='/Finance' style='color:var(--apple-blue);text-decoration:none'>Tài chính</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Ngân sách</span>";
}

<!-- Stats -->
@{ var active = Model.Items.Count(b => b.Status == "Active"); var warning = Model.Items.Count(b => b.IsWarning); var danger = Model.Items.Count(b => b.IsDanger); }
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-piggy-bank"></i></div><div class="stat-value">@Model.Items.Count</div><div class="stat-label">Tổng ngân sách</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div><div class="stat-value">@active</div><div class="stat-label">Đang hoạt động</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon orange"><i class="fa-solid fa-triangle-exclamation"></i></div><div class="stat-value">@warning</div><div class="stat-label">Cần lưu ý (&gt;70%)</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon red"><i class="fa-solid fa-fire"></i></div><div class="stat-value">@danger</div><div class="stat-label">Cảnh báo (&gt;90%)</div></div></div>
</div>

<div class="card content-card">
    <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center py-3">
        <h5 class="card-title mb-0"><i class="fa-solid fa-wallet me-2 text-primary"></i>Ngân sách theo phòng ban</h5>
        <a asp-action="BudgetCreate" class="btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>Tạo ngân sách</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">Tên ngân sách</th>
                        <th>Phòng ban</th>
                        <th>Tổng ngân sách</th>
                        <th>Đã sử dụng</th>
                        <th>Tiến độ</th>
                        <th>Trạng thái</th>
                        <th>Kỳ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Items)
                    {
                        var pct = b.UsagePercent;
                        var barColor = b.IsDanger ? "bg-danger" : b.IsWarning ? "bg-warning" : "bg-success";
                        var rowClass = b.IsDanger ? "style='background:rgba(255,59,48,.03)'" : "";
                        <tr @Html.Raw(rowClass)>
                            <td class="ps-4 fw-bold">
                                <a asp-action="BudgetDetails" asp-route-id="@b.Id" style="color:var(--apple-blue);text-decoration:none;font-weight:600">@b.Name</a>
                                @if (b.IsDanger) { <i class="fa-solid fa-fire ms-1" style="color:var(--danger);font-size:.7rem" title="Vượt 90%"></i> }
                            </td>
                            <td>@b.Department</td>
                            <td class="fw-medium">@b.TotalAmount.ToString("N0") ₫</td>
                            <td class="text-muted">@b.UsedAmount.ToString("N0") ₫</td>
                            <td style="min-width:140px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px;border-radius:4px;">
                                        <div class="progress-bar @barColor progress-bar-animated" style="width:@(Math.Min(pct, 100))%"></div>
                                    </div>
                                    <span class="small fw-bold" style="color:@(b.IsDanger ? "var(--danger)" : b.IsWarning ? "var(--warning)" : "var(--text-muted)")">@pct%</span>
                                </div>
                            </td>
                            <td>
                                @{ var badgeCls = b.Status switch { "Active" => "bg-success", "Closed" => "bg-secondary", "Draft" => "bg-warning text-dark", _ => "bg-secondary" }; }
                                <span class="badge @badgeCls rounded-pill">@b.StatusLabel</span>
                            </td>
                            <td class="text-muted small">@b.PeriodStart.ToString("dd/MM") – @b.PeriodEnd.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center py-5 text-muted"><i class="fa-solid fa-wallet fa-3x mb-3 d-block opacity-50"></i>Chưa có ngân sách</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
