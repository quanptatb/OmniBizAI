@model OmniBizAI.ViewModels.PaymentRequestCreateViewModel
@{ ViewData["Title"] = "Tạo đề nghị thanh toán"; ViewData["Breadcrumb"] = "<a href='/Finance' style='color:var(--apple-blue);text-decoration:none'>Tài chính</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Finance/PaymentRequests' style='color:var(--apple-blue);text-decoration:none'>Thanh toán</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>Tạo mới</span>"; }

<div class="content-card" style="max-width:640px">
    <div class="card-header-custom"><h5><i class="fa-solid fa-file-invoice-dollar"></i> Tạo đề nghị thanh toán</h5></div>
    <div class="card-body-custom">
        <form method="post" asp-action="PaymentCreate">@Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Thanh toán hóa đơn tháng 5..." />
                    <span asp-validation-for="Title" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nhà cung cấp</label>
                    <select asp-for="VendorId" class="form-select">
                        <option value="">— Không chọn —</option>
                        @foreach (var v in Model.Vendors) { <option value="@v.Value">@v.Text</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Đơn mua hàng liên kết</label>
                    <select asp-for="PurchaseOrderId" class="form-select">
                        <option value="">— Không liên kết —</option>
                        @foreach (var po in Model.PurchaseOrders) { <option value="@po.Value">@po.Text</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Tổng tiền (VNĐ) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="TotalAmount" type="number" step="1000" class="form-control" placeholder="0" />
                        <span class="input-group-text">₫</span>
                    </div>
                    <span asp-validation-for="TotalAmount" class="text-danger" style="font-size:.78rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Hạn thanh toán</label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Ghi chú</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nội dung thanh toán, ghi chú thêm..."></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check me-1"></i>Tạo đề nghị</button>
                <a asp-action="PaymentRequests" class="btn btn-light">Hủy</a>
            </div>
        </form>
    </div>
</div>
