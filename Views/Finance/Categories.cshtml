@{
    ViewData["Title"] = "Danh mục chi phí";
}

<section class="page-header">
    <div>
        <span class="eyebrow"><i class="bi bi-tags"></i> Finance</span>
        <h1>Danh mục chi phí</h1>
        <p>Quản lý phân loại thu chi (Category) theo cấu trúc cây (Tree structure) để nhóm ngân sách.</p>
    </div>
    <button class="btn-app" data-bs-toggle="modal" data-bs-target="#categoryModal"><i class="bi bi-plus-circle"></i> Thêm danh mục</button>
</section>

<div class="two-col-grid">
    <article class="panel">
        <div class="panel-header">
            <h2 class="panel-title"><i class="bi bi-diagram-3"></i> Cây danh mục</h2>
        </div>
        <div class="panel-body stack-list">
            <div class="list-item">
                <div>
                    <strong>Marketing & Sales</strong>
                    <small>Type: Expense • Code: MKT-001</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
            <div class="list-item" style="margin-left: 20px; border-left: 2px solid var(--border);">
                <div>
                    <strong>Digital Ads</strong>
                    <small>Type: Expense • Code: MKT-002 • Parent: Marketing & Sales</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
            <div class="list-item" style="margin-left: 20px; border-left: 2px solid var(--border);">
                <div>
                    <strong>Sự kiện (Events)</strong>
                    <small>Type: Expense • Code: MKT-003 • Parent: Marketing & Sales</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
            <div class="list-item">
                <div>
                    <strong>Chi phí vận hành (OpEx)</strong>
                    <small>Type: Expense • Code: OP-001</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
            <div class="list-item" style="margin-left: 20px; border-left: 2px solid var(--border);">
                <div>
                    <strong>Thuê văn phòng</strong>
                    <small>Type: Expense • Code: OP-002 • Parent: Chi phí vận hành</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
            <div class="list-item">
                <div>
                    <strong>Doanh thu dịch vụ</strong>
                    <small>Type: Income • Code: REV-001</small>
                </div>
                <span class="status-badge success">Active</span>
            </div>
        </div>
    </article>
</div>

<!-- Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="categoryModalLabel">Thêm danh mục</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body form-grid">
                <label>
                    Tên danh mục
                    <input type="text" class="form-control" placeholder="Ví dụ: Google Ads" />
                </label>
                <label>
                    Mã danh mục (Code)
                    <input type="text" class="form-control" placeholder="Ví dụ: MKT-004" />
                </label>
                <label>
                    Loại hình (Type)
                    <select class="form-select">
                        <option value="Expense">Chi phí (Expense)</option>
                        <option value="Income">Doanh thu (Income)</option>
                    </select>
                </label>
                <label>
                    Danh mục cha (Parent)
                    <select class="form-select">
                        <option value="">-- Không có (Là Root) --</option>
                        <option value="1">Marketing & Sales</option>
                        <option value="2">Chi phí vận hành</option>
                    </select>
                </label>
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="isActive" checked>
                    <label class="form-check-label" for="isActive">Kích hoạt (Active)</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" data-demo-toast>Lưu danh mục</button>
            </div>
        </div>
    </div>
</div>
