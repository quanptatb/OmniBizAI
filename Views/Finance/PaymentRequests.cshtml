@model OmniBizAI.ViewModels.PaymentRequestListViewModel
@{
    ViewData["Title"] = "Đề nghị Thanh toán";
    ViewData["Breadcrumb"] = "<a href='/Finance' style='color:var(--apple-blue);text-decoration:none'>Tài chính</a> <i class='fa-solid fa-chevron-right mx-2' style='font-size:.6rem;color:var(--text-muted)'></i> <span>Thanh toán</span>";
}

<!-- Stats -->
@{ var pending = Model.Items.Count(p => p.Status is "Draft" or "Submitted"); var approved = Model.Items.Count(p => p.Status is "Approved" or "Paid"); var overdue = Model.Items.Count(p => p.IsOverdue); }
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-file-invoice-dollar"></i></div><div class="stat-value">@Model.TotalCount</div><div class="stat-label">Tổng đề nghị</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon orange"><i class="fa-solid fa-clock"></i></div><div class="stat-value">@pending</div><div class="stat-label">Chờ xử lý</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-check-double"></i></div><div class="stat-value">@approved</div><div class="stat-label">Đã duyệt/TT</div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon red"><i class="fa-solid fa-exclamation-triangle"></i></div><div class="stat-value">@overdue</div><div class="stat-label">Quá hạn</div></div></div>
</div>

<!-- Filter -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex gap-2 flex-wrap">
        @{ var filters = new[] { ("","Tất cả"), ("Draft", EnumHelper.Label<PaymentStatus>("Draft")), ("Submitted", EnumHelper.Label<PaymentStatus>("Submitted")), ("Approved", EnumHelper.Label<PaymentStatus>("Approved")), ("Paid", EnumHelper.Label<PaymentStatus>("Paid")), ("Rejected", EnumHelper.Label<PaymentStatus>("Rejected")) }; }
        @foreach (var (val, lbl) in filters) {
            var isAct = (Model.StatusFilter ?? "") == val;
            <a asp-action="PaymentRequests" asp-route-status="@val" class="btn btn-sm @(isAct ? "btn-primary" : "btn-light")" style="font-size:.78rem">@lbl</a>
        }
    </div>
    <a asp-action="PaymentCreate" class="btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>Tạo đề nghị</a>
</div>

<div class="card content-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">Mã ĐN</th>
                        <th>Nhà cung cấp</th>
                        <th>Người đề nghị</th>
                        <th>Tổng tiền</th>
                        <th>Hạn TT</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Items)
                    {
                        var rowCls = p.IsOverdue ? "style='background:rgba(255,59,48,.03)'" : "";
                        var badgeCls = p.Status switch { "Approved" => "bg-success", "Paid" => "bg-primary", "Rejected" => "bg-danger", "Submitted" => "bg-warning text-dark", _ => "bg-secondary" };
                        <tr @Html.Raw(rowCls)>
                            <td class="ps-4 fw-bold">
                                <a asp-action="PaymentDetails" asp-route-id="@p.Id" style="color:var(--apple-blue);text-decoration:none;font-weight:600">@p.RequestNo</a>
                                @if (p.IsOverdue) { <i class="fa-solid fa-fire ms-1" style="color:var(--danger);font-size:.65rem" title="Quá hạn"></i> }
                            </td>
                            <td>@if(p.VendorName != null) { @p.VendorName } else { <span style="color:var(--text-muted)">—</span> }</td>
                            <td style="font-size:.82rem">@(p.RequestedBy ?? "—")</td>
                            <td class="fw-medium">@p.TotalAmount.ToString("N0") ₫</td>
                            <td style="font-size:.82rem;color:@(p.IsOverdue ? "var(--danger)" : "var(--text-muted)")">@(p.DueDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td><span class="badge @badgeCls rounded-pill">@p.StatusLabel</span></td>
                            <td class="text-muted small">@p.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="text-center py-5 text-muted"><i class="fa-solid fa-file-invoice fa-3x mb-3 d-block opacity-50"></i>Chưa có đề nghị thanh toán</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
