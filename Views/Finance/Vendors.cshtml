@{
    ViewData["Title"] = "Nhà cung cấp";
}

<section class="page-header">
    <div><span class="eyebrow"><i class="bi bi-building-check"></i> Vendor master</span><h1>Nhà cung cấp</h1><p>Quản lý hồ sơ, tài khoản ngân hàng, lịch sử giao dịch và tín hiệu rủi ro theo nhà cung cấp.</p></div>
    <button class="btn-app" data-modal-target="addVendorModal"><i class="bi bi-plus-circle"></i> Thêm NCC</button>
</section>

<div class="modal-overlay" id="addVendorModal">
    <div class="crud-modal">
        <div class="modal-header">
            <h3><i class="bi bi-building-add"></i> Thêm Nhà cung cấp mới</h3>
            <button class="btn-close" data-modal-close>&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-grid">
                <div class="form-group">
                    <label>Tên nhà cung cấp *</label>
                    <input type="text" class="form-control" placeholder="Ví dụ: Google LLC" />
                </div>
                <div class="form-group">
                    <label>Mã số thuế</label>
                    <input type="text" class="form-control" placeholder="MST / Tax ID" />
                </div>
                <div class="form-group">
                    <label>Người liên hệ</label>
                    <input type="text" class="form-control" placeholder="Họ và tên" />
                </div>
                <div class="form-group">
                    <label>Email liên hệ</label>
                    <input type="email" class="form-control" placeholder="email@domain.com" />
                </div>
            </div>
            <div class="form-group mt-2">
                <label>Tài khoản ngân hàng</label>
                <input type="text" class="form-control" placeholder="Số tài khoản - Ngân hàng - Chi nhánh" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-ghost" data-modal-close>Hủy</button>
            <button class="btn-app" data-demo-toast><i class="bi bi-save"></i> Lưu nhà cung cấp</button>
        </div>
    </div>
</div>

<section class="three-col-grid">
    <article class="module-card"><i class="bi bi-google"></i><h3>Google Vietnam</h3><p>Rating 4.8, tổng chi 580 triệu, 2 PR đang mở.</p></article>
    <article class="module-card"><i class="bi bi-meta"></i><h3>Meta Platforms</h3><p>Rating 4.6, tổng chi 340 triệu, không có cảnh báo.</p></article>
    <article class="module-card"><i class="bi bi-microsoft"></i><h3>Microsoft</h3><p>Rating 4.9, license renew Q2 cần duyệt.</p></article>
</section>

<article class="panel mt-3">
    <div class="panel-header"><h2 class="panel-title"><i class="bi bi-table"></i> Vendor directory</h2></div>
    <div class="data-table-wrap">
        <table class="data-table">
            <thead><tr><th>Tên</th><th>Mã thuế</th><th>Liên hệ</th><th>Email</th><th>Tổng chi</th><th>Rating</th><th>Trạng thái</th></tr></thead>
            <tbody>
                <tr><td>Google Vietnam</td><td>0312345678</td><td>Lan Phạm</td><td>billing@google.vn</td><td>580,000,000</td><td>4.8</td><td><span class="status-badge warning">Theo dõi</span></td></tr>
                <tr><td>Meta Platforms</td><td>0108877665</td><td>Minh Trần</td><td>apac@meta.com</td><td>340,000,000</td><td>4.6</td><td><span class="status-badge success">Active</span></td></tr>
            </tbody>
        </table>
    </div>
</article>
