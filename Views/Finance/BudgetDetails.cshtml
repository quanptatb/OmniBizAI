@model OmniBizAI.ViewModels.BudgetDetailViewModel
@{ ViewData["Title"] = Model.Name; ViewData["Breadcrumb"] = "<span>Tài chính</span> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <a href='/Finance/Budgets' style='color:var(--apple-blue);text-decoration:none'>Ngân sách</a> <i class='fa-solid fa-chevron-right' style='font-size:.6rem;margin:0 6px;color:var(--text-muted)'></i> <span>" + Model.Name + "</span>"; }

<div class="row g-3 mb-4">
    <div class="col-md-3 fade-in"><div class="stat-card"><div class="stat-icon blue"><i class="fa-solid fa-money-bill-trend-up"></i></div><div class="stat-value">@Model.PlannedAmount.ToString("N0") ₫</div><div class="stat-label">Kế hoạch</div></div></div>
    <div class="col-md-3 fade-in fade-in-delay-1"><div class="stat-card"><div class="stat-icon orange"><i class="fa-solid fa-receipt"></i></div><div class="stat-value">@Model.UsedAmount.ToString("N0") ₫</div><div class="stat-label">Đã chi</div></div></div>
    <div class="col-md-3 fade-in fade-in-delay-2"><div class="stat-card"><div class="stat-icon green"><i class="fa-solid fa-coins"></i></div><div class="stat-value">@Model.Remaining.ToString("N0") ₫</div><div class="stat-label">Còn lại</div></div></div>
    <div class="col-md-3 fade-in fade-in-delay-2"><div class="stat-card"><div class="stat-icon @(Model.UsagePercent > 90 ? "red" : Model.UsagePercent > 70 ? "orange" : "green")"><i class="fa-solid fa-chart-pie"></i></div><div class="stat-value">@Model.UsagePercent%</div><div class="stat-label">Sử dụng</div></div></div>
</div>

<div class="content-card mb-4"><div class="card-header-custom"><h5><i class="fa-solid fa-piggy-bank"></i> @Model.Name</h5><span class="status-badge-soft badge-on-track"><span class="status-dot"></span>@Model.Status</span></div><div class="card-body-custom">
    <div class="row g-3">
        <div class="col-md-4"><label class="form-label" style="color:var(--text-muted);font-size:.78rem">Phòng ban</label><div style="font-weight:600">@Model.Department</div></div>
        <div class="col-md-4"><label class="form-label" style="color:var(--text-muted);font-size:.78rem">Năm tài chính</label><div>@Model.FiscalYear</div></div>
        <div class="col-md-4">
            <label class="form-label" style="color:var(--text-muted);font-size:.78rem">Tiến độ</label>
            <div class="progress" style="height:8px;border-radius:4px;background:var(--bg-secondary)"><div class="progress-bar" style="width:@(Math.Min(Model.UsagePercent, 100))%;background:@(Model.UsagePercent > 90 ? "var(--apple-red)" : Model.UsagePercent > 70 ? "var(--apple-orange)" : "var(--apple-green)");border-radius:4px"></div></div>
        </div>
    </div>
</div></div>

<div class="content-card"><div class="card-header-custom"><h5><i class="fa-solid fa-list"></i> Chi phí liên quan</h5></div><div class="card-body-custom p-0">
    <table class="data-table">
        <thead><tr><th class="ps-3">Mô tả</th><th>Ngày chi</th><th>Số tiền</th><th class="pe-3">Trạng thái</th></tr></thead>
        <tbody>
            @foreach (var e in Model.Expenses) { <tr><td class="ps-3" style="font-weight:500">@e.Description</td><td style="font-size:.82rem">@e.ExpenseDate.ToString("dd/MM/yyyy")</td><td style="font-weight:600">@e.Amount.ToString("N0") ₫</td><td class="pe-3"><span class="status-badge-soft badge-on-track"><span class="status-dot"></span>@e.Status</span></td></tr> }
            @if (!Model.Expenses.Any()) { <tr><td colspan="4" class="text-center py-3" style="color:var(--text-muted)">Chưa có chi phí</td></tr> }
        </tbody>
    </table>
</div></div>
