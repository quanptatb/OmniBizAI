<script>
  function updateTime() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const d = String(now.getDate()).padStart(2,'0');
    const mo = String(now.getMonth()+1).padStart(2,'0');
    const y = now.getFullYear();
    document.getElementById('time-display').textContent = `Cập nhật lúc ${h}:${m}, ${d}/${mo}/${y}`;
  }
  updateTime();
  setInterval(updateTime, 60000);

  // Modal functions
  function showLogoutModal(e) {
    e.preventDefault();
    document.getElementById('logoutModal').classList.add('active');
  }
  function closeLogoutModal() {
    document.getElementById('logoutModal').classList.remove('active');
  }

  // Progress bars
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.fill[data-w]').forEach(el => {
        el.style.width = el.dataset.w;
      });
    }, 300);
  });

  // Revenue Chart (Line)
  const ctx1 = document.getElementById('revenueChart').getContext('2d');
  new Chart(ctx1, {
    type: 'line',
    data: {
      labels: ['21/4', '22/4', '23/4', '24/4', '25/4', '26/4', '27/4'],
      datasets: [{
        label: 'Doanh thu (triệu ₫)',
        data: [3.2, 3.8, 4.1, 3.5, 4.6, 5.2, 4.8],
        borderColor: '#6c63ff',
        backgroundColor: 'rgba(108, 99, 255, 0.05)',
        borderWidth: 2,
        pointBackgroundColor: '#8b85ff',
        pointBorderColor: '#0a0c12',
        pointRadius: 4,
        pointHoverRadius: 6,
        tension: 0.3,
        fill: true
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: '#5a6280', font: { size: 11 } } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      scales: {
        y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#5a6280' } },
        x: { grid: { display: false }, ticks: { color: '#5a6280' } }
      }
    }
  });

  // Category Chart (Doughnut)
  const ctx2 = document.getElementById('categoryChart').getContext('2d');
  new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: ['Điện tử', 'Gia dụng', 'Thời trang', 'Thực phẩm'],
      datasets: [{
        data: [42, 23, 18, 17],
        backgroundColor: ['#6c63ff', '#2dd4bf', '#fbbf24', '#f472b6'],
        borderWidth: 0,
        hoverOffset: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: '#5a6280', font: { size: 11 }, usePointStyle: true, pointStyle: 'circle' } },
        tooltip: { backgroundColor: '#181c2e', titleColor: '#e2e8f8', bodyColor: '#5a6280' }
      },
      cutout: '65%'
    }
  });
</script>
</body>
</html>